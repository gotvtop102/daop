# GitHub Actions Environment Variables
# Add these to GitHub Repo -> Settings -> Secrets and variables -> Actions
# Prefer "Secrets" for sensitive values.

# REQUIRED (để build enrichment từ TMDB)
# TMDB_API_KEY (SECRET): https://www.themoviedb.org -> Settings -> API -> API Key (v3 auth)
TMDB_API_KEY=

# OPTIONAL (mặc định đã có trong code)
# OPHIM_BASE_URL: base API OPhim (mặc định đã có sẵn trong code)
OPHIM_BASE_URL=https://ophim1.com/v1/api
# OPHIM_FETCH_TIMEOUT_MS: timeout fetch OPhim (ms)
OPHIM_FETCH_TIMEOUT_MS=25000
# OPHIM_IMG_DOMAIN: domain ảnh OPhim (dùng khi normalize link ảnh)
OPHIM_IMG_DOMAIN=https://img.ophim.live

# OPTIONAL (giới hạn build cho nhẹ)
# OPHIM_MAX_PAGES / OPHIM_MAX_MOVIES: giới hạn số trang/số phim OPhim (0 = không giới hạn)
OPHIM_MAX_PAGES=0
OPHIM_MAX_MOVIES=0
# OPHIM_START_PAGE / OPHIM_END_PAGE: giới hạn khoảng trang (để trống = mặc định)
OPHIM_START_PAGE=
OPHIM_END_PAGE=

# OPTIONAL (tắt TMDB nếu muốn build nhanh: SKIP_TMDB=1)
# SKIP_TMDB=1: bỏ qua TMDB enrichment
SKIP_TMDB=0
# VALIDATE_TMDB=1: bật validate thêm cho TMDB
VALIDATE_TMDB=0

# OPTIONAL (Google Sheets phim custom: nếu không dùng sheet thì để trống)
# GOOGLE_SHEETS_ID: ID trong URL sheet: https://docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEETS_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY (SECRET):
# - Cách 1: dán JSON service account (recommended)
# - Cách 2: đường dẫn file JSON trong runner (không khuyến nghị)
# Lấy JSON: Google Cloud Console -> IAM & Admin -> Service Accounts -> Keys -> Create new key (JSON)
# Nhớ share sheet cho email service account (Editor)
GOOGLE_SERVICE_ACCOUNT_KEY=
# GOOGLE_SHEETS_JSON / GOOGLE_SERVICE_ACCOUNT_JSON (SECRET): JSON string của service account
GOOGLE_SHEETS_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON=

# OPTIONAL (đọc một số env từ Supabase rồi export vào workflow env)
# SUPABASE_ADMIN_URL (SECRET): Supabase project (Admin) -> Settings -> API -> Project URL
SUPABASE_ADMIN_URL=
# SUPABASE_ADMIN_SERVICE_ROLE_KEY (SECRET): Supabase project (Admin) -> Settings -> API -> service_role key
SUPABASE_ADMIN_SERVICE_ROLE_KEY=

# OPTIONAL (validate build)
# VALIDATE_BUILD=0 để tắt validate output
VALIDATE_BUILD=1
# VALIDATE_SAMPLE_COUNT: số lượng sample để validate
VALIDATE_SAMPLE_COUNT=200
# GENERATE_MOVIES_LIGHT=1: generate movies-light.js
GENERATE_MOVIES_LIGHT=0

# OPTIONAL (Cloudflare R2: chỉ cần nếu build/upload ảnh hoặc dùng scripts/*-r2.js)
# R2_* (SECRET): Cloudflare Dashboard -> R2 -> Manage R2 API Tokens / Access Keys
# R2_BUCKET_NAME: tên bucket
# R2_PUBLIC_URL: domain public để build link ảnh (vd: https://pub-xxx.r2.dev)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
