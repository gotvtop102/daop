# GitHub Actions Environment Variables
# Add these to GitHub Repo -> Settings -> Secrets and variables -> Actions
# Prefer "Secrets" for sensitive values.

# REQUIRED (để build enrichment từ TMDB)
TMDB_API_KEY=

# OPTIONAL (mặc định đã có trong code)
OPHIM_BASE_URL=https://ophim1.com/v1/api
OPHIM_FETCH_TIMEOUT_MS=25000
OPHIM_IMG_DOMAIN=https://img.ophim.live

# OPTIONAL (giới hạn build cho nhẹ)
OPHIM_MAX_PAGES=0
OPHIM_MAX_MOVIES=0
OPHIM_START_PAGE=
OPHIM_END_PAGE=

# OPTIONAL (tắt TMDB nếu muốn build nhanh: SKIP_TMDB=1)
SKIP_TMDB=0
VALIDATE_TMDB=0

# OPTIONAL (Google Sheets phim custom: nếu không dùng sheet thì để trống)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_SHEETS_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON=

# OPTIONAL (đọc một số env từ Supabase rồi export vào workflow env)
SUPABASE_ADMIN_URL=
SUPABASE_ADMIN_SERVICE_ROLE_KEY=

# OPTIONAL (validate build)
VALIDATE_BUILD=1
VALIDATE_SAMPLE_COUNT=200
GENERATE_MOVIES_LIGHT=0

# OPTIONAL (Cloudflare R2: chỉ cần nếu build/upload ảnh hoặc dùng scripts/*-r2.js)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
