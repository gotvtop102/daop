# =============================================================================
# DAOP — Mẫu Secrets & Variables cho GitHub Actions
# =============================================================================
# GitHub không đọc file .env: dùng checklist này khi thêm vào repo:
#   Settings → Secrets and variables → Actions
#   - Repository secrets  → từng dòng "SECRET" bên dưới
#   - Variables           → mục VARIABLES (không mã hóa, không dùng cho mật khẩu)
#
# Không commit giá trị thật. Đối chiếu workflow: .github/workflows/*.yml
# Chú thích đầy đủ repo + Actions + PAT: docs/github/README.md
# =============================================================================

# ----- Repository secrets (nhạy cảm) -----

# Cloudflare — deploy thư mục public/ lên Pages (Wrangler / pages-action)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Git — workflow commit/push vào main (nhiều job dùng GH_PAT || GITHUB_TOKEN)
# GH_PAT: Personal Access Token (classic), quyền repo + workflow nếu cần — tạo khi GITHUB_TOKEN mặc định không đủ quyền push
GH_PAT=

# OPhim — endpoint API (tùy chọn; mặc định trong workflow: https://ophim1.com/v1/api)
OPHIM_BASE_URL=

# jsDelivr base (kết thúc /public) — trùng site_settings; khuyến nghị trỏ repo ảnh riêng
IMAGE_CDN_BASE=https://cdn.jsdelivr.net/gh/ophim102/cm114@main/public

# Repo chỉ lưu ảnh (owner/repo). GitHub không cho secret bắt đầu bằng GITHUB_ → dùng tên IMAGES_*.
IMAGES_REPO=ophim102/cm114
# IMAGES_TOKEN=   # tuỳ chọn — mặc định GH_PAT hoặc GITHUB_TOKEN trong workflow
# IMAGES_BRANCH=main

# Supabase Admin — script build đọc cấu hình (URL + service_role, không dùng anon)
SUPABASE_ADMIN_URL=
SUPABASE_ADMIN_SERVICE_ROLE_KEY=

# TMDB — metadata khi chạy npm run build trên runner
TMDB_API_KEY=
# Tùy chọn: nhiều key (phân cách phẩy), khi 429 build xoay key — có thể đặt Repository variable
# TMDB_API_KEYS=

# -----------------------------------------------------------------------------
# KHÔNG thêm vào GitHub Secrets (không có trong .github/workflows):
# SUPABASE_USER_* — chỉ dùng trên Vercel cho /api/supabase-user (xem vercel.env.example)
# -----------------------------------------------------------------------------

# =============================================================================
# Repository variables (không bắt buộc — có thể để trống, workflow dùng mặc định)
# Thêm tại: Settings → Secrets and variables → Actions → Variables tab
# =============================================================================

# Tên project Cloudflare Pages khi khác mặc định "daop"
CLOUDFLARE_PAGES_PROJECT_NAME=daop

# Phân trang OPhim khi build (một số workflow đọc vars hoặc input)
OPHIM_START_PAGE=1
OPHIM_END_PAGE=0
OPHIM_FETCH_TIMEOUT_MS=25000

# update-data two-phase / deploy (xem deploy.yml, update-data.yml)
UPDATE_DATA_TWO_PHASE=
UPLOAD_IMAGES_AFTER_BUILD=
# 1 = chỉ deploy Pages sau khi upload/sync ảnh xong (2 pha). Tên cũ: DEPLOY_AFTER_R2_UPLOAD
DEPLOY_AFTER_IMAGE_UPLOAD=
DEPLOY_AFTER_R2_UPLOAD=

# Sau update-data: tự export batches → Supabase. Đặt 1 để tắt bước export
SKIP_EXPORT_TO_SUPABASE=
# Phạm vi export (cùng scripts/export-to-supabase.js): all | custom
EXPORT_TO_SUPABASE_SCOPE=all
