# =============================================================================
# DAOP — Mẫu biến môi trường Vercel (Admin + /api/*)
# =============================================================================
# Dùng làm checklist: copy từng biến vào Vercel → Project → Settings →
# Environment Variables (Production / Preview / Development tùy nhu cầu).
#
# Không đưa file chứa giá trị thật vào Git. TMDB cho build site nằm trên
# GitHub Secrets (TMDB_API_KEY), không thay thế VITE_TMDB_API_KEY nếu cần TMDB trong Admin.
#
# Chú thích đầy đủ từng nhóm biến + route API: docs/vercel/README.md
# =============================================================================

# -----------------------------------------------------------------------------
# Admin (Vite) — bắt buộc để đăng nhập và dùng giao diện quản trị
# Prefix VITE_ được nhúng vào bundle trình duyệt; chỉ dùng anon key, không dùng service_role.
# -----------------------------------------------------------------------------
VITE_SUPABASE_ADMIN_URL=https://xxxx.supabase.co
VITE_SUPABASE_ADMIN_ANON_KEY=

# -----------------------------------------------------------------------------
# Serverless API — bắt buộc cho nút "Build website" và trigger GitHub Actions
# -----------------------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# API /api/supabase-user — import/export dữ liệu user (Supabase project User, không phải Admin)
SUPABASE_USER_URL=https://yyyy.supabase.co
SUPABASE_USER_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Serverless API — Supabase Admin + R2 (/api/movies, /api/upload-image, …)
# -----------------------------------------------------------------------------
SUPABASE_ADMIN_URL=
SUPABASE_ADMIN_SERVICE_ROLE_KEY=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# -----------------------------------------------------------------------------
# Tùy chọn — hành vi GitHub / OPhim / dev local
# -----------------------------------------------------------------------------
# Nhánh GitHub khi gọi workflow (mặc định trong code là main nếu bỏ trống)
GITHUB_REF=main

# Chạy Admin local (localhost): URL bản deploy Vercel để gọi đúng /api/*
# Trên production thường để trống — nhiều chỗ dùng URL tương đối hoặc window.location.origin
VITE_API_URL=

# Trang GitHub Actions trong Admin — OPhim API base (mặc định https://ophim1.com/v1/api)
VITE_OPHIM_BASE_URL=https://ophim1.com/v1/api

# Trang sửa phim — gọi TMDB từ trình duyệt (khác TMDB_API_KEY trên GitHub Actions).
# Đạo diễn / diễn viên lấy tên gốc từ TMDB credits, không qua Google Translate.
VITE_TMDB_API_KEY=
