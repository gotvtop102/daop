# Vercel Environment Variables
# Copy into Vercel Project Settings -> Environment Variables

# REQUIRED (để dùng Admin -> GitHub Actions / trigger build / xem runs)
# GITHUB_TOKEN (SECRET): GitHub -> Settings -> Developer settings -> Personal access tokens -> Tokens (classic)
# - Repo private: chọn scope "repo". Repo public: có thể dùng "public_repo".
GITHUB_TOKEN=
# GITHUB_REPO: dạng "owner/repo" (vd: daop-movie/daop-movie)
GITHUB_REPO=owner/repo

# OPTIONAL (default: main)
# GITHUB_REF: nhánh để trigger workflow (mặc định main)
GITHUB_REF=main

# OPTIONAL (chỉ cần nếu muốn set mặc định cho Google Sheets API; nếu admin gửi spreadsheetId/serviceAccountKey qua request thì không bắt buộc)
# GOOGLE_SHEETS_ID: ID nằm trong URL: https://docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEETS_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY (SECRET):
# - Cách 1: dán JSON service account (recommended)
# - Cách 2: đường dẫn file JSON (chỉ phù hợp nếu runtime có file đó)
# Lấy JSON: Google Cloud Console -> IAM & Admin -> Service Accounts -> Keys -> Create new key (JSON)
# Nhớ share sheet cho email service account (Editor)
GOOGLE_SERVICE_ACCOUNT_KEY=
# GOOGLE_SHEETS_JSON / GOOGLE_SERVICE_ACCOUNT_JSON (SECRET): JSON string của service account (tương tự GOOGLE_SERVICE_ACCOUNT_KEY)
GOOGLE_SHEETS_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON=

# OPTIONAL (chỉ cần nếu dùng chức năng upload ảnh lên R2 qua /api/upload-image)
# R2_* (SECRET): Cloudflare Dashboard -> R2 -> Manage R2 API Tokens / Access Keys
# R2_BUCKET_NAME: tên bucket
# R2_PUBLIC_URL: domain public để build link ảnh (vd: https://pub-xxx.r2.dev)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
