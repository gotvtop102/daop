{
  "name": "daop-movie-system",
  "version": "1.0.0",
  "description": "Hệ thống website phim tĩnh, app đa nền tảng và admin panel",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "build:release": "cross-env MINIFY_ASSETS=1 node scripts/build.js",
    "build:incremental": "node scripts/build.js --incremental",
    "regenerate-actors": "node scripts/regenerate-actors-shards.js",
    "export-to-supabase": "node scripts/export-to-supabase.js",
    "push-pubjs-repo": "node scripts/push-pubjs-to-data-repo.js",
    "refresh-pubjs-urls": "node scripts/refresh-pubjs-jsdelivr-after-push.js",
    "refresh-image-urls": "node scripts/refresh-image-jsdelivr-after-push.js",
    "check-public": "node scripts/check-public-conflict-markers.mjs",
    "clean:public-data": "node scripts/clean-generated-public-data.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.3.1",
    "fs-extra": "^11.2.0",
    "node-fetch": "^3.3.2",
    "sharp": "^0.33.2",
    "slugify": "^1.6.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vercel/node": "^3.0.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.0"
  }
}
