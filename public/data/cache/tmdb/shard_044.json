{"version":1,"entries":{"person_2929020_translations":{"at":1774731920400,"data":{"id":2929020,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Lee Ga-ryeong","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"이가령","primary":true}},{"iso_3166_1":"GR","iso_639_1":"el","name":"ελληνικά","english_name":"Greek","data":{"biography":"Η Lee Ga Ryeong είναι Νοτιοκορεάτισσα ηθοποιός και μοντέλο. Έκανε το ντεμπούτο της το 2012 μέσα από το δράμα του SBS \"A Gentleman's Dignity.\" Είναι περισσότερο γνωστή για τον ρόλο της στη δραματική σειρά Love (ft. Marriage and Divorce) το 2021-2022 (3 σεζόν).","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"李歌领（韩语：이가령，1980年10月2日—）或译李可宁，韩国女演员兼模特儿。原本以艺林（예림）作为艺名，2014年更改为“李歌领”，在结束与SidusHQ的经纪合约后，曾一度将艺名改回“艺林”，但最终仍沿用现时的艺名。曾在2015年的长篇连续剧《不屈的车女士》中担纲主演，但是直到2021年主演《婚词离曲》系列才声名大噪。","name":"李歌领","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"李歌領（韓語：이가령，1980 年 10 月 2 日—）或譯李可寧，韓國女演員兼模特兒。原本以藝林（예림）作為藝名，2014 年更改為“李歌領”，在結束與 SidusHQ 的經紀合約後，曾一度將藝名改回“藝林”，但最終仍沿用現時的藝名。曾在 2015 年的長篇聯續劇《不屈的車女士》中擔綱主演，但是直到 2021 年主演《婚詞離曲》系列才聲名大噪。","name":"李歌領","primary":false}}]}},"tv_70581_detail_vi-VN":{"at":1774731923148,"data":{"adult":false,"backdrop_path":"/bNKkzY9rWxtzCZmMrO62IEO7AEf.jpg","created_by":[{"id":2256974,"credit_id":"5c7cfce30e0a2631f50e8f47","name":"Min Jin-gi","original_name":"Min Jin-gi","gender":0,"profile_path":null},{"id":24991,"credit_id":"5de22ead3faba000190a2b1a","name":"박상연","original_name":"박상연","gender":2,"profile_path":null}],"episode_run_time":[60],"first_air_date":"2017-05-22","genres":[{"id":9648,"name":"Phim Bí Ẩn"},{"id":10765,"name":"Sci-Fi & Fantasy"}],"homepage":"http://program.tving.com/tvn/circle","id":70581,"in_production":false,"languages":["ko"],"last_air_