:4,"vote_average":0}],"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Returning Series","tagline":"","type":"Scripted","vote_average":10,"vote_count":1}},"person_57921_translations":{"at":1773676801048,"data":{"id":57921,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Kitty Winn (born February 21, 1944) is an award-winning American actress.\n\nDescription above from the Wikipedia article Kitty Winn, licensed under CC-BY-SA, full list of contributors on Wikipedia.","name":"Kitty Winn","primary":true}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Kitty Winn (21 de febrero de 1944, Washington, Distrito de Columbia, Estados Unidos) es una actriz estadounidense.\n\nKitty Winn nació en Washington, DC y pasó gran parte de su infancia por China, India y Japón. Ella hizo su debut en Broadway el año 1969 en Las Tres Hermanas y ganó la Palma de Oro en el Festival de Cannes por su rol en la película The Panic in Needle Park, con Al Pacino.\n\nSu papel más conocido fue del personaje de Sharon Spencer en la película El Exorcista (1973) y después en Exorcista II: El Hereje (1977). Su última película fue Espejos (1978) en donde interpreta el rol de Marianne Whitman, una mujer con una maldición.\n\nActualmente está trabajando en Broadway.","name":"","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"키티 윈","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"Kitty Winn（1944 年 2 月 21 日出生）是一位屡获殊荣的美国女演员。","name":"吉蒂·温","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"吉蒂·温（1944 年 2 月 21 日出生）是一位屢獲殊榮的美國女演員。","name":"吉蒂·温","primary":false}}]}},"person_5983843_translations":{"at":1773676809099,"data":{"id":5983843,"translations":[{"iso_3166_1":"SE","iso_639_1":"sv","name":"svenska","english_name":"Swedish","data":{"biography":"","name":"Steve Janaszak","primary":true}}]}},"person_2679439_translations":{"at":1773676816730,"data":{"id":2679439,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Dianne Simpson","primary":true}}]}},"person_212821_translations":{"at":1773676831764,"data":{"id":212821,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Christa Miller (born May 28, 1964) is an American actress who has achieved success in television comedy series. Her foremost roles include Kate O'Brien on The Drew Carey Show and Jordan Sullivan on Scrubs (which was created by her husband Bill Lawrence). She has also made appearances on Seinfeld and CSI: Miami. Since 2009, she has a starring role in the ABC sitcom Cougar Town, also created by husband Bill Lawrence.\n\nDescription above from the Wikipedia article Christa Miller, licensed under CC-BY-SA, full list of contributors on Wikipedia.","name":"Christa Miller","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Mit 16 drehte Miller ihren ersten Werbespot für Polaroid. Ihre erste Rolle spielte sie 1985 als Gast in der Fernsehserie Kate & Allie. Für diese Rolle hatte sie selbst vorgesprochen und diese ohne Hilfe ihrer Tante Susan Saint James erhalten, die die Hauptrolle in der Serie spielte. 1990 zog Miller nach Los Angeles. Zunächst trat sie in Gastrollen in Fernsehserien wie Ausgerechnet Alaska, Seinfeld, Der Prinz von Bel-Air und Party of Five auf. Filmauftritte hatte Miller zumeist nur in Fernsehfilmen wie Stepfather III – Vatertag oder Andromeda – Tödlicher Staub aus dem All.\n\n1995 bekam sie als Kate eine Rolle in der neuen Sitcom Drew Carey Show und schaffte hier ihren Durchbruch. 1999 heiratete sie den Fernsehproduzenten Bill Lawrence. Nachdem sie 2002 die Drew Carey Show verlassen hatte, trat sie als regulärer Gaststar häufig in Scrubs – Die Anfänger, einer Produktion ihres Mannes, auf. Mit Lawrence hat sie drei Kinder (* 2000, 2003 und 2006). Ihre letzten beiden Schwangerschaften flossen in ihre Rolle der Jordan Sullivan in Scrubs ein. Für ihre Rolle in Scrubs wurde Miller 2003 und 2004 als „Beste Nebendarstellerin in einer Serie (Komödie/Musical) (Best Performance by an Actress in a Supporting Role in a Series, Comedy or Musical)“ für einen Satellite Award nominiert.\n\nVon 2009 bis 2015 war Miller in der Rolle der Ellie Torres in der Comedy-Serie Cougar Town zu sehen, die ebenfalls von ihrem Mann produziert wurde.  __________\n\nDies ist ein Auszug  aus der deutschsprachigen Wikipedia. Der vollständige Artikel (/wiki/Christa_Miller) ist unter der Lizenz „Creative Commons Attribution/Share Alike“ verfügbar. Alle beitragenden Personen können der Quelle entnommen werden.","name":"","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Christa Miller (28 de mayo de 1964) es una actriz y ex-modelo estadounidense.","name":"","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"クリスタ・ミラー","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Кріста Міллер","primary":false}},{"iso_3166_1":"IR","iso_639_1":"fa","name":"فارسی","english_name":"Persian","data":{"biography":"","name":"کریستا میلر","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Криста Миллер","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"크리스타 밀러","primar