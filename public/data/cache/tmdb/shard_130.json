nglish_name":"Turkish","iso_639_1":"tr","name":"Türkçe"}],"status":"Released","tagline":"","title":"Il deserto rosso","video":false,"vote_average":7.3,"vote_count":499}},"tv_306916_keywords":{"at":1773688725474,"data":{"id":306916,"results":[{"name":"transmigration","id":12320},{"name":"historical fiction","id":12995},{"name":"costume drama","id":195013}]}},"person_119447_translations":{"at":1773688728250,"data":{"id":119447,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Shing Fui-On (成奎安; 1 February 1955 - 27 August 2009) was a Hong Kong actor. He is best known for his supporting roles in Hong Kong cinema, and only had one leading role in his entire career. His older brother, Shing Fu-On (成福安), was also an actor. Fui On died on August 17, 2009 from a nasopharyngeal carcinoma.","name":"Shing Fui-On","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"성규안","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"成奎安（Fui-On Shing，1955年2月1日-2009年8月27日），出生于香港，中国香港影视男演员。\n\n1978年，成奎安被香港艺人李修贤发掘而进入影视圈发展。  1985年，在电影《吉人天相》中首次扮演了“大傻”这个角色。1986年，主演动作电影《英雄本色》。1987年，因在电影《监狱风云》中再次饰演大傻一角而被人们所熟识。同年，还出演了《英雄本色2》，再次赢得了影迷的肯定。1989年，主演动作电影《喋血双雄》并饰演黑社会老大汪海。1990年，主演无线剧集《900重案追凶》，这也是他唯一一次也是最后一次当主角。1996年，成奎安开始来到内地娱乐圈发展。2001年，主演时装剧《美味情缘》。 2004年，成奎安被诊断患上鼻咽癌。 2009年8月27日晚23时45分，成奎安因鼻咽癌扩散医治无效，在香港浸会医院病逝，享年54岁。","name":"","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"成奎安，出生於香港，香港影視男演員。\n\n1978 年，成奎安被香港藝人李修賢發掘而進入影視圈發展。\n\n1985 年，在電影《吉人天相》中首次扮演了“成奎安”這個角色。1986 年，主演動作電影《英雄本色》。1987 年，因在電影《監獄風雲》中再次飾演成奎安一角而被人們所熟識。同年，還出演了《英雄本色 2》，再次贏得了影迷的肯定。1989 年，主演動作電影《喋血雙雄》並飾演黑社會老大汪海。1990 年，主演無線劇集《900 重案追兇》，這也是他唯一一次也是最後一次當主角。1996 年，成奎安開始來到內地娛樂圈發展。2001 年，主演時裝劇《美味情緣》。\n\n2004 年，成奎安被診斷患上鼻嚥癌。\n\n2009 年 8 月 27 日晚 23 時 45 分，成奎安因鼻嚥癌擴散醫治無效，在香港浸會醫院病逝，享年 54 歲。","name":"成奎安","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Shing Fui-on","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Thành Khuê An","primary":false}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"Shing Fui-On","primary":false}}]}},"person_5702035_translations":{"at":1773688729030,"data":{"id":5702035,"translations":[]}},"person_3159943_translations":{"at":1773688729771,"data":{"id":3159943,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Jeslyn Gorman is a singer, songwriter and dancer based out of Los Angeles. Gorman has toured with multiple top artists including Taylor Swift.","name":"Jeslyn Gorman","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"Jeslyn Gorman 是一位来自洛杉矶的歌手、词曲作者和舞者。戈尔曼曾与包括泰勒·斯威夫特在内的多位顶级艺术家一起巡回演出。","name":"杰斯林·戈尔曼","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"傑斯林·戈爾曼 是一位來自洛杉磯的歌手、詞曲作者和舞者。戈爾曼曾與包括泰勒·斯威夫特在內的多位頂級藝術家一起巡迴演出。","name":"傑斯林·戈爾曼","primary":false}}]}},"person_2646053_translations":{"at":1773688732000,"data":{"id":2646053,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Kim Hee-Tae (Korean: 김희태; born May 8, 1977), better known by his English-language name Sam Kim (Korean: 샘 킴) is a South Korean chef and television personality.","name":"Sam Kim","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"샘 킴","primary":true}}]}},"tv_263048_credits":{"at":1773688732678,"data":{"cast":[{"adult":false,"gender":1,"id":126777,"known_for_department":"Acting","name":"Michelle Chen Yan-Hsi","original_name":"