na"}],"seasons":[{"air_date":"2026-01-22","episode_count":30,"id":496226,"name":"Season 1","overview":"","poster_path":null,"season_number":1,"vote_average":0}],"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Ended","tagline":"","type":"Scripted","vote_average":7.333,"vote_count":3}},"person_2086256_translations":{"at":1773676815872,"data":{"id":2086256,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Pan Binlong","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"潘斌龙，出生于黑龙江省鸡西市，中国内地影视演员、相声小品演员。师从相声表演艺术家冯巩，戏剧表演艺术教育家常莉。毕业于中央戏剧学院相声表演班。\n\n2004年，考入中央戏剧学院相声表演班。2005年，参加北京电视台全国相声小品邀请赛并获得一等奖。2008年，第一次登上中央电视台春节联欢晚会的舞台并表演相声剧《公交协奏曲》，饰演上错车的老太太。2009年1月19日，在北京电视台春节联欢晚会上表演的相声剧《返乡》。 2012年，担任黑龙江卫视喜剧类综艺节目《快乐都市之爱笑会议室》主要演员。2013年，主演黑色幽默电影《一路狂奔》。2014年主演电影《煎饼侠》饰演大鹏助理董成龙。2016年参加《欢乐喜剧人第二季》，与崔志佳组合，并凭借小品《老爸》夺得了第一期冠军，从而受到更多关注。2018年，潘斌龙参演喜剧电影《无名之辈》。","name":"潘斌龙","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"潘斌龍","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Phan Bân Long","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"潘斌龍，出生於黑龍江省雞西市，中國內地影視演員、相聲小品演員。師從相聲表演藝術家馮鞏，戲劇表演藝術教育家常莉。畢業於中央戲劇學院相聲表演班。\n\n2004 年，考入中央戲劇學院相聲表演班。2005 年，參加北京電視台全國相聲小品邀請賽並獲得一等獎。2008 年，第一次登上中央電視台春節聯歡晚會的舞台並表演相聲劇《公交協奏曲》，飾演上錯車的老太太。2009 年 1 月 19 日，在北京電視台春節聯歡晚會上表演的相聲劇《返鄉》。\n\n2012 年，擔任黑龍江衞視喜劇類綜藝節目《快樂都市之愛笑會議室》主要演員。2013 年，主演黑色幽默電影《一路狂奔》。2014 年主演電影《煎餅俠》飾演大鵬助理董成龍。2016 年參加《歡樂喜劇人第二季》，與崔志佳組合，並憑藉小品《人父心事》奪得了第一期冠軍，從而受到更多關注。2018 年，潘斌龍參演喜劇電影《無名之輩》。","name":"潘斌龍","primary":false}}]}},"person_5144265_translations":{"at":1773676822238,"data":{"id":5144265,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English"