{"version":1,"entries":{"person_1356727_translations":{"at":1774722345010,"data":{"id":1356727,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Beam Saranyoo Prachakrit is a Thai actor, DJ and TV host.","name":"Sarunyoo Prachakit","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"ศรัณยู ประชากริช","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"","primary":false}}]}},"person_5024758_translations":{"at":1774722348995,"data":{"id":5024758,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"孙仲秋","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Sun Zhongqiu","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"孫仲秋","primary":false}}]}},"person_1232599_translations":{"at":1774722354981,"data":{"id":1232599,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Matthew Maher (born 1971/1972 in Arkabutla, Mississippi) is an American film, voice and theater actor. He is best known for providing the voice of Wade Hebert in the 2013 video game Grand Theft Auto V. Maher also appeared in TV shows like Clerks, Law & Order: Special Victims Unit and The Unusuals.","name":"Matthew Maher","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Matthew Maher ist ein US-amerikanischer Schauspieler, der für seine vielseitigen Charakterrollen bekannt ist. Er wurde in den 1970er Jahren geboren und begann seine Karriere in der Off-Broadway-Theaterszene, wo er sich schnell als talentierter Darsteller etablierte. Maher ist bekannt für seine Fähigkeit, exzentrische und tiefgründige Figuren zu verkörpern, die oft eine besondere Eigenart oder skurrile Persönlichkeit besitzen.\n\nSein Filmdebüt gab er in den frühen 2000er Jahren, und seitdem hat er in zahlreichen Independent- und Hollywood-Produktionen mitgewirkt. Zu seinen bekanntesten Filmen gehören „Gone Baby Gone“ (2007), „Captain Marvel“ (2019) und „Air“ (2023). Neben seiner Arbeit im Kino hat Maher auch in Fernsehserien wie „The Outsider“ und „Mozart in the Jungle“ mitgewirkt.\n\nMaher ist ein gefragter Charakterdarsteller, der oft in Nebenrollen brilliert und seinen Figuren eine besondere Tiefe verleiht. Seine markante Erscheinung und sein einzigartiger Schauspielstil haben ihn zu einem beliebten Darsteller für Regisseure gemacht, die nach unverwechselbaren Charakteren suchen. Neben seiner Film- und Fernsehkarriere bleibt er dem Theater treu und tritt regelmäßig in Bühnenproduktionen auf.\n\nMaher ist bekannt für seine bescheidene und zurückhaltende Art, die ihn in der Branche zu einem geschätzten Kollegen macht. Trotz seiner langen Karriere bleibt er ein eher unauffälliger Star, der sich auf die Kunst des Schauspielens konzentriert und weniger auf öffentliche Aufmerksamkeit.","name":"","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"马修·马赫","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"매튜 마허","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Мэттью Мехер","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"マシュー・マー","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"馬修·馬希爾","primary":false}},{"iso_3166_1":"SA","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"","name":"ماثيو ماهر","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"馬修·馬希爾","primary":false}}]}},"person_2148055_translations":{"at":1774722355142,"data":{"id":2148055,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Zhao Liang","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"赵亮，现隶属成都军区话剧团的赵亮在登上荧屏大红大紫之前，曾说过相声、演过哑剧、排过话剧。但刚刚出演《康熙微服私访记》“三德子”一角的时候，他还是无法对角色做到驾轻就熟，一直到了《风流才子纪晓岚》的时候，赵亮才算是找到了感觉，成为新一代的喜剧明星","name":"赵亮","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Liang Zhao","primary":true}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"趙亮，現隸屬成都軍區話劇團的趙亮在登上熒屏大紅大紫之前，曾説過相聲、演過啞劇、排過話劇。但剛剛出演《康熙微服私訪記》“三德子”一角的時候，他還是無法對角色做到駕輕就熟，一直到了《風流才子紀曉嵐》的時候，趙亮才算是找到了感覺，成為新一代的喜劇明星","name":"趙亮","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Чжао Лян","primary":false}}]}},"movie_1499984_credits":{"at":1774722355586,"data":{"id":1499984,"cast":[{"adult":false,"gender":2,"id":1466559,"known_for_department":"Acting","name":"D.Y. Sao","original_name":"D.Y. Sao","popularity":0.4633,"profile_path":"/1CRoavLS9F5qvJBxos3wVzBblAd.jpg","cast_id":1,"character":"Max Yen","credit_id":"685218175e0a818692efa9bb","order":0},{"adult":false,"gender":2,"id":1068877,"known_for_department":"Acting","name":"Andy Le","original_name":"Andy Le","popularity":0.7364,"profile_path":"/46hI8q3ufjUsYZ3rSTYP8AnOvRc.jpg","cast_id":3,"character":"Wu Yen","credit_id":"68521847b9e659bf0dfb5079","order":1},{"adult":false,"gender":2,"id":2410189,"known_for_department":"Acting","name":"Bria