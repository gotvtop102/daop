{"version":1,"entries":{"person_1338063_translations":{"at":1772689420835,"data":{"id":1338063,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"　　黄志忠，中国内地男演员，毕业于中央戏剧学院，出生于天津，曾为天津体工大队青年队篮球运动员，因在电视剧《人间正道是沧桑》中扮演反面人物杨立仁而走红，在热播剧《中国远征军》、《新亮剑》中塑造了多个“荧幕硬汉”形象。","name":"黄志忠","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Huang Zhizhong is Chinese actor born in 5 March 1969 in Tianjin. Huang was a basketball player at a young age. After he retired from basketball team, he worked in Tianjin Textile manufacturing factory as a Machinist fitter. Later， he enter Tianjin Trade union Academy for a short training. In 1991, Huang attended the Central Academy of Drama, where he graduated in 1995. He has since gone on to star in numerous TV dramas and films, he is famous known by most audience since historical TV series The Road We Have Taken 2009","name":"Huang Zhizhong","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"黃志忠","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"黃志忠，中國內地男演員，畢業於中央戲劇學院，出生於天津，曾為天津體工大隊青年隊籃球運動員，因在電視劇《人間正道是滄桑》中扮演反面人物楊立仁而走紅，在熱播劇《中國遠征軍》、《新亮劍》中塑造了多個“熒幕硬漢”形象。","name":"黃志忠","primary":false}}]}},"movie_1518130_credits":{"at":1772689424681,"data":{"id":1518130,"cast":[{"adult":false,"gender":2,"id":131513,"known_for_department":"Acting","name":"Xiao Shenyang","original_name":"小沈阳","popularity":1.2952,"profile_path":"/9Z79wV40mQ59w22AlpVAMDUk8hT.jpg","cast_id":2,"character":"Peng","credit_id":"6881cec265f0807e59d9a0da","order":0},{"adult":false,"gender":2,"id":3809435,"known_for_department":"Acting","name":"Wang Wei","original_name":"王唯","popularity":0.4583,"profile_path":"/44TjzkCGx3GI1pDNlsttJonpjZ1.jpg","cast_id":3,"character":"","credit_id":"6881cec820e51d61b7245804","order":1},{"adult":false,"gender":2,"id":5711787,"known_for_department":"Acting","name":"张登平","original_name":"张登平","popularity":0.2961,"profile_path":"/9RUQzRQQjzNr9PvFPqg708VEt0Z.jpg","cast_id":5,"character":"","credit_id":"68d5f460b54861613cc833a2","order":2},{"adult":false,"gender":1,"id":1387957,"known_for_department":"Acting","name":"Ni Jingyang","original_name":"倪景阳","popularity":0.8237,"profile_path":"/9W0bL3jX0NenH70EJL3xQ5K2PE9.jpg","cast_id":6,"character":"","credit_id":"68d5f93eb91d9c7d73c83441","order":3}],"crew":[{"adult":false,"gender":2,"id":5583325,"known_for_department":"Directing","name":"Zhao Yu","original_name":"Zhao Yu","popularity":0.426,"profile_path":"/z7jcqeu2g07IL7GNhjZTGWe5GIO.jpg","credit_id":"6881ce7365f0807e59d9a0d3","department":"Directing","job":"Director"},{"adult":false,"gender":2,"id":5583325,"known_for_department":"Directing","name":"Zhao Yu","original_name":"Zhao Yu","popularity":0.426,"profile_path":"/z7jcqeu2g07IL7GNhjZTGWe5GIO.jpg","credit_id":"6881cef539f21967c5d9a319","department":"Writing","job":"Writer"},{"adult":false,"gender":2,"id":121136,"known_for_department":"Directing","name":"Zhang Meng","original_name":"Zhang Meng","popularity":0.456,"profile_path":"/c69lcDcNk3X4aPJraYRvHoUAq4k.jpg","credit_id":"68ff475bb3cd0c6651a31127","department":"Production","job":"Executive Producer"}]}},"person_2684219_translations":{"at":1772689425041,"data":{"id":2684219,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Tommy Chu Pak-Hong","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"朱栢康","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"朱淩淩（Juicyning）為香港的男子戲劇表演組合暨獨立樂隊，成立於 2005 年 9 月，成員全為香港演藝學院畢業生－包括淩智豪（白只），楊偉倫（阿卵），陳文進（阿 Chris），朱柏謙（朱謙）及朱柏康（朱栢康），以搞笑加憤怒加不拘一格加騎呢造型著名。樂隊音樂方向是致力以音樂改變生命，希望讓人們反省生命並重整價值觀，同時亦與世界分享我們之生活體驗，把朱淩淩的音樂傳送世界。\n\n樂隊名稱諧音朱玲玲（香港小姐），來自創始成員淩智豪及朱柏謙、朱柏康兄弟的姓氏。由於淩身形龐大，被戲謔一個人比朱氏兄弟兩個加起來還要大，故樂隊名稱“淩”字也佔雙份。","name":"朱栢康","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"　　朱凌凌（Juicyning）为香港的男子戏剧表演组合暨独立乐队，成立于2005年9月，成员全为香港演艺学院毕业生－包括凌智豪（白只），杨伟伦（阿卵），陈文进（阿Chris），朱柏谦（朱谦）及朱柏康（朱康），以搞笑加愤怒加不拘一格加骑呢造型著名。乐队音乐方向是致力以音乐改变生命，希望让人们反省生命并重整价值观，同时亦与世界分享我们之生活体验，把朱凌凌的音乐传送世界。\n\n　　乐队名称谐音朱玲玲（香港小姐），来自创始成员凌智豪及朱柏谦、朱柏康兄弟的姓氏。由于凌身形庞大，被戏谑一个人比朱氏兄弟两个加起来还要大，故乐队名称“凌”字也占双份。","name":"朱栢康","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Pak Hon Chu","primary":false}}]}},"person_5461125_translations":{"at":1772689426454,"data":{"id":5461125,"translations":[{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"ปารมี เหลืองนฤมิตชัย","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Paramee Luengnaruemitchai","primary":false}}]}},"movie_1262815_keywords":{"at":1772689429753,"data":{"id":1262815,"keywords":[{"id":2504,"name":"world war i"},{"id":2318,"name":"choir"},{"id":9180,"name":"yorkshire"},{"id":15060,"name":"period drama"},{"id":208156,"name":"frantic"},{"id":210184,"name":"1910s"},{"id":296608,"name":"teenager"},{"id":356539,"name":"choral"}]}},"movie_1238379_keywords":{"at":1772689432812,"data":{"id":1238379,"keywords":[{"id":9799,"name":"romcom"}]}},"person_1255182_translations":{"at":1772689441292,"data":{"id":1255182,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Sei Matobu is a Japanese actress who is a former Hanagumi Top Star of the Takarazuka Revue. In addition to her stage roles, she has acted for television, feature films, radio and advertisements. She is represented by Watanabe Entertainment. Born in Kawasaki, Kanagawa, she is nicknamed \"Yuu\".","name":"Sei Matobu","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"真飛聖","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"真飞圣","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Sei Matobu","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"真飛聖","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Сей Матобу","primary":false}}]}},"person_145248_translations":{"at":1772689446517,"data":{"id":145248,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Christopher Pang (born 29 December 1984) is an Australian actor and producer. He is best known for his role as Colin Khoo in Crazy Rich Asians (2018) and Lee Takkam in Tomorrow, When the War Began (2010).\n\nDescription above from the Wikipedia article Chris Pang, licensed under CC-BY-SA, full list of contributors on Wikipedia.","name":"Chris Pang","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"吴育刚（英语：Chris Pang, 1984年12月29日—）是澳大利亚华人演员。\n\n克里斯·彭（Christopher Pang）是台湾华裔澳大利亚演员和制片人。他最出名的是他在《明天，当战争开始时》中扮演“李”的角色，这部电影在澳大利亚取得了票房上的成功。","name":"吴育刚","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Christopher Pang ist ein australischer Schauspieler und Produzent mit taiwanesisch-chinesischen Wurzeln. Er ist am besten bekannt für seine Rolle als \"Lee\" in \"Tomorrow, When the War Began\", der in Australien ein Kassenerfolg war.","name":"","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Крис Пан","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"吳育剛（英語：Chris Pang, 1984 年 12 月 29 日—）是澳大利亞華人演員。\n\n克里斯·彭（Christopher Pang）是台灣華裔澳大利亞演員和制片人。他最出名的是他在《明天，當戰爭開始時》中扮演“李”的角色，這部電影在澳大利亞取得了票房上的成功。","name":"吳育剛","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"크리스 팽","primary":false}}]}},"tv_120738_detail_vi-VN":{"at":1772689448092,"data":{"adult":false,"backdrop_path":"/pxdTnJULQSspc05mKeOm4bU7jR5.jpg","created_by":[],"episode_run_time":[15],"first_air_date":"2019-04-30","genres":[{"id":16,"name":"Phim Hoạt Hình"},{"id":10762,"name":"Kids"}],"homepage":"","id":120738,"in_production":true,"languages":["zh"],"last_air_date":"2024-09-23","last_episode_to_air":{"id":5650744,"name":"Episode 26","overview":"","vote_average":0,"vote_count":0,"air_date":"2024-09-23","episode_number":26,"episode_type":"finale","production_code":"","runtime":13,"season_number":8,"show_id":120738,"still_path":"/5gaN94oLvAFdmDVJthu7BsBq56W.jpg"},"name":"猪猪侠之恐龙日记","next_episode_to_air":null,"networks":[],"number_of_episodes":208,"number_of_seasons":8,"origin_country":["CN"],"original_language":"zh","original_name":"猪猪侠之恐龙日记","overview":"","popularity":0.6377,"poster_path":"/r4JcYRHKYdr69fUCxRS2kipOksU.jpg","production_companies":[],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"seasons":[{"air_date":"2019-04-30","episode_count":26,"id":185840,"name":"Season 1","overview":"","poster_path":"/9EYsrVkb8kUEwMW24oe1H8K3RnI.jpg","season_number":1,"vote_average":0},{"air_date":"2019-08-16","episode_count":26,"id":185907,"name":"Season 2","overview":"","poster_path":"/ecsRSQKPpQy1jPfwXw0Y4X1SU5F.jpg","season_number":2,"vote_average":0},{"air_date":"2020-06-24","episode_co