]}},"movie_1368166_detail_vi-VN":{"at":1772689480003,"data":{"adult":false,"backdrop_path":"/5Q71GYwh2mOz5rr8tPTcvbeBWtN.jpg","belongs_to_collection":{"id":1611146,"name":"Loạt Phim Cô Hầu Gái","poster_path":"/nzfd4GSmANTyJVVryteFU3Xjuje.jpg","backdrop_path":"/lu7VARBXX1B5XjwYh3KhcV7WlGW.jpg"},"budget":35000000,"genres":[{"id":18,"name":"Phim Chính Kịch"},{"id":9648,"name":"Phim Bí Ẩn"},{"id":53,"name":"Phim Gây Cấn"}],"homepage":"","id":1368166,"imdb_id":"tt27543632","origin_country":["US"],"original_language":"en","original_title":"The Housemaid","overview":"Từ đạo diễn Paul Feig, một thế giới hỗn loạn sẽ mở ra, nơi sự hoàn hảo chỉ là ảo giác và mọi thứ dường như đều đang che đậy một bí mật đằng sau. Để chạy trốn khỏi quá khứ, Millie (Sydney Sweeney) trở thành bảo mẫu cho gia đình Nina (Amanda Seyfried) và Andrew (Brandon Sklener), một cặp đôi giàu có. Nhưng ngay khi cô chuyển vào sống chung và bắt đầu công việc \"trong mơ\", sự thật dần được hé lộ - đằng sau vẻ ngoài xa hoa lộng lẫy là mối nguy lớn hơn bất cứ thứ gì Millie có thể tưởng tượng. Một trò chơi đầy cám dỗ của bí mật và quyền lực sắp bắt đầu.","popularity":91.9749,"poster_path":"/vpHLCt2bwYmmkGH4soqJNIFLOUQ.jpg","production_companies":[{"id":1632,"logo_path":"/cisLn1YAUuptXVBa0xjq7ST9cH0.png","name":"Lionsgate","origin_country":"US"},{"id":221429,"logo_path":"/7xNNmHcuDy0tOqZmsUMnZ6HcZ6E.png","name":"Media Capital Technologies","origin_country":"US"},{"id":198785,"logo_path":"/oBnMrmwnlAKcACe5h7Vwmk8m1CC.png","name":"Hidden Pictures","origin_country":"US"},{"id":284257,"logo_path":null,"name":"Pretty Dangerous Pictures","origin_country":"US"}],"production_countries":[{"iso_3166_1":"US","name":"United States of America"}],"release_date":"2025-12-18","revenue":383000000,"runtime":131,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"Khám phá bí mật đằng sau cánh cửa.","title":"Cô Hầu Gái","video":false,"vote_average":7.26,"vote_count":1383}},"