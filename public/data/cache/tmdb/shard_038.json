{"version":1,"entries":{"tv_99607_credits":{"at":1774728573189,"data":{"cast":[],"crew":[{"adult":false,"gender":1,"id":3295321,"known_for_department":"Acting","name":"Kang Sook","original_name":"Kang Sook","popularity":0.8452,"profile_path":"/3sF8B2Ao6aTrJSqGG58fL3O2y7J.jpg","credit_id":"693e597c0a25a85155f787b3","department":"Directing","job":"Continuity"},{"adult":false,"gender":1,"id":3295321,"known_for_department":"Acting","name":"Kang Sook","original_name":"Kang Sook","popularity":0.8452,"profile_path":"/3sF8B2Ao6aTrJSqGG58fL3O2y7J.jpg","credit_id":"693e5988705c0e3b2c99ebc0","department":"Writing","job":"Storyboard"}],"id":99607}},"person_126485_translations":{"at":1774728574763,"data":{"id":126485,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Yumiko Kobayashi","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"小林由美子是日本的女性聲優。出身於千葉縣匝瑳市，畢業於和洋女子大學畢業、日本播音表演研究所的聲優學校 Animeju。","name":"小林由美子","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"小林由美子","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"小林由美子（日语：小林 由美子／こばやし ゆみこ Kobayashi Yumiko，1979年6月18日—），日本女性声优，出生于千叶县八日市场市（即现匝瑳市）。\n\n2006年4月7日在个人网站宣布结婚。2007年9月由于母亲及祖母接连过世，因此宣布退出ARTSVISION事务所。\n\n2018年6月1日，矢岛晶子卸下长年担任《蜡笔小新》主角野原新之助的配音。经过两周之后的6月14日，动画官方正式宣布决定由小林接任。","name":"小林由美子","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Yumiko Kobayashi","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"코바야시 유미코","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Jumiko Kobajaši","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Yumiko Kobayashi","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"โคบายาชิ ยูมิโกะ","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Yumiko Kobayashi (小林 由美子, Kobayashi Yumiko, nacida el 18 de junio de 1979) es una actriz de voz japonesa de la ciudad de Sosa, prefectura de Chiba.","name":"Yumiko Kobayashi","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Юміко Кобаяші","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"小林由美子，日本女性聲優，出身於千葉縣八日市場市。2007 年 9 月退出 ARTSVISION 事務所。2018 年 6 月 1 日，矢島晶子卸下長年擔任《蠟筆小新》主角野原新之助的配音。同年 6 月 14 日，動畫官方正式宣佈由小林由美子接任。","name":"小林由美子","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Юмико Кобаяши","primary":false}}]}}}}