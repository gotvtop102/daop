al_name":"陆三三","popularity":0.0071,"profile_path":null,"credit_id":"69692a65599f190718e712cc","department":"Sound","job":"Theme Song Performance"},{"adult":false,"gender":0,"id":4504411,"known_for_department":"Sound","name":"Lu San San","original_name":"陆三三","popularity":0.0071,"profile_path":null,"credit_id":"69692a779da6d82d53f40d4d","department":"Writing","job":"Lyricist"},{"adult":false,"gender":2,"id":3998514,"known_for_department":"Acting","name":"Wu Jifeng","original_name":"Jifeng Wu","popularity":0.389,"profile_path":"/hPY2nc3AJfkz6BCtBKBBZ7IK2HN.jpg","credit_id":"69692bd1f46ad238d5f40d88","department":"Writing","job":"Lyricist"}],"id":278096}},"person_5888684_translations":{"at":1773688735760,"data":{"id":5888684,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Ted Maher (born June 9, 1958) is an American former nurse who became the focus of international media attention following a high-profile criminal case in Monaco. While working as a personal nurse in the Monaco penthouse of billionaire banker Edmond Safra, Maher was convicted in 2002 of arson causing the 1999 fire that killed Safra and another caregiver, after initially giving conflicting accounts of the circumstances. He was sentenced to ten years in prison and released in October 2007 after serving eight years behind bars.  Following his release, Maher’s life remained marked by legal troubles. Under the name Jon Green, he faced multiple charges in the United States, including an unsuccessful plot to solicit the killing of his then-wife, Kim Lark. In March 2025 he was found guilty of solicitation to commit first-degree murder in connection with that plot and received the maximum sentence permitted for the charge.","name":"Ted Maher","primary":true}}]}},"person_559958_translations":{"at":1773688737392,"data":{"id":559958,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Mikhail Filippov","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Михаил Филиппов","primary":true}}]}},"movie_405373_detail_vi-VN":{"at":1773688737932,"data":{"adult":false,"backdrop_path":"/jnLtdHYpYjULtDfHBSEi87DAZeK.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":9648,"name":"Phim Bí Ẩn"},{"id":53,"name":"Phim Gây Cấn"}],"homepage":"","id":405373,"imdb_id":"tt5920348","origin_country":["RU"],"original_language":"ru","original_title":"Чистое искусство","overview":"","popularity":1.5686,"poster_path":"/kk8cWBVu56195WdZ0U3SQGaCI06.jpg","production_companies":[{"id":11989,"logo_path":null,"name":"Interfest","origin_country":"RU"},{"id":11987,"logo_path":"/1JNEKggH6b65vcQB6h2YenZ5zl0.png","name":"Real Dakota","origin_country":"RU"}],"production_countries":[{"iso_3166_1":"RU","name":"Russia"}],"release_date":"2016-06-09","revenue":1085332,"runtime":93,"spoken_languages":[{"english_name":"Russian","iso_639_1":"ru","name":"Pусский"}],"status":"Released","tagline":"","title":"Nghệ Thuật Thuần Khiết","video":false,"vote_average":5.6,"vote_count":17}},"person_1870908_translations":{"at":1773688738533,"data":{"id":1870908,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Qin Pengfei has been fond of martial arts since he was a child. In 1994 he went to Yanzhao Wushu in Wuji County to learn martial arts. During this period Qin won the championship of Hebei martial arts, was named as a first-class athlete in Hebei Province, and won the title of sportsmanship style award. In 2000 he joined the Hebei Wushu Team to engage in professional training. During this period, Qin Pengfei went abroad to perform many times on behalf of China's friendship visits. In 2005 he entered the film and television industry","name":"Qin Pengfei","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"1985年10月8日生于河北石家庄，毕业于山西省师范大学。自幼喜欢武术，1994年到无极县燕赵武馆学习武术，期间蝉联获得河北省武术冠军，被评为河北省一级运动员，并获得体育道德风尚奖称号。2000年进入河北省武术队从事专业训练，期间代表中国友好访问出国表演多次，并在全国武术比赛中被评为国家运动健将全国武英级运动员。2005年进入影视圈并在电影《墨攻》剧组从事武打替身工作，此后还参与了《白银帝国》、《赤壁》、《画皮》、《剑雨江湖》、《花木兰》、《十月围城》等多部影片的拍摄，并曾在多部影视作品中担任武术导演，代表作品有《战神戚继光》、《睡在我上铺的兄弟》、《凤凰无双》、《古剑奇谭2》等。","name":"秦鹏飞","primary":true}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"1985 年 10 月 8 日生於河北石家莊，畢業於山西省師範大學。自幼喜歡武術，1994 年到無極縣燕趙武館學習武術，期間蟬聯獲得河北省武術冠軍，被評為河北省一級運動員，並獲得體育道德風尚獎稱號。2000 年進入河北省武術隊從事專業訓練，期間代表中國友好訪問出國表演多次，並在全國武術比賽中被評為國家運動健將全國武英級運動員。2005 年進入影視圈並在電影《墨攻》劇組從事武打替身工作，此後還參與了《白銀帝國》、《赤壁》、《畫皮》、《劍雨江湖》、《花木蘭 1998》、《十月圍城》等多部影片的拍攝，並曾在多部影視作品中擔任武術導演，代表作品有《戰神戚繼光》、《睡在我上鋪的兄弟》、《鳳凰無雙》、《古劍奇譚 2》等。","name":"秦鵬飛","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"秦鵬飛","primary":false}}]}}}}