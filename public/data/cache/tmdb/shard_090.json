h trình ấy của Thạch Mục cũng chẳng hề dễ dàng, gian nan và cũng không thiếu nguy hiểm. Từ những trận chiến thập tử nhất sinh, tưởng hẹo mười mươi, cho đến những ngày tháng bị rượt đuổi chạy như bị Tào Tháo rượt, những những khoảnh khắc ấy đã tôi luyện cho Thạch Mục ngày càng trưởng thành, trở thành một võ giả có thể cứu rỗi tương lai của muôn người.","popularity":9.8538,"poster_path":"/sTCWzoUUQHT36uS9Kt2O3qXGSoM.jpg","production_companies":[{"id":123270,"logo_path":"/4KxfGr13VXMr44og11hzpdwfQDQ.png","name":"bilibili","origin_country":"CN"},{"id":208526,"logo_path":null,"name":"BYMENT","origin_country":"CN"}],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"seasons":[{"air_date":"2025-11-26","episode_count":26,"id":476705,"name":"Season 1","overview":"","poster_path":"/88eylq2rbHMSv4Do9RoFpj5fuFt.jpg","season_number":1,"vote_average":0}],"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Returning Series","tagline":"","type":"Scripted","vote_average":8,"vote_count":1}},"person_2247825_translations":{"at":1773578266215,"data":{"id":2247825,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Qu Zheming","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"曲哲明，1989年5月13日出生于辽宁鞍山，中国内地男演员，毕业于上海戏剧学院表演系2008级本科班。","name":"曲哲明","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"曲哲明","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"曲哲明，1989 年 5 月 13 日出生於遼寧鞍山，中國內地男演員，畢業於上海戲劇學院表演系 2008 級本科班。","name":"曲哲明","primary":false}}]}},"movie_1537715_detail_vi-VN":{"at":1773109836305,"data":{"adult":false,"backdrop_path":"/zVErlNqgiAaegmD1m4D3g9q