{"version":1,"entries":{"person_2640689_translations":{"at":1773688717999,"data":{"id":2640689,"translations":[{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"王可元（Wang Ko Yuan，1989年11月18日—），台灣男演員及模特兒。2019年演出公視電視劇《我們與惡的距離》開始嶄露頭角，同年入圍第21屆台北電影獎最佳新演員獎。","name":"王可元","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Tommi Wang is a Taiwanese model and actor. He is known for his roles in \"Erotica\", \"The World Between Us\", and \"Dear Tenant\".","name":"Wang Ko-Yuan","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"王可元","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"王可元（Wang Ko Yuan，1989 年 11 月 18 日—），台灣男演員及模特兒。2019 年演出公視電視劇《我們與惡的距離》開始嶄露頭角，同年入圍第 21 屆台北電影獎最佳新演員獎。","name":"王可元","primary":false}}]}},"person_1578455_translations":{"at":1773688721901,"data":{"id":1578455,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Gina Vultaggio is known for Battlestar Galactica: The Plan (2009), Resident Alien (2021) and Keeper (2025).","name":"Gina Vultaggio","primary":true}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"","primary":false}}]}},"person_2128510_translations":{"at":1773688722079,"data":{"id":2128510,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Vlad Semenescu","primary":true}}]}},"person_131563_translations":{"at":1773688726489,"data":{"id":131563,"translations":[{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"Jun Fukuyama","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Jun Fukuyama is a Japanese voice actor and singer.","name":"Jun Fukuyama","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"후쿠야마 준","primary":false}},{"iso_3166_1":"IN","iso_639_1":"hi","name":"हिन्दी","english_name":"Hindi","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"福山潤是日本的男性聲優、歌手。出生於廣島縣福山市，成長於大阪府高槻市，畢業於大阪府立大冠高中，所屬公司為 Black Ship。","name":"福山潤","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"福山润（日语：福山 潤／ふくやま じゅん Fukuyama Jun，1978年11月26日—）是一名日本男性声优（配音员）、歌手。生于广岛县福山市，出身于大阪府高槻市。BLACK SHIP代表取缔役CEO。在日本喜爱他的声优迷们昵称他为ジュン或ジュンジュン（润润）。\n\n高二时喜欢的女孩子（同级生）对\"声优\"的世界非常向往，而自己对动画影集（アニメ）也很有兴趣，为了能更靠近她，在有了这个共通的话题之后，于是两人一起通勤就读起声优养成学校（青二塾大阪校）。\n\n但是不久这女孩却在中途放弃了成为声优的志愿，还有一学年，自己也即将面临是否该继续升学或是就业的抉择。察觉到自己一直以来仍喜爱着声优这个充满魅力的职业，经过了一番审慎的思考，决定继续朝声优之路迈进，做为最初欲\"探求自己的可能性\"的挑战，也因此才有声优福山润的诞生。","name":"福山润","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Džun Fukujama","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"จุง ฟุกุยะมะ","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"福山潤","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Jun Fukuyama","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Jun Fukuyama","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"Jun Fukuyama","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Jun Fukuyama","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"福山潤是日本的男性聲優、歌手。出生於廣島縣福山市，成長於大阪府高槻市，畢業於大阪府立大冠高中，所屬公司為 Black Ship。","name":"福山潤","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Джюн Фукуяма","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Дзюн Фукуяма","primary":false}}]}},"person_125391_translations":{"at":1773688728432,"data":{"id":125391,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Lu Chu-Kun (Chinese: 鲁俊谷), a native Fukienese, was born in December 1946, and was originally named Wang Chun-Yeung. He immigrated to Hong Kong in 1962, and in 1970 successfully joined Cathay's actor training course, during which time he acquired the stage-name Lu Chun. After Cathay was closed down, Lu joined Yangtze Film Company as an actor, and first appeared in \"My Millionaire Sister\". He took up his first lead role in \"Armour of God\".\n\nIn 1974, Lu began to work behind the scenes. In 1979 he changed his name to Lu Chun-Ku and joined Shaw Brothers as a director. He directed a number of martial arts movies, and even starred in a few.\n\nFrom the Celestial DVD edition of \"Return of the Bastard Swordsman\".","name":"Tony Lou Chun-Ku","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"鲁俊谷，福建人，1946年12月出生，原名王春阳。他于1962年移民香港，并于1970年成功参加国泰的演员培训班，在此期间他获得了艺名卢春。国泰停业后，陆志明加入长江电影公司担任演员，首次出演《我的百万富翁姐姐》。他在《上帝的盔甲》中担任了他的第一个主角。\n\n1974年，陆志强开始从事幕后工作。1979年，他改名为卢俊库，并加入邵氏兄弟担任董事。他执导了多部武侠电影，甚至出演了几部。\n\n出自《混蛋剑客归来》的天体DVD版。","name":"鲁俊谷","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"魯俊谷，福建人，1946 年 12 月出生，原名王春陽。他於 1962 年移民香港，並於 1970 年成功參加國泰的演員培訓班，在此期間他獲得了藝名盧春。國泰停業後，陸志明加入長江電影公司擔任演員，首次出演《我的百萬富翁姐姐》。他在《上帝的盔甲》中擔任了他的第一個主角。\n\n1974 年，陸志強開始從事幕後工作。1979 年，他改名為盧俊庫，並加入邵氏兄弟擔任董事。他執導了多部武俠電影，甚至出演了幾部。\n\n出自《混蛋劍客歸來》的天體 DVD 版。","name":"魯俊谷","primary":false}}]}},"person_64434_translations":{"at":1773688729738,"data":{"id":64434,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Born in Canada, Charlene Choi Chuek-Yin (Chinese: 蔡卓妍) is a Chinese film and television actress and singer. She is a member of the Cantopop group Twins, along with Gillian Chung Yan-Tung.","name":"Charlene Choi Chuek-Yin","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"채탁연","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"蔡卓妍（Charlene Choi，又称阿Sa），香港歌手、演员，为香港女子歌唱组合Twins成员。其甜美外形及阳光微笑深受粉丝们的喜爱，被誉为“香港人气天后”。而其健康时尚的形象也备受广告商的青睐，2008、09年连续两年获得香港“最强广告人气天后”奖。在电影、音乐方面均有出色表现，凭借电影《戏王之王》一举囊获第12届香港金紫荆奖“最佳女主角”与“最受欢迎女演员”奖。为影视歌三栖明星。","name":"蔡卓妍","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"蔡卓妍（Charlene Choi，又稱阿 Sa），香港歌手、演員，為香港女子歌唱組合 Twins 成員。其甜美外形及陽光微笑深受粉絲們的喜愛，被譽為“香港人氣天後”。而其健康時尚的形象也備受廣告商的青睞，2008、09 年聯續兩年獲得香港“最強廣告人氣天後”獎。在電影、音樂方面均有出色表現，憑藉電影《戲王之王》一舉囊獲第 12 屆香港金紫荊獎“最佳女主角”與“最受歡迎女演員”獎。為影視歌三棲明星。","name":"蔡卓妍","primary":true}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"Thái Trác Nghiên (sinh ngày 22 tháng 11 năm 1982) là một nữ ca sĩ kiêm diễn viên người Hồng Kông. Cô là thành viên của nhóm nhạc Twins cùng với Chung Hân Đồng.","name":"Thái Trác Nghiên","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Charlene Choi Cheuk-Yin","primary":false}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"Charlene Choi Chuek-Yin","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"シャーリーン・チョイ","primary":false}}]}},"movie_1575628_detail_vi-VN":{"at":1773688731081,"data":{"adult":false,"backdrop_path":"/9gBuBHIO1Hm9uZkUqP01M81f6Ym.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":18,"name":"Phim Chính Kịch"}],"homepage":"","id":1575628,"imdb_id":null,"origin_country":["CN"],"original_language":"zh","original_title":"血染凤凰","overview":"Vào thời Dân Quốc, tướng lĩnh cuối triều Thanh Bành Phi cùng thầy giáo Ba Đặc Lỗ đã dũng cảm quyết chiến với sát thủ ninja Nhật Bản để bảo vệ quốc bảo “Chén Phụng Hoàng Lưu Ly”. Trong quá trình ấy, họ nhận được sự trợ giúp của Lam Thiên Long, Lam Phượng Hoàng, A Tứ cùng nhiều nghĩa sĩ chính trực khác, họ tiêu diệt kẻ thù hùng mạnh và bảo toàn quốc bảo. Cũng qua trận chiến đầy máu lửa này, Bành Phi và các anh hùng giang hồ đã tìm thấy con đường tươi sáng để thực sự cống hiến cho đất nước.","popularity":0.6867,"poster_path":"/kKwU2Jl32sXcI9CPd2fHeJoiQje.jpg","production_companies":[{"id":172414,"logo_path":"/fNxBFqWr7eWEgNeBDvvCxsSItXx.png","name":"iQIYI","origin_country":"CN"}],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"release_date":"2025-11-06","revenue":0,"runtime":0,"spoken_languages":[],"status":"Released","tagline":"","title":"Huyết Nhiễm Phượng Hoàng","video":false,"vote_average":0,"vote_count":0}},"person_2331091_translations":{"at":1773688733797,"data":{"id":2331091,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Jemal Felix","primary":true}}]}},"tv_82596_credits":{"at":1773688734898,"data":{"cast":[{"adult":false,"gender":1,"id":112561,"known_for_department":"Acting","name":"Lily Collins","ori