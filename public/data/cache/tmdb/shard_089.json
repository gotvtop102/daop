_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"伍允龙，中国香港人，拥有伊利诺州大学香槟校区教育硕士学位，香港动作演员及武术指导。曾出演过《财神客栈》、《无价之宝》、《恶战》、《绝色武器》、《澳门风云》等作品。","name":"伍允龙","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"伍允龍，香港人，擁有伊利諾州大學香檳校區教育碩士學位，香港動作演員及武術指導。曾出演過《財神客棧》、《無價之寶》、《惡戰》、《絕色武器》、《賭城風雲》等作品。","name":"伍允龍","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Ngũ Doãn Long","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"오윤룡","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Philip Ng","primary":false}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"Philip Ng Wan-Lung","primary":false}}]}},"person_2019485_translations":{"at":1773384113425,"data":{"id":2019485,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Kayla Wallace is a Canadian actor, singer, and dancer. She is best known for her work on The Magicians (2020), ABC's The Good Doctor (2017), and her role of 'Fiona Miller' on Hallmark Channel's When Calls The Heart (2019- 2021). Wallace was born in Victoria, British Columbia where she later attended The Canadian College of Performing Arts upon completing high school. She was heavily involved in theatre, dance, singing and piano throughout her childhood and developed a strong passion for film & television.","name":"Kayla Wallace","primary":true}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"凯拉·华莱士","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Кайла Воллес","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"케일라 월레스","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"凱拉·華萊士","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"凱拉·華勒斯","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Кайла Уоллес","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"ケイラ・ウォレス","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Kayla Wallace (geboren am 31. Oktober 1993 auf Vancouver Island, British Columbia) ist eine kanadische Schauspielerin, Sängerin und Tänzerin, die vor allem durch ihre Rolle als Fiona Miller in der Hallmark-Serie „When Calls the Heart“ bekannt wurde. Ihre berufliche Laufbahn begann mit einem Engagement als Tänzerin und Chorsängerin im Disney-Fernsehfilm „Descendants“ (2015), es folgten Auftritte unter anderem in „The Good Doctor“, „The Magicians“, „Zoey’s Extraordinary Playlist“ sowie in zahlreichen Fernsehfilmen wie „Once Upon a Prince“, „Counterfeiting in Suburbia“, „Undercover Cheerleader“, „Heatwave“, „Feeling Butterflies“ und „My Grown-Up Christmas List“. Seit 2024 spielt sie zudem die Rolle der Rebecca Falcone in der Serie „Landman“ und gilt damit als fest etabliert im nordamerikanischen TV- und Streaming-Bereich","name":"","primary":false}},{"iso_3166