ions":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Riho Rosberg (born September 20, 1965) is an Estonian actor.\n\nIn 1983, he graduated from the 20th secondary school in Tallinn and in 1990 from the XIV flight of the theater arts department of the Tallinn Conservatory and has been working as an actor in the Estonian Youth Theater since his graduation.","name":"","primary":false}},{"iso_3166_1":"EE","iso_639_1":"et","name":"Eesti","english_name":"Estonian","data":{"biography":"","name":"Riho Rosberg","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Рихо Росберг","primary":false}}]}},"person_2835903_translations":{"at":1773688732940,"data":{"id":2835903,"translations":[{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Iván Aragón","primary":false}},{"iso_3166_1":"MX","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Iván Aragón","primary":true}}]}},"person_1259463_translations":{"at":1773688733887,"data":{"id":1259463,"translations":[{"iso_3166_1":"GR","iso_639_1":"el","name":"ελληνικά","english_name":"Greek","data":{"biography":"Τραγουδιστής / Ηθοποιός. Η γενέτειρα του R είναι το , στην Ταϊλάνδη. Ο R ξεκίνησε την καριέρα του όταν συμμετείχε στην εκπομπή The Star, μια ταϊλανδέζικη εκδοχή της εκπομπής \"American Idol\". Κέρδισε την πρώτη θέση στην 3η σεζόν. Έχει κυκλοφορήσει δύο άλμπουμ από το 2006 και συναυλίες.","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Arnuttaphol Sirichomsaeng","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"Arnuttaphol Sirichomsaeng","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"阿那德鹏·思里醇慕桑，1983年11月27日出生于泰国乌隆府，泰国男歌手、演员。","name":"阿那德鹏·思里醇慕桑","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"阿那德鵬·思裏醇慕桑，1983 年 11 月 27 日出生於泰國烏隆府，泰國男歌手、演員。","name":"阿那德鵬·思裏醇慕桑","primary":false}}]}},"tv_278635_detail_vi-VN":{"at":1773688734635,"data":{"adult":false,"backdrop_path":"/iCCkBpD5nnWT7vknIbf7XgauT8b.jpg","created_by":[],"episode_run_time":[],"first_air_date":"2025-10-03","genres":[{"id":16,"name":"Phim Hoạt Hình"},{"id":10759,"name":"Action & Adventure"},{"id":10765,"name":"Sci-Fi & Fantasy"},{"id":18,"name":"Phim Chính Kịch"}],"homepage":"https://mugengacha.com","id":278635,"in_production":false,"languages":["ja"],"last_air_date":"2025-12-19","last_episode_to_air":{"id":6579459,"name":"Episode 12","overview":"","vote_average":9.5,"vote_count":1,"air_date":"2025-12-19","episode_number":12,"episode_type":"finale","production_code":"","runtime":24,"season_number":1,"show_id":278635,"still_path":"/7JwaKSSl6DrG8e0nCn6gRJb4VIZ.jpg"},"name":"Thiên Phú Vô Hạn Gacha Cấp 9999","next_episode_to_air":null,"networks":[{"id":614,"logo_path":"/hSdroyVthq3CynxTIIY7lnS8w1.png","name":"Tokyo MX","origin_country":"JP"}],"number_of_episodes":12,"number_of_seasons":1,"origin_country":["JP"],"original_language":"ja","original_name":"信じていた仲間達にダンジョン奥地で殺されかけたがギフト『無限ガチャ』でレベル9999の仲間達を手に入れて元パーティーメンバーと世界に復讐＆『ざまぁ！』します！","overview":"Ngày xưa, Nữ thần đã tạo ra chín chủng tộc. Trong số đó, loài người là chủng tộc yếu nhất và bị chế giễu. Cậu bé loài người Light đã may mắn được chào đón vào một nhóm mạo hiểm giả được thành lập từ chín chủng tộc, mang tên \"\"Chủng Tộc Tụ Hội\"\", và đã có một khoảng thời gian vui vẻ. Tuy nhiên, đó chỉ là một ảo mộng phù du. Điều chờ đợi cậu là sự phản bội tại \"\"Vực Thẳm\"\" - hầm ngục lớn nhất và tồi tệ nhất thế giới.\n\nSống sót ở tận cùng Vực Thẳm, Light đã khám phá ra sức mạnh thật sự của thiên phú \"\"Vô Hạn Gacha\"\" của mình. Vươn lên từ vực sâu của tuyệt vọng, Light sẽ xây dựng vương quốc mạnh nhất. Với ân huệ độc nhất vô nhị là \"\"Vô Hạn Gacha\"\" trong tay, câu chuyện trả thù của cậu chính thức bắt đầu!","popularity":9.964,"poster_path":"/1L3br92RaLMkt8aYVv7NvdPIU3H.jpg","production_companies":[{"id":11884,"logo_path":"/tHzHPSKdmLT5zCdqFbcmHzZvRIc.png","name":"J.C.STAFF","origin_country":"JP"},{"id":210353,"logo_path":"/sG6AWiwUB3J7IU6iXzTI7ezXKu9.png","name":"Hobby Japan","origin_country":"JP"},{"id":173132,"logo_path":"/yV9EORK2ZwdMg45K10PuVh6LlM3.png","name":"Bandai Namco Filmworks","origin_country":"JP"},{"id":3363,"logo_path":"/sj3vD7n63bTCih7bcf6GnWvRf1Q.png","name":"MBS","origin_country":"JP"},{"id":266961,"logo_path":"/4yay95kXq2Dp3pKzcaqMMxEa1OX.png","name":"Daito Giken","origin_country":"JP"},{"id":173133,"logo_path":"/pB59XO7veWGZjzK4MLGKWxYecD.png","name":"Bandai Namco Music Live","origin_country":"JP"},{"id":276311,"logo_path":"/kihxlvATFaZuEGjoFTCKTeHaMmV.png","name":"KMS","origin_country":"JP"},{"id":118502,"logo_path":"/JQ5bx6n7Qmdmyqz6sqjo5Fz2iR.png","name":"BS11","origin_country":"JP"}],"production_countries":[{"iso_3166_1":"JP","name":"Japan"}],"seasons":[{"air_date":"2025-10-03","episode_count":12,"id":431628,"name":"Season 1","overview":"","poster_path":"/lFOtbsKfbrEixJXhHZLeoUtqUIn.jpg","season_number":1,"vote_average":7.4}],"spoken_languages":[{"english_name":"Japanese","iso_639_1":"ja","name":"日本語"}],"status":"Ended","tagline":"Giờ thì, hãy bắt đầu cuộc báo thù.","type":"Scripted","vote_average":8.267,"vote_count":58}},"tv_298567_keywords":{"at":1773688735808,"data":{"id":298567,"results":[{"name":"romance","id":9840},{"name":"unrequited love","id":10048},{"name":"cousin relationship","id":164829},{"name":"aggressive","id":202371},{"name":"boys' love (bl)","id":289844},{"name":"based on web novel","id":318933}]}},"person_5888706_translations":{"at":1773688736014,"data":{"id":5888706,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Luigi Ciadelli","primary":true}}]}},"person_2119283_translations":{"at":1773688736586,"data":{"id":2119283,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Ding Cheng Xin is a Chinese actor, singer, and member of Times Fengjun Entertainment's group, TEENS In TIMES (TNT). He was born in Sichuan, China. After he joined Times Fengjun Entertainment in 2013 and became part of various groups such as Tai Feng Si Zi (Typhoon Four), Tai Feng Shi Er Zi (Typhoon Twelve), Tai Feng Shi Zi (Typhoon Ten), and Typhoon Teens (TYT) which disbanded in 2019 and was remade to TNT through the show Typhoon Project in the same year. He made his acting debut in the 2016 television drama “Finding Soul.”","name":"Ding Chengxin","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"丁程鑫，2002年2月24日出生于四川省资阳市安岳县，中国内地流行乐男歌手、影视演员，男子演唱组合时代少年团成员。\n\n2013年，在TF家族自制综艺《TF少年GO》中首次走进大众视野。2015年，参加录制TF家族自制综艺《星期五练习生》。2016年，参演科幻校园网剧《超少年密码》和青春励志剧《旋风少女第二季》。2017年4月，参加录制湖南卫视文化节目《中华文明之美》；7月，参演青春励志剧《我们的少年时代》；11月，首登湖南卫视综艺节目《快乐大本营》。2018年，参演奇幻校园网剧《念念》和青春励志剧《甜蜜暴击》。2019年2月，参加录制的综艺《台风少年行》播出；3月，参加录制央视文化音乐节目《经典咏流传第二季》。2020年9月，加盟腾讯视频导演选角真人秀《演员请就位第二季》，最终获得“最受观众喜爱演员”称号。","name":"丁程鑫","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Ding Chengxin","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Дин Чэн Синь","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Đinh Trình Hâm","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"丁程鑫，2002 年 2 月 24 日出生於四川省資陽市安嶽縣，中國內地流行樂男歌手、影視演員，男子演唱組合時代少年團成員。\n\n2013 年，在 TF 家族自制綜藝《TF 少年 GO》中首次走進大眾視野。2015 年，參加錄製 TF 家族自制綜藝《星期五練習生》。2016 年，參演科幻校園網劇《超少年密碼》和青春勵志劇《旋風少女第二季》。2017 年 4 月，參加錄製湖南衞視文化節目《中華文明之美》；7 月，參演青春勵志劇《我們的少年時代》；11 月，首登湖南衞視綜藝節目《快樂大本營》。2018 年，參演奇幻校園網劇《念念》和青春勵志劇《甜蜜暴擊》。2019 年 2 月，參加錄製的綜藝《台風少年行》播出；3 月，參加錄製央視文化音樂節目《經典詠流傳第二季》。2020 年 9 月，加盟騰訊視頻導演選角真人秀《演員請就位第二季》，最終獲得“最受觀眾喜愛演員”稱號。","name":"丁程鑫","primary":false}}]}},"person_1161472_translations":{"at":1773688739020,"data":{"id":1161472,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Mao Ichimichi is a Japanese actress, voice actress, and a former gravure idol. When she does voice acting she uses her moniker M·A·O. In 2011, she made her major acting debut in the role of Luka Millfy / Gokai Yellow in the Super Sentai series Kaizoku Sentai Gokaiger.","name":"Mao Ichimichi","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"市道真央（1992年2月1日－）出生于日本大阪府，日本女演员、声优，身高158公分，血型O型。她出道以来，以前是大阪堀制作事务所所属女艺人，目前为Yellow Cab NEXT旗下的女艺人。\n\n2006年10月，市道真央曾在大阪堀制作的HOP CLUB组合面试之中夺得大奖。到了2010年中，她移居到东京之后，2011年2月，她在参演超级战队系列特摄作品《海贼战队豪快者》之中，饰演女主角之一“Luka Millfy／豪快黄”。2012年以“M·A·O”名义开始配音活动。","name":"市道真央","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Mao Ichimichi","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"이치미치 마오","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"市道真央是日本的女性聲優、演員，聲優活動時以「M・A・O」名義，演員活動時以「市道真央」名義。出身於大阪府，所屬公司為 Yellow Cab Next。","name":"市道真央（M・A・O）","primary":false}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"Mao Ičimiči","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Mao Ičimiči","primary":false}},{"iso_3166_1":"SA","iso_