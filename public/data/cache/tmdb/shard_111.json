{"version":1,"entries":{"person_4190007_translations":{"at":1774698735551,"data":{"id":4190007,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Aungpao Ochiris Suwanacheep is a Thai actor and singer under GMMTV. He attends Sarasit Phithayalai School in Ratchaburi. Aungpao was named Ochiris after the Egyptian god Osiris as depicted in a manga.\n\nAfter making it to the finale of GMMTV's survival programme \"Project Alpha\" in 2022 and falling short of landing a position in their boy group, the company signed Aungpao as an artist. He subsequently made his acting debut with a supporting role in their series \"Cooking Crush\" when his scene partner Neo Trai selected him as a late replacement for an actor who dropped out.\n\nIn November 2025, he was revealed as a member of the boy group CLO'VER under Riser Music.","name":"Ochiris Suwanacheep","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"โอชิริส สุวรรณชีพ","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"昂保·奥奇里斯·苏瓦纳奇普","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"昂保·奧奇里斯·蘇瓦納奇普","primary":false}}]}},"person_5441616_translations":{"at":1774698735835,"data":{"id":5441616,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"吴悠悠","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Wu Youyou","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"吳悠悠","primary":false}}]}},"movie_1193501_keywords":{"at":1774698739443,"data":{"id":1193501,"keywords":[{"id":6270,"name":"high school"},{"id":2968,"name":"grave"},{"id":10114,"name":"evil spirit"},{"id":10873,"name":"school"},{"id":34079,"name":"death"},{"id":41328,"name":"whistle"},{"id":156866,"name":"based on short story"},{"id":256183,"name":"supernatural horror"},{"id":266753,"name":"cautionary"},{"id":304115,"name":"cursed object"},{"id":309060,"name":"teen horror"},{"id":315058,"name":"horror"},{"id":325851,"name":"straightforward"}]}},"person_21134_translations":{"at":1774698747772,"data":{"id":21134,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"John M. Slattery, Jr. (born August 13, 1962) is an American actor and director, best known for his roles as Roger Sterling on AMC's series Mad Men, Frank Jaffe in Confess, Fletch, Howard Stark (Tony Stark's father) in the Marvel movie series, Paul LeBlanc on FOX's NEXT, Dwight Eisenhower in Churchill, Lyle Bettencourt on CBS's The Good Fight,  Richardson in The Adjustment Bureau, Cravely in Charlie Wilson's War, Bud Gerber in Flags of Our Fathers, Peter Benedict on WB's Jack & Bobby, Roland Yates in Bad Company, Dr. Richard Meyers on Lifetime's sitcom Maggie, FBI Agent Corman in Eraser, and Al Kahn on ABC's Homefront.\n\nHe has been married to actress Talia Balsam since 1998 and they have a son, Henry.","name":"John Slattery","primary":true}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"John M. Slattery, Jr. (nacido el 13 de agosto de 1962) es un actor y director estadounidense, mejor conocido por su papel de Roger Sterling en la serie Mad Men de AMC.\n\nDescripción arriba del artículo de Wikipedia John Slattery, con licencia de CC-BY-SA, lista completa de colaboradores en Wikipedia.","name":"","primary":false}},{"iso_3166_1":"GR","iso_639_1":"el","name":"ελληνικά","english_name":"Greek","data":{"biography":"","name":"Τζον Σλάτερι","primary":false}},{"iso_3166_1":"PL","iso_639_1":"pl","name":"Polski","english_name":"Polish","data":{"biography":"John Slattery urodził się w 1963 iw Bostonie, Massachusetts, gdzie także się wychowywał, z czego teraz jest dumny. Aktualnie jest żonatyy z Talią Balsam, byłą żoną George`a Clooney`a. John po raz pierwszy pojawił sie w serialu w roku 1988 a był to \"The Dirty Dozen: the Series\" i od tamtego czasu nie przestaje ciężko pracować. Jego dorobek telewizyjny obejmuje seriale takie jak \"Under Cover\", \"Homefront\", \"Maggie,\" i \"Feds\" oraz mini-seriale: \"A Woman of Independent Means\", w którym gra z Sally Field i \"From the Earth to the Moon\", w którym gra Waltera Mondalę. Dzięki swoim rolom w \"Will and Grace\" jako starszy brat Willa - Sam, \"Judging Amy\" jako oziębły mąż Amy oraz \"Sex and the City\", John stał się jednym z najbardziej poszukiwanych aktorów. W 2001 zagrał w serialu komediowym NBC pt. \"Ed\" rolę dyrektora szkoły średniej - Denisa Martino. Ta kreacja przyniosła mu wielka popularność i stała się obiektem dyskusji fanów serialu. John odnosi też sukcesy na deskach teatrów. Jego teatralny debiut przypada na rok 1989, kiedy to zagrał w \"Lisbon Traviata\". Bardzo owocna okazała się współpraca z dramaturgiem Richardem Greenburgiem. Pojawił się w paru sztukach tego autora m.in. w \"Night and Her Stars\" oraz \"Three Days of Rain. Za role w tej ostatniej dostał nagrodę krytyki za podwójną rolę ojca i syna. W 1993 debiutuje na Broadway`u występując w \"Laughter on the 23rd Floor\". Powrócił do teatru w roku 2000 rolą w \"Betrayal\" W filmie zadebiutował w 1996 gościnnym występem w filmie \"City Hall\". Od tamtego czasu pojawił się w \"Eraser\", \"Where's Marlow?\", \"Traffic\" i \"Bad Company\". W roku 2004 wystąpił z Julią Roberts w \"Mona Lisa Smile\" oraz w drugiej części \"Dirty Dancing\" - \"Havana Nights\".","name":"","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"ジョン・スラッテリー","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"ג'ון סלאטרי","primary":false}},{"iso_3166_1":"SA","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"","name":"جون سلاتري","primary":false}},{"iso_3166_1":"PK","iso_639_1":"ur","name":"اردو","english_name":"Urdu","data":{"biography":"","name":"جان سلیٹری","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"จอห์น สแลตเทอรี","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Джон Слэттери","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Джон Слеттері","primary":false}},{"iso_3166_1":"RS","iso_639_1":"sr","name":"Srpski","english_name":"Serbian","data":{"biography":"","name":"Џон Слатери","primary":false}},{"iso_3166_1":"IR","iso_639_1":"fa","name":"فارسی","english_name":"Persian","data":{"biography":"","name":"جان اسلتری","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"존 슬래터리","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"John M. Slattery， Jr.（生于 1962 年 8 月 13 日）是一位美国演员和导演","name":"约翰·斯拉特里","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"John Slattery (nascido em 13 de agosto de 1962) é um ator e diretor americano, mais conhecido por seus papéis como Roger Sterling na série Mad Men da AMC, Frank Jaffe em Confess, Fletch, Howard Stark (pai de Tony Stark) em a série de filmes da Marvel, Paul LeBlanc no NEXT da FOX, Dwight Eisenhower em Churchill, Lyle Bettencourt no The Good Fight da CBS, Richardson no The Adjustment Bureau, Cravely em Charlie Wilson's War, Bud Gerber em Flags of Our Fathers, Peter Benedict no WB's Jack & Bobby, Roland Yates em Bad Company, Dr. Richard Meyers na sitcom Maggie da Lifetime, o agente do FBI Corman em Eraser e Al Kahn em Homefront da ABC.\n\nEle é casado com a atriz Talia Balsam desde 1998 e eles têm um filho, Henry.","name":"","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"John M.Slattery， Jr. （生於 1962 年 8 月 13 日）是一位美國演員和導演","name":"約翰·斯拉特里","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"約翰·史萊特利","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CA","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"","primary":false}}]}},"person_5366144_translations":{"at":1774698752369,"data":{"id":5366144,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Sam Rowlands","primary":true}}]}},"tv_211721_credits":{"at":1774698754504,"data":{"cast":[{"adult":false,"gender":1,"id":17027,"known_for_department":"Acting","name":"Charlene McKenna","original_name":"Charlene McKenna","popularity":1.46,"profile_path":"/68rKssGm8fLzWuRMTSUx03YFQiv.jpg","character":"Shelly Mohan","credit_id":"633dd8dc68929c0081786922","order":0},{"adult":false,"gender":2,"id":1307013,"known_for_department":"Acting","name":"Barry Ward","original_name":"Barry Ward","popularity":1.108,"profile_path":"/3cIhm76aPUvJdIa9GbGrzhAL5GF.jpg","character":"Jason Mohan","credit_id":"633dd8e54b6d9d0079cd332c","order":1},{"adult":false,"gender":2,"id":3248000,"known_for_department":"Acting","name":"Aidan McCann","original_name":"Aidan McCann","popularity":0.1699,"profile_path":"/lZbEE4JSoDKYwpPmXnaat7ybHsE.jpg","character":"Niall Mohan","credit_id":"633dd686ecc7e8007a8d5a3e","order":2},{"adult":false,"gender":0,"id":3072484,"known_for_department":"Acting","name":"Rhys Mannion","original_name":"Rhys Mannion","popularity":0.3402,"pro