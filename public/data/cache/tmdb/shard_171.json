{"version":1,"entries":{"person_1497921_translations":{"at":1774731918916,"data":{"id":1497921,"translations":[{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Kimmy Shields","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Q79422769","primary":false}}]}},"person_1281498_translations":{"at":1774731924460,"data":{"id":1281498,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"小松未可子（日语：小松 未可子／こまつ みかこ Komatsu Mikako，1988年11月11日—），出身于日本三重县桑名市的女性演员、声优。偶像团体いもうと前成员之一。目前隶属于Hirata Office。大妻女子大学毕业。\n\n代表作有《HEROMAN》（乔瑟夫·卡达·乔伊·琼斯）、《游戏王ZEXAL》（观月小鸟）、《迷你裙宇宙海贼》（加藤茉莉香）等。","name":"小松未可子","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Mikako Komatsu (小松 未可子, Komatsu Mikako, November 11, 1988) is a Japanese voice actress, actress and singer from Kuwana, Mie. She is affiliated with Hirata Office. Her record label is Toy's Factory.","name":"Mikako Komatsu","primary":false}},{"iso_3166_1":"IN","iso_639_1":"hi","name":"हिन्दी","english_name":"Hindi","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"小松未可子是日本的女性演員、聲優、歌手。出身於三重縣桑名市，畢業於大妻女子大學，所屬公司為平田事務所。","name":"小松未可子","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"小松未可子","primary":true}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"코마츠 미카코","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Mikako Komatsu (小松 未可子, Komatsu Mikako, geboren am 11. November 1988) ist eine japanische Synchronsprecherin, Schauspielerin und Sängerin aus Kuwana in der Präfektur Mie. Sie ist bei der Agentur Hirata Office unter Vertrag. Ihr Musiklabel ist Toy’s Factory.","name":"Mikako Komatsu","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"มิกาโกะ โคมัตสึ","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Mikako Komacu","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"Mikako Komatsu","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Mikako Komatsu","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"Mikako Komatsu","primary":false}},{"iso_3166_1":"PT","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Mikako Komatsu","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Mikako Komatsu","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"Микако Комацу родилась 11 ноября 1988 года в префектуре Миэ, Япония. Бывший айдол, а ныне актриса. Ранее она была участницей айдол-группы Imouto (いもうと) и сотрудничала с Yoshimoto Creative Agency, а теперь сотрудничает с Hirata Office. Ее хобби — просмотр фильмов и песни. Ее особый навык — игра на Маримбе.","name":"Микако Комацу","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"Мікако Комацу — японська актриса озвучування та співачка.","name":"Мікако Комацу","primary":false}},{"iso_3166_1":"SA","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"","name":"ميكا