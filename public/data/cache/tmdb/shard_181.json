h_name":"Mandarin","data":{"biography":"","name":"Mo Xi er","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Чжао Юй Си","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"趙豫熙（曾用名莫熙兒），1990 年 12 月 16 日出生於四川省成都市，畢業於四川省藝術學院，中國內地女演員、歌手 。\n\n2010 年，趙豫熙推出個人首支單曲《飛行雲端》 。2011 年，出演個人首部電影《目擊者》，從而正式進入演藝圈 。2012 年，出演年代情感劇《雅典娜女神》。2013 年，因在愛情喜劇片《青春荷爾蒙》中飾演莫菲而嶄露頭角。2014 年，出演青春愛情片《青春荷爾蒙 2 躁動時代》 。2015 年，主演網絡輕喜劇《我的美女老師》，飾演地獄女惡魔羅茜。2016 年，憑藉都市愛情網絡劇《女總裁的貼身高手》而獲得更多關注 。同年，出演古裝仙俠劇《莽荒紀》 。2017 年 3 月，在古裝愛情網絡劇《假鳳虛凰》中飾演葉清歌。2018 年 1 月，在《最好的安排》中飾演賈小朵。","name":"趙豫熙","primary":false}}]}},"person_1599988_translations":{"at":1773676812661,"data":{"id":1599988,"translations":[{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"水谷果穂","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Kaho Mizutani","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"水谷果穂","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Kaho Mizutani","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"水谷果穗","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Кахо Мідзутані","primary":false}}]}},"person_2339332_translations":{"at":1773676815660,"data":{"id":2339332,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"赵铭洲","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Zhao Mingzhou","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"趙銘洲","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Чжао Мин Чжоу","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Zhao Mingzhou","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"趙銘洲","primary":false}}]}},"person_3277192_translations":{"at":1773676817305,"data":{"id":3277192,"translations":[{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Dean Ricky Goldblum is a South African born Stage, Screen and Voice Actor raised in the City of Gold, Johannesburg. Dean is known for playing the parts of Todd on the Hulu Original feature 'Darby and the Dead' (2023), Sean on the SAFTA Award winning Netflix / SABC 1 mini-series 'The Kingdom' (2021), as well as Jason on the SAFTA award winning Showmax TV Comedy, 'Tali's Joburg Diary' (2023). In 2024, Dean featured in South Africa's first Amazon Prime Original Feature Film and Television Drama, playing the parts of Francois in 'The Morning After' (2024) as well as the young Dovi Diamond in 'The Shakedown' (2024). After acting in principle roles in a number of plays and musicals during his secondary and tertiary school years, Dean went on to study Theatre and Performance (acting) at The University of Cape Town (2021). Some of Dean's roles on stage include Badvoc in Boudica (2019), Will Bloom in Big Fish: The Musical (2016), Danny Zuko in Grease (2014) & Tom Snout/Faerie in A Midsummer Night's Dream at Maynardville (2023). Starting his screen career at the age of 13 on the South African Broadcasting Corporation's (SABC) 'Little Stars' (2013), Dean went on to perform as a contestant on South Africa's Got Talent (2015) in which his musical performance was described by Etv as \"melting the hearts [of] the young at heart across the country\".","name":"Dean Goldblum","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Дин Голдблюм","primary":false}}]}},"person_5972532_translations":{"at":1773676824381,"data":{"id":5972532,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Isaac McKee","primary":true}}]}},"tv_304645_keywords":{"at":1773676827959,"data":{"id":304645,"results":[{"name":"cultural","id":14889}]}},"person_175604_translations":{"at":1773676842395,"data":{"id":175604,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Shanna Lynn Moakler (born March 28, 1975) is a European-American model, actress, reality television star and a former beauty queen. She was the winner of the Miss New York USA pageant in 1995 and was originally the first runner-up at Miss USA 1995. She was later crowned Miss USA after Chelsi Smith won Miss Universe. Moakler began modeling at age 15 and was later chosen as a Playmate of the Month for Playboy magazine in December 2001. She currently hosts E!'s Bridalplasty.\n\nMoakler eventually branched out into an acting career, appearing as a regular for two seasons on the USA Network television series Pacific Blue in 1998, and in 2005 she starred as herself on the reality television series Meet the Barkers with her then husband Travis Barker, drummer in the rock band Blink-182. The series aired for two seasons on MTV.  Moakler's private life has been much discussed in the media, including her relationship with rock singer Billy Idol, as well as her relationships with Olympic champion boxer Oscar de la Hoya and Hollywood actor Dennis Quaid.\n\nMoakler served as co-director for the Miss California USA pageant until May 13, 2009.\n\nDescription above from the Wikipedia article Shanna Moakler, licensed under CC-BY-SA, full list of contributors on Wikipedia.","name":"Shanna Moakler","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"","primary":false}}]}},"person_1546861_translations":{"at":1773676843821,"data":{"id":1546861,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Hazel Doupe","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"헤이젤 더프","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"SA","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"","name":"هيزل دوب","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"","primary":false}}]}},"person_2716546_translations":{"at":1773676854820,"data":{"id":2716546,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Seo Ye Hwa is a South Korean actress who was born in 1989. She made her start in musical theater, and then went on to make her screen debut with a role in the 2014 drama series “Flower Grandpa Investigation Unit.” She followed up with “Thumping Spike” (2016) and more recently appeared in the 2019 drama “Her Private Life.”","name":"Seo Ye-hwa","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"徐