":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Ended","tagline":"","type":"Scripted","vote_average":0,"vote_count":0}},"person_2430100_translations":{"at":1773688731729,"data":{"id":2430100,"translations":[{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"대한민국의 요리사.","name":"송훈","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Song Hoon","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"宋勋","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"宋勳","primary":false}}]}},"person_1403028_translations":{"at":1773688731907,"data":{"id":1403028,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Erki Laur (born on August 16, 1976 in Tallinn) is an Estonian actor.\n\nHe graduated in 1998 from the Estonian Academy of Music as an actor.\n\nFrom 1998 to 2008, he was an actor at the Von Krahl Theater. Since 2008, he has been a freelance actor.","name":"","primary":false}},{"iso_3166_1":"EE","iso_639_1":"et","name":"Eesti","english_name":"Estonian","data":{"biography":"Erki Laur (sündinud 16. augustil 1976 Tallinnas) on eesti näitleja.\n\nTa on lõpetanud 1998. aastal Eesti Muusikaakadeemia Kõrgema Lavakunstikooli näitlejana (18.lend).\n\nAastatel 1998–2008 oli ta Von Krahli Teatri näitleja. Alates 2008. aastast on ta vabakutseline näitleja.","name":"Erki Laur","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Эрки Лаур","primary":false}},{"iso_3166_1":"TR","iso_639_1":"tr","name":"Türkçe","english_name":"Turkish","data":{"biography":"Erki Laur, 19 Ağustos 1976 tarihinde Tallinn, Estonya'da dünyaya gelmiştir. Estonya tiyatrosunun ve sinemasının deneyimli isimlerinden biri olan Laur, oyunculuk eğitimini Estonya Müzik ve Tiyatro Akademisi Sahne Sanatları Okulu'nda tamamlamış ve 2002 yılında mezun olmuştur. Profesyonel kariyerine ülkenin önde gelen avangart topluluklarından biri olan Von Krahl Tiyatrosu'nda başlamış, burada yer aldığı yenilikçi oyunlarla sahne disiplinini ve oyunculuk tekniğini geliştirmiştir. Daha sonra serbest oyuncu olarak çalışmaya devam etmiş ve çeşitli tiyatrolarda sahne almıştır.\n\nSinema ve televizyon dünyasında pek çok farklı karakteri canlandıran Laur, Estonya yapımlarının vazgeçilmez yüzlerinden biri haline gelmiştir. Kariyerinin erken dönemlerinde \"Nimed marmortahvlil\" (2002) gibi tarihi filmlerde ve popüler suç dizisi \"Kelgukoerad\"da rol almıştır. Ancak onu daha geniş bir izleyici kitlesine tanıtan proje, İlmar Raag'ın ödüllü filmi \"Klass\"ın olaylarını takip eden ve karakterlerin sonraki yaşamlarına odaklanan \"Klass: Elu pärast\" (2010) dizisi olmuştur.\n\nErki Laur'un uluslararası alanda dikkat çeken en prestijli işlerinden biri, 2018 yapımı \"Pank\" (The Bank) dizisidir. Gerçek olaylara dayanan ve 90'lı yıllarda Demir Perde'nin yıkılmasının ardından Estonya'daki bankacılık sektörünün vahşi yükselişini konu alan bu dizide, Allan karakterine hayat vermiştir. Dönemin hırslı atmosferini yansıtan bu performansı, kariyerinde önemli bir yer tutmaktadır. Sinemada ise \"Kertu\" (2013) ve psikolojik gerilim türündeki \"Teesklejad\" (Pretenders) (2016) gibi filmlerde dramatik yeteneğini sergilemiştir.\n\nSon dönemde, Estonya'da gişe rekorları kıran ortaçağ dedektiflik serisi \"Apteeker Melchior\" (Melchior the Apothecary) (2022) üçlemesinde Şövalye Freising rolüyle yer alarak dönem filmlerindeki başarısını kanıtlamıştır. Erki Laur'un küresel aksiyon sineması izleyicisiyle buluştuğu yapım ise, Jalmari Helander'in yönettiği ve dünya çapında ses getiren \"Sisu\" (2022) filmi olmuştur. Bu filmde, efsanevi eski komando Aatami Korpi'nin peşine düşen acımasız Nazi konvoyundaki askerlerden birini canlandırmış ve filmin gerilim dolu atmosferine katkıda bulunmuştur. Laur, hem tiyatro sahnesindeki köklü geçmişi hem de ekran önündeki çok yönlülüğüyle Estonya'nın saygın aktörlerinden biri olarak kariyerine devam etmektedir.","name":"","primary":false}}]}},"person_3056079_translations":{"at":1773688732920,"data":{"id":3056079,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Abhay Joshi","primary":false}},{"iso_3166_1":"IN","iso_639_1":"hi","name":"हिन्दी","english_name":"Hindi","data":{"biography":"","name":"Abhay Joshi","primary":true}}]}},"person_1234583_translations":{"at":1773688734401,"data":{"id":1234583,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Gerran Howell","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Gerran Lyn Howell (* 25. Februar 1991 in Wales) ist ein walisischer Schauspieler. Er hat in Young Dracula, einer Fernsehserie des BBC Wales, in 65 Folgen die Rolle des Vladimir Dracula gespielt.","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"格伦·霍威尔","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"格倫·霍威爾","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Ґерран Гавелл","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Герран Хауэлл","primary":false}}]}}}}