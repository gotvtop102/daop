{"version":1,"entries":{"person_1184468_translations":{"at":1773688717821,"data":{"id":1184468,"translations":[{"iso_3166_1":"NL","iso_639_1":"nl","name":"Nederlands","english_name":"Dutch","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Stevel Marc","primary":true}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Стевель Марк","primary":false}}]}},"person_2634629_translations":{"at":1773688718553,"data":{"id":2634629,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Francesco Filice","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Франческо Филиче","primary":false}}]}},"person_1379103_translations":{"at":1773688720478,"data":{"id":1379103,"translations":[{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Jenny Curtis","primary":true}}]}},"person_2593751_translations":{"at":1773688721074,"data":{"id":2593751,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"陈庭威（1961年9月1日－），广东潮阳人，香港影视演员。\n\n陈庭威于1984年毕业于无线电视艺员训练班，毕业后曾演出多部无线剧集。当时未获重用，知名度不高。至1991年他跳糟至亚洲电视，以连续剧《胜者为王》打响了知名度，人气还一度遍及台湾。此后他一直留在亚视演出剧集，很多都是主角，与亚视前主席林百欣有良好之关系。1998年亚视拍摄以林百欣生平为题材的《我来自潮州》，陈庭威还饰演以林百欣为蓝本的角色“郑琛”。\n\n随着亚视因亏损累累减少了剧集制作，近年陈庭威改在内地发展，甚少在香港露面。","name":"陈庭威","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Nathan Chan (Chinese: 陳庭威) is a Hong Kong actor.","name":"Nathan Chan Ting-Wai","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"陳庭威（1961 年 9 月 1 日－），廣東潮陽人，香港影視演員。\n\n陳庭威於 1984 年畢業於無線電視藝員訓練班，畢業後曾演出多部無線劇集。當時未獲重用，知名度不高。至 1991 年他跳糟至亞洲電視，以聯續劇《勝者為王》打響了知名度，人氣還一度遍及台灣。此後他一直留在亞視演出劇集，很多都是主角，與亞視前主席林百欣有良好之關係。1998 年亞視拍攝以林百欣生平為題材的《我來自潮州》，陳庭威還飾演以林百欣為藍本的角色“鄭琛”。\n\n隨著亞視因虧損累累減少了劇集製作，近年陳庭威改在內地發展，甚少在香港露面。","name":"陳庭威","primary":true}}]}},"person_1486957_translations":{"at":1773688721969,"data":{"id":1486957,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Bridget Everett","primary":true}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"AT","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"브리짓 에버렛","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Бріджет Еверетт","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Бриджет Эверетт","primary":false}}]}},"person_20563_translations":{"at":1773688723620,"data":{"id":20563,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Alex Veadov is a Russian-American film and television actor. Since the late 1980s the actor Alex Veadov aka Oleg Flyshecker, whose family was from theCaucasus, appeared in TV movies, -series and feature films. Alex Veadov also voiced characters in some computer and video games. He often played and voiced Russian characters. Alex Veadov is best known for starring in the film We Own the Night taking the role as a Russian mob drug lord and hit-man named Vadim Nezhinski. Veadov played the role of Christo, a drug smuggler, in the 2012 movie Act of Valor.","name":"Alex Veadov","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"亚历克斯·维多夫（Alex Veadov）是俄裔美国电影和电视演员。自 1980 年代后期以来，演员亚历克斯·维多夫（Alex Veadov）又名奥列格·弗莱谢克（Oleg Flyshecker），他的家人来自高加索地区，出现在电视电影、连续剧和故事片中。亚历克斯·维多夫（Alex Veadov）还在一些电脑和视频游戏中为角色配音。他经常扮演俄罗斯角色并为其配音。亚历克斯·维多夫 （Alex Veadov） 最出名的是主演电影《我们拥有夜晚》，饰演一位名叫瓦迪姆·涅任斯基的俄罗斯黑帮毒枭和杀手。Veadov 在 2012 年的电影《英勇行动》中扮演毒品走私者克里斯托的角色。","name":"亚历克斯·维多夫","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Алекс Видов","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"亞歷克斯·維多夫（Alex Veadov）是俄裔美國電影和電視演員。自 1980 年代後期以來，演員亞歷克斯·維多夫（Alex Veadov）又名奧列格·弗萊謝克（Oleg Flyshecker），他的家人來自高加索地區，出現在電視電影、聯續劇和故事片中。亞歷克斯·維多夫（Alex Veadov）還在一些電腦和視頻遊戲中為角色配音。他經常扮演俄羅斯角色併為其配音。亞歷克斯·維多夫 （Alex Veadov） 最出名的是主演電影《我們擁有夜晚》，飾演一位名叫瓦迪姆·涅任斯基的俄羅斯黑幫毒梟和殺手。Veadov 在 2012 年的電影《英勇行動》中扮演毒品走私者克里斯託的角色。","name":"亞歷克斯·維多夫","primary":false}}]}},"tv_155545_credits":{"at":1773688724927,"data":{"cast":[{"adult":false,"gender":0,"id":3654066,"known_for_department":"Acting","name":"Pilar Pascual","original_name":"Pilar Pascual","popularity":0.7167,"profile_path":"/tges9UoP8GOvbL4DiOMFjXhbfuT.jpg","character":"Stefania \"Steffi\" Navarro","credit_id":"62efca6a813cb6007b33adb2","order":0},{"adult":false,"gender":1,"id":3380885,"known_for_department":"Acting","name":"Abril di Yorio","original_name":"Abril di Yorio","popularity":0.2682,"profile_path":"/z5Gbj9kTMyvt3iEoFmMIVPjpXTL.jpg","character":"Luz Aguilar","credit_id":"61dffa4ea6fdaa0068faa950","order":1},{"adult":false,"gender":2,"id":2126335,"known_for_department":"Acting","name":"Víctor Varona","original_name":"Víctor Var