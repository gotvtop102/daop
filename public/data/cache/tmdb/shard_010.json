玟","primary":false}}]}},"person_931382_translations":{"at":1773688722082,"data":{"id":931382,"translations":[{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Marius Panduru","primary":false}},{"iso_3166_1":"RO","iso_639_1":"ro","name":"Română","english_name":"Romanian","data":{"biography":"","name":"Marius Panduru","primary":true}}]}},"tv_301874_detail_vi-VN":{"at":1773688722887,"data":{"adult":false,"backdrop_path":"/zS5dYnequDfVWutSVxE1uOpbLHC.jpg","created_by":[],"episode_run_time":[],"first_air_date":"2025-11-15","genres":[{"id":35,"name":"Phim Hài"}],"homepage":"","id":301874,"in_production":true,"languages":["zh"],"last_air_date":"2025-12-13","last_episode_to_air":{"id":6689148,"name":"Episode 12","overview":"","vote_average":0,"vote_count":0,"air_date":"2025-12-13","episode_number":12,"episode_type":"finale","production_code":"","runtime":48,"season_number":1,"show_id":301874,"still_path":"/uqPFw49eeEdOPtSJnovR5l36YCP.jpg"},"name":"Nhật Ký Sinh Tồn Của Những Người Đàn Ông Ở Nhà Tù","next_episode_to_air":null,"networks":[{"id":3801,"logo_path":"/mQBLK2OkX19oX352goiuF1ztXnh.png","name":"MyVideo","origin_country":"TW"},{"id":6316,"logo_path":"/ewwmht0dJZVia8gvmmf3rKSZynF.png","name":"iQIYI International","origin_country":""}],"number_of_episodes":12,"number_of_seasons":1,"origin_country":["TW"],"original_language":"zh","original_name":"監所男子囚生記","overview":"MiNhật Ký Sinh Tồn Của Những Người Đàn Ông Ở Nhà Tù (OOPS! I'M IN JAIL) là bộ phim hài công sở nước ngoài được đạo diễn bởi Cao Bỉnh Quyền, người từng đoạt giải Kim Chung của Đài truyền hình Đài Loan chỉ đạo sản xuất. Phim có sự tham gia của Lưu Dĩ Hào (từng tham gia Khi Tình Yêu Gặp Nhà Khoa Học, Khi Phụ Nữ Toả Sáng), Trần Trạch Diệu (từng tham gia Phân Bối Nhân Sinh, Thanh Niên Phú Đô) và Dương Hựu Ninh (từng tham gia Theo Dòng Nước Ngầm, Lưu Kim Tuế Nguyệt). “Người giống như đang bị giam hơn cả phạm nhân chính là chúng ta, những nô lệ của tư bản!”. Ngôi sao Taekwondo tiềm năng A Diệu (do Trần Trạch Diệu thủ vai) phải giải nghệ vì chấn thương, sa vào cờ bạc, và để trả nợ, anh bị thế lực ngầm ép vào làm quản giáo trong nhà tù, chăm sóc ông trùm Cát Oa Oa (Dương Hựu Ninh đóng).","popularity":2.8772,"poster_path":"/jxJK5oYYkEYSVHg5XShvNxAjuBF.jpg","production_companies":[],"production_countries":[{"iso_3166_1":"TW","name":"Taiwan"}],"seasons":[{"air_date":"2025-11-15","episode_count":12,"id":477575,"name":"Season 1","overview":"","poster_path":"/jxJK5oYYkEYSVHg5XShvNxAjuBF.jpg","season_number":1,"vote_average":7.8}],"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Returning Series","tagline":"","type":"Miniseries","vote_average":7.5,"vote_count":2}},"person_4316_translations":{"at":1773688724600,"data":{"id":4316,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Henry George \"Harry\" Carey Jr. (May 16, 1921 - December 27, 2012) was an American actor. He appeared in more than ninety films including several John Ford westerns as well as numerous television series. The son of actors Harry Carey Sr. and Olive Carey, he attempted a singing career before beginning his acting career in the John Ford Stock Company. Director John Ford became a close friend and collaborator. Carey appeared in such notable Ford films as 3 Godfathers (1948), She Wore a Yellow Ribbon (1949), The Searchers (1956), and Cheyenne Autumn (1964), some also featuring appearances by his parents. He became a respected character actor like his father.  Carey made four films with director Howard Hawks: Red River (1948), Monkey Business (1952), Gentlemen Prefer Blondes (1953), and Rio Bravo (1959 - scenes cut). He also frequently co-starred with actors John Wayne and Ben Johnson, acting together in nine films each. Between 1955 -1957, Carey appeared as ranch counselor Bill Burnett in the serial Spin and Marty, seen on Walt Disney's Mickey Mouse Club. In the 1960s, Carey appeared on such western series as Have Gun - Will Travel and The Legend of Jesse James.\n\nLater film roles include George Arthur in The Long Riders (1980), Mr. Anderson in Gremlins (1984), aging biker Red in Mask (1985), Joshua Brackett in The Whales of August (1987), saloon old-timer Zeke in Back to the Future Part III (1990), and Marshal Fred White in Tombstone (1993).","name":"Harry Carey, Jr.","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"Harry Carey Jr. est le fils d'une star du cinéma muet, Harry Carey, et de l'actrice Olive Carey. Il naît le 16 mai 1921 dans le ranch de ses parents situé à Saugus, un quartier de Santa Clarita, au nord de Los Angeles. Le jeune Carey grandit parmi le bétail et les chevaux1,2. Durant sa jeunesse il espère devenir chanteur1,3. Il est scolarisé dans une école privée d'Hollywood, le Black-Foxe Military Institute. Pendant la Seconde Guerre mondiale, Carey rejoint l'US Navy et sert dans le Pacifique. En 1944, il épouse Marilyn Fix, la fille de l'acteur Paul Fix.\n\nAprès la guerre, Harry Carey Jr. entame une carrière cinématographique. John Wayne le recommande à Howard Hawks et Carey obtient un rôle dans La Rivière rouge (Red River), le dernier film dans lequel joue son père Harry Carey Sr. Après la mort de celui-ci, John Ford confie à Harry Carey Jr. des rôles plus importants, notamment dans Le Fils du désert (Three Godfathers). Durant les deux décennies suivantes, il fait partie des acteurs qui apparaissent de façon régulière dans les westerns de John Ford. (source : Wikipédia)","name":"","primary":false}},{"iso_3166_1":"ES","iso_639_1":"ca","name":"Català","english_name":"Catalan","data":{"biography":"Harry Carey \"Dobe\" Jr., nascut Henry George Carey, Jr (Saugus, Califòrnia, 16 de maig de 1921 − Santa Barbara, 27 de desembre de 2012), va ser un actor de cinema estatunidenc fill del també actor Harry Carey.","name":"","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"해리 커리 쥬니어","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Гарри Кэри мл.","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Гаррі Кері молодший","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"小哈里·凱里","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"ハリー・ケリー・ジュニア","primary":false}}]}},"person_1613379_translations":{"at":1773688726593,"data":{"id":1613379,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Taku Yashiro is a Japanese voice actor affiliated with VIMS.","name":"Taku Yashiro","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"八代 拓は、日本の男性声優。岩手県出身。ヴィムス所属。タイガーマスクW』の東ナオト / タイガーマスク役をはじめ、『アイドルマスター SideM』の柏木翼役など、人気作品のキャラクターを多く演じる。","name":"八代拓","primary":true}},{"iso_3166_1":"TR","iso_639_1":"tr","name":"Türkçe","english_name":"Turkish","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"IN","iso_639_1":"hi","name":"हिन्दी","english_name":"Hindi","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"八代拓是日本的男性聲優。出身於岩手縣盛岡市，畢業於日本播音演技研究所，所屬公司為 VIMS。","name":"八代拓","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography"