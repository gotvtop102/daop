:"English","data":{"biography":"","name":"Amina Abdi","primary":true}}]}},"person_5431193_translations":{"at":1773676864465,"data":{"id":5431193,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"AKA Fatrick Ewing.","name":"Luke Manley","primary":true}}]}},"person_3916722_translations":{"at":1773676868429,"data":{"id":3916722,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Ghazi Al Ruffai","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Гази Аль Руффаи","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"가지 알 루파이","primary":false}}]}},"person_4738228_translations":{"at":1773676883715,"data":{"id":4738228,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Lox Pratt is a British actor known for his breakout lead role as bad boy 'Jack' in BBC's Lord of the Flies and 'Draco Malfoy' in HBO's Harry Potter series.","name":"Lox Pratt","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TR","iso_639_1":"tr","name":"Türkçe","english_name":"Turkish","data":{"biography":"2012'de İngiltere'nin Cornwall Bölgesi'nde dünyaya gelen Lox Pratt, ilk oyunculuğunu 2024'te Malezya'da çekilen ve Şubat 2026'da yayına giren Sineklerin Tanrısı dizisinde yaptı. Dört bölümlük mini diziyle olumlu yorumlar alan Pratt, HBO'nun 2027'de yayına girmesi planlanan Harry Potter dizisinde Draco Malfoy rolüyle yer alacağını 45 bin takipçili Instagram hesabından duyurdu.\n\nRöportajlarında erken yaşlarda hikaye anlatmaya, film çekmeye, dans etmeye ve yazmaya ilgi duyduğunu ve bunun da kendisini oyunculuğa yönlendirdiğini söyleyen Pratt; yerel bir tiyatro grubuna katıldıktan sonra açık bir oyuncu seçimine alındı. Böylelikle Sineklerin Tanrısı'nda ilk büyük rolünü kazandı. Pratt, ayrıca gelecekte yönetmenlik ve senaristlik alanlarında da çalışmalar yapmak istediğini ifade etti.\n\nLox ve diğer çocuk oyuncuların eğitimlerinin büyük bir bölümünü Londra'nın kuzeyindeki Watford'da bulunan Warner Bros'un Leavesden stüdyosunda kurulacak bir mini okuldaki öğretmenlerden alacaklar. HBO'nun CEO'sunun yaptığı açıklamaya göre dizi, 10 yıl boyunca kesintisiz devam edecek. Çocuk oyuncular ergenliklerini, sınav hazırlıklarını, replik ezberlerini ve daha bir çok şeyi set karavanlarında geçirecekler.\n\nÜç erkek kardeşe sahip olan mavi gözlü sarışın Lox; bateri çalmayı, şarkı söylemeyi, dans etmeyi, sörf yapmayı ve kaykay kaymayı seviyor.","name":"","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Локс Пратт","primary":false}}]}},"person_5640869_translations":{"at":1773676885571,"data":{"id":5640869,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Kai Wilson","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Кай Уилсон","primary":false}}]}},"tv_315224_keywords":{"at":1773676886423,"data":{"id":315224,"results":[]}},"person_61182_translations":{"at":1773676896040,"data":{"id":61182,"translations":[{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Gillian Vigman (born January 28, 1972) is an American actress and comedian. She is known for her roles in the films The Hangover (2009), The Hangover Part II (2011), and The Hangover Part III (2013), as well as the television series The Mindy Project (2012-2017) and The Good Place (2016-2020).\n\nVigman was born in New Jersey and raised in New York City. She attended the University of Pennsylvania, where she studied theater. After graduating, she moved to Los Angeles to pursue a career in comedy.\n\nVigman is 5 feet 5 inches (1.65 meters) tall.","name":"Gillian Vigman","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"吉莲·韦格曼","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"ג'יליאן ויגמן","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"吉蓮·韋格曼","primary":false}}]}},"person_83285_translations":{"at":1773676902792,"data":{"id":83285,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"From Wikipedia, the free encyclopedia. Leah Marie Pipes  (born August 12, 1988) is an American actress. She is most notable for starring in the television series Life Is Wild and slasher film remake Sorority Row. Description above from the Wikipedia article Leah Pipes, licensed under CC-BY-SA, full list of contributors on Wikipedia.  ","name":"Leah Pipes","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"","primary":false}}]}},"person_5369313_translations":{"at":1773676903505,"data":{"id":5369313,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Lv Yihao","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Лу И Хао","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"呂奕豪","p