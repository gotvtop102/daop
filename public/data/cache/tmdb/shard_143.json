{"version":1,"entries":{"person_1239240_translations":{"at":1773470202630,"data":{"id":1239240,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Yoo Jae-suk (유재석) is a South Korean comedian and television host, commonly called \"The Nation's MC\" (국민 MC). ","name":"Yoo Jae-suk","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"유재석(劉在錫, 1972년 8월 14일~)은 대한민국의 희극인, 방송인이다. 1991년에 KBS 공채 7기 개그맨으로 데뷔했다. 《X맨》, 《무한도전》, 《해피투게더》, 《런닝맨》, 《놀면 뭐하니?》, 《유 퀴즈 온 더 블럭》, 《식스센스》 등 다수의 TV 프로그램 진행을 맡았거나 맡고 있다. 대한민국 지상파 방송 3사(KBS, MBC, SBS)와 백상예술대상의 대상을 총 19회 수상하여 최다 수상 기록을 세웠으며, 2018년 대중문화예술상 대통령 표창을 받았다.","name":"유재석","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"刘在锡（朝鲜语：유재석 Yoo Jae-Seok；日语：ユ·ジェソク；1972年8月14日－），韩国知名主持人、谐星及演员，本贯江陵，曾音译刘在石。昵称为“国民MC”，分别于韩国三大无线电视台KBS、MBC、SBS主持不少综艺节目，其中包括非常受欢迎的《无限挑战》、《家族的诞生》及《Running Man》等。\n\n无名时期主持节目时常带着蚱蜢头套，因而有“蚱蜢”之名。他亲切、聪明、可爱的主持风格令他成为韩国最受欢迎的主持及喜剧演员，并和姜虎东并称韩国主持界两大山脉。刘在锡在2008年时的出场费高达每场840万韩圆，在韩国三大平无线电视台KBS、MBC、SBS中主持的节目收视率都曾达到第一。\n\n2011年至2015年期间，刘在锡都是在没有所属公司的情况下独自活动，直到2015年7月确定正式和FNC娱乐签约。","name":"刘在锡","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"劉在錫是一位韓國喜劇演員和電視主持人，通常被稱為「國民MC」。","name":"劉在錫","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Ю Чэ Сок","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"Yoo Jae-suk nascido em 14 de agosto de 1972, é um comediante sul-coreano, além de apresentador e personalidade da televisão. Ele é integrante de diversos programas televisivos, incluindo os populares e de grande audiência Infinite Challenge e Running Man.","name":"Yoo Jae Suk","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"劉在錫是一位韓國喜劇演員和電視主持人，通常被稱為「國民 MC」。","name":"劉在錫","primary":false}},{"iso_3166_1":"MX","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Yoo Jae Suk","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Yoo Jae-suk","primary":false}}]}},"movie_1542299_credits":{"at":1773211329664,"data":{"id":1542299,"cast":[{"adult":false,"gender":2,"id":2273510,"known_for_department":"Acting","name":"Chen Yiming","original_name":"陈奕名","popularity":0.4616,"profile_path":"/qmYi0ecpTUSQ2kLGO1O5q845Ynv.jpg","cast_id":1,"character":"","credit_id":"68bc1e35b5e9c25e5798b78e","order":0},{"adult":false,"gender":2,"id":4849711,"known_for_department":"Acting","name":"Han Bowei","original_name":"韩伯维","popularity":0.1243,"profile_path":"/fj4ue20FzpCaJ5PD85FNOBAUtlD.jpg","cast_id":2,"character":"","credit_id":"68bc1e3c0251feffce946ec1","order":1},{"adult":false,"gender":1,"id":1399224,"known_for_department":"Acting","name":"Wenjing Qin","original_name":"Wenjing Qin","popularity":0.3743,"profile_path":"/ik0G4BfREVlri2la4wUbCa6YNGD.jpg","cast_id":3,"character":"","credit_id":"68bc1e4532854f06dc9bfdde","order":2}],"crew":[]}},"person_4179404_translations":{"at":1773319437278,"data":{"id":4179404,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Wissem Belgharek","primary":false}},{"iso_3166_1":"AE","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"","name":"Wissem Belgharek","primary":true}}]}},"tv_254953_credits":{"at":1773578265367,"data":{"cast":[{"adult":false,"gender":2,"id":4495,"known_for_department":"Acting","name":"Steve Carell","original_name":"Steve Carell","popularity":5.7305,"profile_path":"/cS7Cbyff6wFVfUGem497vy9LS7A.jpg","character":"Greg Russo","credit_id":"664b768933bcdede539862c4","order":0},{"adult":false,"gender":1,"id":1853