bvkRj2Jmku4kGw1HOVD.jpg","character":"Queen Dowager","credit_id":"69256788a777c445c330c740","order":7},{"adult":false,"gender":2,"id":4365677,"known_for_department":"Acting","name":"Lee Seung-woo","original_name":"이승우","popularity":0.3972,"profile_path":"/Ail0c4xZ2gwfVmlayIh28TFUSqn.jpg","character":"Daechu","credit_id":"6971af7c7dc5308e87e36adf","order":8}],"crew":[{"adult":false,"gender":0,"id":5720111,"known_for_department":"Directing","name":"Ham Young-geol","original_name":"함영걸","popularity":0.0071,"profile_path":null,"credit_id":"68db9ae4686bca377f2df29d","department":"Directing","job":"Director"},{"adult":false,"gender":1,"id":6021300,"known_for_department":"Creator","name":"이선","original_name":"이선","popularity":0.0485,"profile_path":null,"credit_id":"69990fb63b092022afe8e856","department":"Writing","job":"Writer"}],"id":301886}},"person_236075_translations":{"at":1772691658592,"data":{"id":236075,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Michael Miu Kiu-Wai ( 苗僑偉 ) ( born 18 June 1958 ) is a Hong Kong actor and businessman. His career has been met with popular success in his youth, followed by a resurgence in middle age after a period of hiatus. He is considered one of the most popular Hong Kong actors of the 1980s. Miu is best known for the villainous Yeung Hong in the 1983 television drama The Legend of the Condor Heroes.","name":"Michael Miu Kiu-Wai","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"苗侨伟（Michael Miu），1958年6月18日生于浙江舟山，五岁时移居中国香港。香港影视男演员、商人。\n\n1980年，苗侨伟参加香港无线电视第9期艺员训练班出道。1982年参演《飞越十八层》；1983年，出演《射雕英雄传》，凭借杨康一角成名，与梁朝伟、刘德华、汤镇业、黄日华被称为无线“五虎将” 。\n\n1989年退出娱乐圈，创办艺视眼镜，担任集团主席 。2004年复出，先后主演《学警雄心》《赌场风云》《雷霆扫毒》等电视剧 。2008年，夺得腾讯星光大典“港台地区年度最具实力电视男演员”奖 。2014年，主演警匪剧《使徒行者》打破港剧网络播放记录，凭借卓Sir获得TVB马来西亚星光荟萃颁奖典礼“我最喜爱TVB电视角色”奖。\n\n2015年4月，苗侨伟签约坤杰影视传媒有限公司，工作重心放在中国内地，主打内地市场；同年参演中国内地电视剧《猛龙过江》。2016年，在蒋家骏执导的电视剧《射雕英雄传》里饰演黄药师 。2017年11月参演电视剧《守护神》，27日，凭借《使徒行者2》获得TVB马来西亚星光荟萃颁奖典礼最喜爱TVB男主角奖 。","name":"苗侨伟","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"苗僑偉（Michael Miu），1958 年 6 月 18 日生於浙江舟山，五歲時移居香港。香港影視男演員、商人。\n\n1980 年，苗僑偉參加香港無線電視第 9 期藝員訓練班出道。1982 年參演《飛越十八層》；1983 年，出演《射鵰英雄傳》，憑藉楊康一角成名，與梁朝偉、劉德華、湯鎮業、黃日華被稱為無線“五虎將” 。\n\n1989 年退出娛樂圈，創辦藝視眼鏡，擔任集團主席 。2004 年復出，先後主演《學警雄心》《賭場風雲》《雷霆掃毒》等電視劇 。2008 年，奪得騰訊星光大典“港台地區年度最具實力電視男演員”獎 。2014 年，主演警匪劇《使徒行者》打破港劇網絡播放記錄，憑藉卓 Sir 獲得 TVB 馬來西亞星光薈萃頒獎典禮“我最喜愛 TVB 電視角色”獎。\n\n2015 年 4 月，苗僑偉簽約坤傑影視傳媒有限公司，工作重心放在中國內地，主打內地市場；同年參演中國內地電視劇《猛龍過江》。2016 年，在蔣家駿執導的電視劇《射鵰英雄傳》裏飾演黃藥師 。2017 年 11 月參演電視劇《守護神》，27 日，憑藉《使徒行者 2》獲得 TVB 馬來西亞星光薈萃頒獎典禮最喜愛 TVB 男主角獎 。","name":"苗僑偉","primary":true}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Miêu Kiều Vỹ","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"苗僑偉","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Майкл Мю","primary":false}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"Michael Miu Kiu-Wai","primary":false}}]}},"person_1581097_translations":{"at":1772691666436,"data":{"id":1581097,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Zoey Vargas","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"","primary":false}}]}}}}