 bộ phim hot như Trường Ca Hành (vai Di Di Cổ Lệ), Chuế Tế (vai Nguyên Cẩm Nhi), Sở Kiều Truyện (vai Cẩm Chúc), Nhiệt Huyết Thiếu Niên (vai Ngô Tiêu Tiêu),...","name":"Tào Hi Nguyệt","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Цао Си Юэ","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"曹曦月，中國大陸女演員、模特。2013 年電視劇《鎧甲勇士拿瓦》中擔任女主角馬靈靈一角被大家熟知。","name":"曹曦月","primary":false}}]}},"tv_284735_detail_vi-VN":{"at":1772691618842,"data":{"adult":false,"backdrop_path":"/d9nnTWXmE0I1skSBNYCrecUxrJi.jpg","created_by":[],"episode_run_time":[],"first_air_date":"2026-01-28","genres":[{"id":18,"name":"Phim Chính Kịch"}],"homepage":"https://v.qq.com/x/cover/mzc00200nt0pggl.html","id":284735,"in_production":false,"languages":["zh"],"last_air_date":"2026-02-04","last_episode_to_air":{"id":6891348,"name":"Episode 24","overview":"","vote_average":0,"vote_count":0,"air_date":"2026-02-04","episode_number":24,"episode_type":"finale","production_code":"","runtime":null,"season_number":1,"show_id":284735,"still_path":null},"name":"回到1995爱上你","next_episode_to_air":null,"networks":[{"id":2007,"logo_path":"/6Lfll43wYG2eyereOBjpYFRSGs4.png","name":"Tencent Video","origin_country":"CN"}],"number_of_episodes":24,"number_of_seasons":1,"origin_country":["CN"],"original_language":"zh","original_name":"回到1995爱上你","overview":"","popularity":1.2135,"poster_path":"/6dinsIQBbG1nojsQIZrmbJeJ48x.jpg","production_companies":[],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"seasons":[{"air_date":"2026-01-28","episode_count":24,"id":443216,"name":"Season 1","overview":"","poster_path":null,"season_number":1,"vote_average":0}],"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Ended","tagline":"","type":"Scripted","vote_average":10,"vote_count":1}},"person_83966_translations":{"at":1772691619291,"data":{"id":83966,"translations":[{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Pascale Arbillot (born 17 April 1970) is a French actress. She is a graduate of the Paris Institute of Political Sciences; however, soon after, she decided to become an actress. She has appeared in films, on television and in the theatre.","name":"Pascale Arbillot","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"Pascale Arbillot est une actrice française née le 17 avril 1970.  Si la comédie était son rêve, Pascale Arbillot ne s'est pas tout de suite engagée dans cette voie, puisque ce n'est qu'après un passage par Sciences Po qu'elle a fait ses débuts sur les planches, avant d'apparaître au générique de L'Affaire de Sergio Gobbi, en 1994.\n\nUn premier rôle qui sera suivi, deux ans plus tard, d'une participation au court métrage de François Ozon, Scènes de lit, dans l'épisode de \"L'Homme idéal\". Suite à ce rôle, la comédienne se partage entre théâtre, télévision (dans la série Crimes en série) et cinéma, grâce auquel il est possible de la voir dans Le Sourire du clown où elle tient le premier rôle féminin aux côtés de Ticky Holgado et Vincent Elbaz ou dans L'Extraterrestre, où elle donne la réplique à Didier Bourdon et Bernard Campan.\n\nAu cours des années 2000, Pascale Arbillot tourne sous la direction de son compagnon Artus de Penguern, dans Grégoire Moulin contre l'humanité, mais également sous celle d'Arnaud Viard (Clara et moi), avant de décrocher l'un des rôles principaux de la série Merci, les enfants vont bien !, qu'elle tiendra tout au long des 3 saisons. La comédienne n'en délaisse pas pour autant le cinéma, puisqu'elle joue dans le film noir Un printemps à Paris, la comédie Notre univers impitoyable ou encore Parlez-moi de la pluie, troisième réalisation d'Agnès Jaoui. En 2009, on la retrouve dans la première de Gad Elmaleh (Coco), jouant l'épouse du héros, obligée de subir ses délires mégalomaniaques.\n\nC'est dans un registre de \"comédie de couples\" qu'elle figure ensuite, avec le bien nommé Divorces en 2009, suivi des Meilleurs amis du monde. L'année d'après lui offre une place au générique de la très attendue réalisation de Guillaume Canet, Les Petits mouchoirs, où elle intègre une nouvelle fois un groupe d'amis, réuni pour les vacances suite à l'annonce d'un bouleversant événement. Pascale incarne ensuite la femme de François Damiens dans Une Pure affaire avant de rejoindre François Cluzet dans L'Art d'aimer.\n\nEn 2015, la comédienne croise la route de Franck Dubosc et Gérard Lanvin dans Pension complète. L'année suivante, Pascale campe une mère dépassée par l'émancipation de ses adolescentes dans Juillet Août avant de devenir la meilleure amie d'Agnès Jaoui dans Aurore. Très active, l'actrice s'illustre dans Momo aux côtés de Christian Clavier puis brille en compagne d'un Alex Lutz grimé en papy chanteur dans Guy. En 2019, elle reprend son rôle d'Isabelle dans Nous finirons ensemble, suite des Petits mouchoirs.","name":"","primary":false}},{"iso_3166_1":"GR","iso_639_1":"el","name":"ελληνικά","english_name":"Greek","data":{"biography":"Ο Πασκάλ Αρμπιγιό είναι Γαλλίδα ηθοποιός. Είναι πτυχιούχος του Ινστιτούτου Πολιτικών Επιστημών του Παρισιού. Παρόλο που η υποκριτική ήταν το όνειρό της, η Πασκάλ Αρμπιγιό δεν ακολούθησε αμέσως αυτόν τον δρόμο, αφού μόλις μετά από ένα διάστημα στο Sciences Po έκανε το ντεμπούτο της στη σκηνή, πριν εμφανιστεί στους τίτλους τέλους της παράστασης L'Affaire του Sergio Gobbi, το 1994. Έχει εμφανιστεί σε ταινίες, στην τηλεόραση και στο θέατρο","name":"","primary":false}},{"iso_3166_1":"CA","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"Pascale Arbillot","primary":true}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"帕斯卡爾·艾比略特","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Паскаль Арбийо","primary":false}}]}},"person_15343_translations":{"at":1772691626672,"data":{"id":15343,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Kim Fleming","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Ким Флеминг","primary":false}}]}},"movie_1596291_keywords":{"at":1772691626821,"data":{"id":1596291,"keywords":[{"id":316,"name":"chess"},{"id":4411,"name":"sexism"},{"id":5561,"name":"child prodigy"},{"id":4926,"name":"chess champion"},{"id":182210,"name":"playing chess"},{"id":228041,"name":"prodigy"},{"id":275348,"name":"chess match"},{"id":333780,"name":"chess game"},{"id":363103,"name":"kasparov"}]}},"person_303020_translations":{"at":1772691628391,"data":{"id":303020,"translations":[{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"Meaghan Rath (Montréal, 18 giugno 1986) è un'attrice canadese.\n\nDi origini austriache da parte di padre ed indiane da parte di madre, la Rath è conosciuta per aver interpretato il ruolo di Adena Stiles nella serie televisiva 15/Love dalla prima stagione.\n\nNel 2011 è protagonista del remake statunitense Being Human nel ruolo del fantasma Sally.","name":"","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Meaghan Rath ist eine kanadische Schauspielerin. Bekannt wurde sie durch ihre Rollen in Matchball für die Liebe und in The Assistens. Sie stellte zwischen 2011 und 2014 den Geist Sally Malik in der US-Version von Being Human dar.  Im April 2014 erhielt sie eine wiederkehrende Rolle in der Serie Banshee - Small Town. Big Secrets. Seit 2017 hat sie eine Hauptrolle in der Serie Hawaii Five-0 als Officer Tani Rey.","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Meaghan Rath is a Canadian actress. She is known for her television roles on Being Human, 15/Love, The Assistants, and Hawaii Five-0.","name":"Meaghan Rath","primary":true}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Meaghan Rath (18 de junio de 1986) es una actriz de cine y televisión canadiense.\n\nActuó en la serie de televisión 15/Love y The Assistants. Aunque su fama le llegó al interpretar a Sally Malik en la serie de Syfy, Casi Humanos.","name":"","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"Канадская актриса. Наиболее известна по роли Салли Малик в американской адаптации британского телесериала «Быть человеком».","name":"Миган Рат","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"Meaghan Rath, née le 18 juin 1986 à Montréal au (Québec), est une actrice canadienne.  Meaghan Rath a des origines indiennes du côté de sa mère et britanniques et autrichiennes du côté de son père. Elle a passé son enfance dans le milieu de la natation, rêvant de faire partie de l'équipe canadienne. À huit ans, elle nageait de façon compétitive, mais à l'adolescence elle a décidé de laisser son bonnet de bain pour devenir comédienne. Elle est la sœur de l'acteur canadien Jesse Rath.\n\nElle a commencé sa formation à la Children' Shakespeare Company, la Montreal School Of Performing Arts, au Centre Sacred Heart Drama et à la Dynamic Theatre Factory. Elle fait ses débuts à la télé dans la série 15/A (15/Love) où elle joue le rôle d'Adena Stiles. Elle étudie ensuite la communication et le cinéma au college Dawson, à Montréal. Elle est connue pour avoir joué dans Hawaii 5-0 une série policière qui se déroule à Hawaii dont le personnage principal est Alex O'Loughlin","name":"","primary":false}}]}},"person_215772_translations":{"at":1772691634697,"data":{"id":215772,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Shelby Adamowsky","primary":true}}]}},"tv_270444_detail_vi-VN":{"at":1772691639721,"data":{"adult":false,"backdrop_path":"/ra12F3J3uVe112FEqBGmQapW2Bu.jpg","created_by":[],"episode_run_time":[],"first_air_date":"2026-02-11","genres":[{"id":18,"name":"Phim Chính Kịch"},{"id":10768,"name":"War & Politics"}],"homepage":"https://www.netflix.com/title/81707679","id":270444,"in_production":false,"languages":["pl"],"last_air_date":"2026-02-11","last_episode_to_air":{"id":6830938,"name":"Tập 6","overview":"Khi Jolanta thành công xoay chuyển tình thế trước giới chức thành phố, Niedziela yêu cầu các biện pháp đặc biệt để ngăn chặn cô.","vote_average":8,"vote_count":2,"air_date":"2026-02-11","episode_number":6,"episode_type":"finale","production_code":"","runtime":66,"season_number":1,"show_id":270444,"still_path":"/PxhqaiZeD397Hoc0aaIzn3fpw6.jpg"},"name":"Những đứa trẻ nhuốm chì","next_episode_to_air":null,"networks":[{"id":213,"logo_path":"/wwemzKWzjKYJFfCeiB57q3r4Bcm.png","name":"Netflix","origin_country":""}],"number_of_episodes":6,"number_of_seasons":1,"origin_country":["PL"],"original_language":"pl","original_name":"Ołowiane dzieci","overview":"Phát hiện ra rằng trẻ em sống gần nhà máy luyện kim bị nhiễm độc chì, vị bác sĩ trẻ nọ mạo hiểm sự nghiệp và an toàn của bản thân để cứu bọn trẻ.","popularity":9.2596,"poster_path":"/ous8IYSqDHNd8gOJDDQBL3kNqqW.jpg","production_companies":[{"id":238123,"logo_path":"/vlS72xE2u0jf82STcje0PD96KN.png","name":"Orient Film","origin_country":"PL"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"}],"seasons":[{"air_date":"2026-02-11","episode_count":6,"id":416594,"name":"Loạt phim truyền hình ngắn","overview":"","poster_path":"/ous8IYSqDHNd8gOJDDQBL3kNqqW.jpg","season_number":1,"v