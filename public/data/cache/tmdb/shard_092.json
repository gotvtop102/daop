{"version":1,"entries":{"person_1353921_translations":{"at":1773211331157,"data":{"id":1353921,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"David Sturzaker","primary":true}}]}},"person_2350581_translations":{"at":1773211331238,"data":{"id":2350581,"translations":[{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"2015 年，蘇偉泉選擇了掛靴退出球圈，機緣巧合之下遇到伯樂黃柏高 (前太陽飛馬榮譽主席)，得到他的賞識而加入電影圈，突然轉型做演員簽約娛樂公司，當初決定轉行做演員時，蘇偉泉家人知道後反而非常贊成。現時蘇偉泉既要學習普通話，又要學打功夫和駕駛摩託車，為未來參與的電影做準備，拍了多個廣告和 MV 的蘇偉泉是公司 2016 年力捧的新人，將會參演不同的電影。2016 年，開始首次接拍電視劇和電影的蘇偉泉，已經可以參與幾部大製作包括《狂獸》、《今晚打喪屍》及劇集《三一如三》等。","name":"蘇偉泉","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"2015年，苏伟泉选择了挂靴退出球圈，机缘巧合之下遇到伯乐黄柏高(前太阳飞马荣誉主席)，得到他的赏识而加入电影圈，突然转型做演员签约娱乐公司，当初决定转行做演员时，苏伟泉家人知道后反而非常赞成。现时苏伟泉既要学习普通话，又要学打功夫和驾驶摩托车，为未来参与的电影做准备，拍了多个广告和MV的苏伟泉是公司2016年力捧的新人，将会参演不同的电影。2016年，开始首次接拍电视剧和电影的苏伟泉，已经可以参与几部大制作包括《狂兽》、《今晚打丧尸》及剧集《三一如三》等。","name":"苏伟泉","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Kumer So Wai-Chuen (Chinese: 蘇偉泉) is a Hong Kong actor and a former professional football player.","name":"Kumer So","primary":false}}]}},"movie_445040_keywords":{"at":1773297823344,"data":{"id":445040,"keywords":[{"id":6270,"name":"high school"},{"id":1228,"name":"1970s"},{"id":5565,"name":"biography"},{"id":9672,"name":"based on true story"},{"id":2494,"name":"ohio"},{"id":9740,"name":"sociopath"},{"id":9826,"name":"murder"},{"id":10180,"name":"male homosexuality"},{"id":10714,"name":"serial killer"},{"id":15160,"name":"divorce"},{"id":171556,"name":"social outcast"}]}},"tv_88324_credits":{"at":1773319436890,"data":{"cast":[{"adult":false,"gender":1,"id":58369,"known_for_department":"Acting","name":"Alexandra Breckenridge","original_name":"Alexandra Breckenridge","popularity":2.8693,"profile_path":"/tyR52cqImLCFwT8otR