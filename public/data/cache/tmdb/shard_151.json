id":198002,"results":[{"name":"3d animation","id":278823},{"name":"web series","id":281372},{"name":"donghua","id":315535},{"name":"based on web novel","id":318933}]}},"person_2227790_translations":{"at":1773688735861,"data":{"id":2227790,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Liu Lin","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"　　刘琳，1974年4月13日出生于北京，毕业于北京电影学院表演系，中国内地女演员。1993年刘琳出演的首部电影《高楼边》上映。1994年在校期间主演电影《夜半歌声》。2000年刘琳凭借主演的剧情电影《过年回家》获得第13届新加坡国际电影节最佳女主角奖。2004年主演苦情剧《香樟树》饰陶妮。2007年领衔主演抗日间谍剧《五号特工组》。2009年8月因在电影《沂蒙六姐妹》中饰演王坪，被授予沂蒙荣誉市民称号。2011年再次与原班人马打造的电视剧《五号特工组2》。2012年主演情感剧《父母爱情》。2015年主演电视剧《金水桥边》及《亲娘木兰》。2017年参演电视剧《琅琊榜之风起长林》。","name":"刘琳","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"劉琳","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Lưu Lâm","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Лю Линь","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"劉琳，1974 年 4 月 13 日出生於北京，畢業於北京電影學院表演系，中國內地女演員。1993 年劉琳出演的首部電影《高樓邊》上映。1994 年在校期間主演電影《夜半歌聲》。2000 年劉琳憑藉主演的劇情電影《過年回家》獲得第 13 屆新加坡國際電影節最佳女主角獎。2004 年主演苦情劇《香樟樹》飾陶妮。2007 年領銜主演抗日間諜劇《五號特工組》。2009 年 8 月因在電影《沂蒙六姐妹》中飾演王坪，被授豫沂蒙榮譽市民稱號。2011 年再次與原班人馬打造的電視劇《五號特工組 2》。2012 年主演情感劇《父母愛情》。2015 年主演電視劇《金水橋邊》及《親孃木蘭》。2017 年參演電視劇《琅琊榜之風起長林》。","name":"劉琳","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"Liu Lin","primary":false}}]}},"person_2842478_translations":{"at":1773688737341,"data":{"id":2842478,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Stacey A. Sheffield","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"史黛西·A·谢菲尔德","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"史黛西·A·謝菲爾德","primary":false}}]}},"person_3651176_translations":{"at":1773688738679,"data":{"id":3651176,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Kikunosuke Toya","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"戸谷菊之介","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"户谷菊之介","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Kikunosuke Toya, geboren am 30. November 1998 in Tokio, ist ein japanischer Synchronsprecher (Seiyū), der der Agentur Sony Music Artists angehört. Nach einer Schulzeit mit Theater- und Comedy-Erfahrung gewann er 2017 einen Sonderpreis bei der „Anistoteles“-Audition und debütierte 2018 in Spielen wie „Wind Boys!“, bevor er 2022 als Denji in der Anime-Adaption von „Chainsaw Man“ (inklusive Reze Arc-Film) seinen internationalen Durchbruch erzielte. Weitere Hauptrollen umfassen Akira Kiyose in „UniteUp!“, Donny in „Four Knights of the Apocalypse“, Mikoto Yuzuki in „The Yuzuki Family's Four Sons“, Fubuki in „The Elusive Samurai“, Three Kurosu in „Beyblade X“ sowie Stimmen in „Teenage Mutant Ninja Turtles: Mutant Mayhem“ und Projekten wie „The Irregular at Magic High School“.","name":"Kikunosuke Toya","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"토야 키쿠노스케","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Кикуносукэ Тоя","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Kikunosuke Toja","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"โทยะ คิคุโนะสุเกะ","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Kikunosuke Toya (戸谷 菊之介, Toya Kikunosuke, nacido el 30 de noviembre de 1998) es un actor de voz (seiyuu) japonés. Pertenece a Sony Music Artists. Originario de Tokio y Kanagawa, de los 2 a los 7 años, vivió en Tailandia debido al trabajo de sus padres.","name":"Kikunosuke Toya","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"戶谷菊之介是日本的男性聲優。所屬公司為 Sony Music Artists。","name":"戶谷菊之介","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"Kikunosuke Toya","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Kikunosuke Toya","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Кікуносуке Тоя","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"戶谷菊之介是日本的男性聲優。所屬公司為 Sony Music Artists。","name":"戶谷菊之介","primary":false}}]}}}}