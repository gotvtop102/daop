{"version":1,"entries":{"movie_10040_detail_vi-VN":{"at":1774727000340,"data":{"adult":false,"backdrop_path":"/2UYxVugjbaPHH5f3cEQveufe75Y.jpg","belongs_to_collection":{"id":93220,"name":"Miss Congeniality Collection","poster_path":"/wgQWsSsvB1iu1Pwc4nUP9E5bRzs.jpg","backdrop_path":"/7TIT28YbhAOeQGD2q2hJ9j83jI1.jpg"},"budget":0,"genres":[{"id":28,"name":"Phim Hành Động"},{"id":35,"name":"Phim Hài"}],"homepage":"","id":10040,"imdb_id":"tt0385307","origin_country":["US"],"original_language":"en","original_title":"Miss Congeniality 2: Armed and Fabulous","overview":"Nổi tiếng sau cuộc thi hoa hậu Mỹ, đặc vụ Gracie Hart trở thành gương mặt đại diện của FBI với biệt danh \"Hoa hậu FBI\", tuy nhiên cô phải tiếp tục hành động để cứu người bạn hoa hậu Cheryl & người dẫn chương trình Stan bị bắt cóc.","popularity":2.9966,"poster_path":"/gcYoIHND3ugn2VH1cNHHNQasEyI.jpg","production_companies":[{"id":79,"logo_path":"/at4uYdwAAgNRKhZuuFX8ShKSybw.png","name":"Village Roadshow Pictures","origin_country":"US"},{"id":97,"logo_path":"/smyTD67uNsdaySnnjVDmh0kyotp.png","name":"Castle Rock Entertainment","origin_country":"US"},{"id":4258,"logo_path":"/2AAcFwLxc1yble95qTSi6QfxKRa.png","name":"Fortis Films","origin_country":"US"}],"production_countries":[{"iso_3166_1":"US","name":"United States of America"}],"release_date":"2005-03-11","revenue":101393569,"runtime":115,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"","title":"Hoa Hậu FBI 2","video":false,"vote_average":5.7,"vote_count":1952}},"person_1118834_translations":{"at":1774727014390,"data":{"id":1118834,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Nichkhun (닉쿤), born Nichkhun Buck Horvejkul (นิชคุณ หรเวชกุล), is a Thai singer famous as a member of South Korean boyband 2PM.","name":"Nichkhun Horvejkul","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"닉쿤","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Никкун Бак Хорведжкул","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"尼查坤·抔勒威查固","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"尼查坤·抔勒威查固","primary":false}},{"iso_3166_1":"MX","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Nichkhun","primary":false}}]}},"person_1731802_translations":{"at":1774727017035,"data":{"id":1731802,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Cao Jun","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"曹骏，1988年2月9日出生于中国上海市，毕业于上海视觉艺术学院，中国内地男演员。\n\n1996年，出演个人首部电视剧《真命小和尚》，从而正式进入演艺圈。1997年，获得“第二届亚洲电视节”最佳新人奖。1998年，推出首张个人音乐专辑《星愿》。1999年，在古装神话剧《莲花童子哪吒》中饰演男主角哪咤。2000年，主演古装武侠剧《侠女闯天关》。2001年，主演古装轻喜剧《九岁县太爷》。\n\n2005年10月，在古装神话剧《宝莲灯》中饰演男主角沉香；同年，主演古装贺岁剧《鸡祥如意》。2007年，出演古装神话剧《宝莲灯前传》。2013年，在魔幻喜剧《魔幻手机2傻妞归来》中饰演陆冬雨。2018年10月，参加浙江卫视演技竞演类励志综艺《我就是演员》。2020年9月，入选“星辰大海青年演员优选计划”候选人。2021年，主演当代农村剧《在希望的田野上》。","name":"曹骏","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Cao Jun","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"曹駿，1988 年 2 月 9 日出生於中國上海市，畢業於上海視覺藝術學院，中國內地男演員。\n\n1996 年，出演個人首部電視劇《真命小和尚》，從而正式進入演藝圈。1997 年，獲得“第二屆亞洲電視節”最佳新人獎。1998 年，推出首張個人音樂專輯《星願奇緣》。1999 年，在古裝神話劇《蓮花童子哪吒》中飾演男主角哪吒。2000 年，主演古裝武俠劇《俠女闖天關》。2001 年，主演古裝輕喜劇《九歲縣太爺》。\n\n2005 年 10 月，在古裝神話劇《寶蓮燈》中飾演男主角沉香；同年，主演古裝賀歲劇《雞祥如意》。2007 年，出演古裝神話劇《寶蓮燈前傳》。2013 年，在魔幻喜劇《魔幻手機 2 傻妞歸來》中飾演陸冬雨。2018 年 10 月，參加浙江衞視演技競演類勵志綜藝《我就是演員》。2020 年 9 月，入選“星辰大海青年演員優選計劃”候選人。2021 年，主演當代農村劇《在希望的田野上》。","name":"曹駿","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Tào Tuấn","primary":false}}]}},"person_1238646_translations":{"at":1774727020732,"data":{"id":1238646,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Choi Bool-am (최불암) is a South Korean actor.","name":"Choi Bool-am","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"崔佛岩","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"최불암","primary":true}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"崔佛巖","primary":false}}]}},"person_1924824_translations":{"at":1774727023207,"data":{"id":1924824,"translations":[{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"Сергей Марин родился в селе Дубровки, Пензенская область, РСФСР, СССР. После окончания школы поступил в Пензенское училище культуры и искусств, где проучился два года. В 2010 году окончил актёрский факультет ВГИК (мастерская И. Ясуловича).","name":"Сергей Марин","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Sergey Marin","primary":false}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"Sergej Marin","primary":false}}]}}}}