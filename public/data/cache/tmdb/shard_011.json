{"version":1,"entries":{"person_3289926_translations":{"at":1774698736849,"data":{"id":3289926,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Prom Theepakorn Kwanboon is an actor under GMMTV. He studied at Saint Gabriel's College.\n\nHe's the owner of the clothing brand Réussi.","name":"Theepakorn Kwanboon","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"ทีปกร ขวัญบุญ","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"提帕功·宽本（Prom），2003年12月7日出生，泰国GMM TV旗下男演员。","name":"提帕功·宽本","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"提帕功·寬本（Prom），2003 年 12 月 7 日出生，泰國 GMM TV 旗下男演員。","name":"提帕功·寬本","primary":false}}]}},"person_1172006_translations":{"at":1774698737334,"data":{"id":1172006,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"　　梁天，喜剧演员、导演、制片人。父亲范荣康是《人民日报》的副主编；母亲谌容是女作家。著名女作家，曾经以《人到中年》名扬海内外。\n\n　　1976年参军，在北京军区装甲兵坦克6师第21团1营3连任炮长，1979年任6师文艺宣传队、守备3师文艺宣传队队员 。1980年转业进入工厂工会负责文体节目。一个偶然的机会被发现他有演戏才能，此后喜剧才能得以发挥。拍摄了《二子开店》、《喜剧明星》、《天生胆小》、《顽主》、《龙年警官》、《烈火金刚》、《男妇女主任》、《过年》、《斗鸡》等一系列电影。\n\n　　他的表演生动幽默，尤其是那双滑稽的小眼睛，让人过目不忘，梁天成为那个时代最为著名的笑星之一。","name":"梁天","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Liang Tian","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Liang Tian","primary":true}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Лян Тянь","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"梁天，喜劇演員、導演、製片人。父親範榮康是《人民日報》的副主編；母親諶容是女作家。著名女作家，曾經以《人到中年》名揚海內外。\n\n1976 年參軍，在北京軍區裝甲兵坦克 6 師第 21 團 1 營 3 聯任炮長，1979 年任 6 師文藝宣傳隊、守備 3 師文藝宣傳隊隊員 。1980 年轉業進入工廠工會負責文體節目。一個偶然的機會被發現他有演戲才能，此後喜劇才能得以發揮。拍攝了《二子開店》、《喜劇明星》、《天生膽小》、《頑主》、《龍年警官》、《烈火金剛》、《男婦女主任》、《過年》、《鬥雞》等一系列電影。\n\n他的表演生動幽默，尤其是那雙滑稽的小眼睛，讓人過目不忘，梁天成為那個時代最為著名的笑星之一。","name":"梁天","primary":false}}]}},"person_2388828_translations":{"at":1774698739660,"data":{"id":2388828,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Sky Yang","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Скай Янг","primary":false}}]}},"movie_44837_credits":{"at":1774698742877,"data":{"id":44837,"cast":[{"adult":false,"gender":2,"id":66761,"known_for_department":"Acting","name":"Leon Lai Ming","original_name":"黎明","popularity":2.7721,"profile_path":"/muGAHc7aIQZQ5HwldoJElqz4dZx.jpg","cast_id":5,"character":"Mei Lanfang","credit_id":"52fe469ec3a36847f8108e47","order":0},{"adult":false,"gender":1,"id":1339,"known_for_department":"Acting","name":"Zhang Ziyi","original_name":"章子怡","popularity":3.8956,"profile_path":"/6DUCAJzpw06VoAA9VWrvB2g4dpq.jpg","cast_id":6,"character":"Meng Xiaodong","credit_id":"52fe469ec3a36847f8108e4b","order":1},{"adult":false,"gender":2,"id":73774,"known_for_department":"Acting","name":"Sun Honglei","original_name":"孙红雷","popularity":2.0941,"profile_path":"/c2gBBUSd7JIfs20W76IutS4o3j4.jpg","cast_id":7,"character":"Qiu Rubai","credit_id":"52fe469ec3a36847f8108e4f","order":2},{"adult":false,"gender":1,"id":20655,"known_for_department":"Acting","name":"Chen Hong","original_name":"陈红","popularity":2.1648,"profile_path":"/2xJBhVDqvBGJr7HMRcbSpXGYgIf.jpg","cast_id":8,"character":"Fu Zhifang","credit_id":"52fe469ec3a36847f8108e53","ord