partment":"Production","name":"Chris Keiper","original_name":"Chris Keiper","popularity":0.0416,"profile_path":null,"credit_id":"673fcb91dae2e6a938254d5c","department":"Production","job":"Executive Producer"},{"adult":false,"gender":0,"id":5073815,"known_for_department":"Production","name":"Joshua Kulic","original_name":"Joshua Kulic","popularity":0.0261,"profile_path":null,"credit_id":"673fcb9a5cac041cfae26a5c","department":"Production","job":"Executive Producer"},{"adult":false,"gender":2,"id":4886515,"known_for_department":"Production","name":"Tyler Conklin","original_name":"Tyler Conklin","popularity":0.0981,"profile_path":"/5oJYdFrzyvpSTzpEQQwk0aS5Gp6.jpg","credit_id":"679601e19a30a85b2723afb0","department":"Directing","job":"Series Director"}],"id":249522}},"person_2537_translations":{"at":1772691615077,"data":{"id":2537,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Sonny Chiba (born January 23, 1939 - August 19, 2021), also known as Shin'ichi Chiba, was a Japanese actor and martial artist. Chiba was one of the first actors to achieve stardom through his skills in martial arts, initially in Japan and later before an international audience.  Born in Fukuoka, Chiba played a variety of sports in high school, including baseball and volleyball. He also practiced gymnastics and participated at the National Sports Festival of Japan in his third year. When he was a university student, he learned martial arts, earning a black belt in Kyokushin Karate in 1965 and later receiving a fourth degree in 1984.\n\nChiba's career began in the 1960s, when he starred in two tokusatsu superhero shows. In his first role, he replaced Susumu Wajima as the main character Kōtarō Ran/Seven Color Mask in Seven Color Mask (Nana-iro Kamen) in the second half of the series. However, his breakthrough role was in the 1974 film The Street Fighter. Before retiring, Chiba had also appeared in a number of English language American films, including Kill Bill: Volume 1 (2003) and Fast & Furious 3: Tokyo Drift (2006).\n\nChiba died of COVID-19 complications at the hospital in Tokyo on 19 August 2021, at the age of 82.\n\nDescription above from the Wikipedia article Sonny Chiba, licensed under CC-BY-SA, full list of contributors on Wikipedia.","name":"Sonny Chiba","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"千葉真一","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"千叶真一（1939年1月23日—2021年08月19日），生于日本福冈。国际空手道连盟极真会馆黑带，会馆早期学员。父亲是一名军事测试飞行员。他年轻的时候热衷体操，以他的天赋足以参加奥运会的比赛，但由于伤病退出。大学期间他对空手道产生了浓厚的兴趣，并在大山倍达的指导下，很快拿到了第一条黑带。千叶真一在六十年代拍动作片成名，电影代表作就有《争霸》，《里见八壮士》，《杀死比尔》。最为人熟悉的是《风云之雄霸天下》，他更凭“雄霸”一角获香港金像奖最佳男主角提名。他与野际阳子于1972年结婚，1994年离婚。","name":"千叶真一","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Сонни Чиба","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"소니 치바","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Shinichi Chiba (eigentlich Sadaho Maeda, bekannt auch als Sonny Chiba) war ein japanischer Schauspieler, der durch Karatefilme wie The Streetfighter und die Kage-no-Gundan-Serie bekannt wurde.\n\nChiba studierte ab 1957 Martial Arts an der Nippon Sport Science University. Zu seinen Lehrern gehörte Ōyama Masutatsu, bei dem er 1965 seinen ersten Schwarzen Gürtel in Karate erhielt und den er in den 1970er Jahren in einer Filmtrilogie verkörperte. Sein Fernseh- und Filmkarriere begann Chiba im Jahr 1960. Mehrfach drehte er mit Regisseur Kinji Fukasaku. Er wirkte in über 200 Film- und Fernsehproduktionen mit, wovon nur ein kleiner Bruchteil in Deutschland ausgewertet wurde. Im Jahr 1993 würdigte Drehbuchautor Quentin Tarantino ihn mit einer Hommage in True Romance, wodurch er auch im Westen einen größeren Bekanntheitsgrad erlangte.\n\nChiba erwarb auch Schwarze Gürtel in anderen Kampfsportarten wie Ninjutsu. Sein letzter Film, Bond of Justice: Kizuna, wird postum veröffentlicht werden. 1990 gab Chiba mit Der Schrecken der Berge sein Regiedebüt.\n\nEr starb im August 2021 im Alter von 82 Jahren an den Folgen einer COVID-19-Erkrankung im Kimitsu-Krankenhaus in Kisarazu.","name":"Sonny Chiba","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Sonny Čiba","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"Sonny Chiba","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"Sonny Chiba","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Sonny Chiba","primary":false}},{"iso_3166_1":"ES","iso_639_1":"ca","name":"Català","english_name":"Catalan","data":{"biography":"Shinichi Chiba (Fukuoka, Japó, 23 de juliol de 1939 - Kimitsu, Japó, 19 d'agost de 2021), més conegut com a Sonny Chiba, fou un actor japonès. Chiba va ser un dels primers actors del cinema d'arts marcials a assolir fama, primer al Japó i més tard internacionalment.","name":"Sonny Chiba","primary":false}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"Sonny Chiba","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Сонні Чіба","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"千葉真一（1939 年 1 月 23 日 — 2021 年 08 月 19 日），生於日本福岡。國際空手道聯盟極真會館黑帶，會館早期學員。父親是一名軍事測試飛行員。他年輕的時候熱衷體操，以他的天賦足以參加奧運會的比賽，但由於傷病退出。大學期間他對空手道產生了濃厚的興趣，並在大山倍達的指導下，很快拿到了第一條黑帶。千葉真一在六十年代拍動作片成名，電影代表作就有《爭霸》，《里見八壯士》，《標殺令》。最為人熟悉的是《風雲之雄霸天下》，他更憑“雄霸”一角獲香港金像獎最佳男主角提名。他與野際陽子於 1972 年結婚，1994 年離婚。","name":"千葉真一","primary":false}}]}},"movie_1180417_detail_vi-VN":{"at":1772691620727,"data":{"adult":false,"backdrop_path":"/bUktSJyiZIs4qPpMopjz2NMY0s9.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":18,"name":"Phim Chính Kịch"},{"id":53,"name":"Phim Gây Cấn"}],"homepage":"","id":1180417,"imdb_id":"tt29214162","origin_country":["US"],"original_language":"en","original_title":"The Dutchman","overview":"Một doanh nhân da đen thành đạt, bị ám ảnh bởi cuộc hôn nhân đang rạn nứt và cuộc khủng hoảng bản sắc cá nhân, bị cuốn vào một trò chơi tâm lý mèo vờn chuột với một người phụ nữ da trắng bí ẩn mà anh gặp trên tàu điện ngầm New York.","popularity":4.0964,"poster_path":"/v7CCosgX9LcSpt7bXmqw5OzTFTV.jpg","production_companies":[{"id":149312,"logo_path":null,"name":"Cinemation Studios","origin_country":"US"},{"id":14862,"logo_path":"/2YobmEkVFAcw368uz6Ie1sGP2C8.png","name":"Washington Square Films","origin_country":"US"},{"id":119226,"logo_path":"/owO85kQ0pQXzk9SPd3NxtMeKldl.png","name":"Federal Films","origin_country":"US"},{"id":164544,"logo_path":null,"name":"Lux Angeles Studios","origin_country":""},{"id":134,"logo_path":"/2uKAP9aAAhVMpfSqa4wtlIHod5g.png","name":"Rogue Pictures","origin_country":"US"}],"production_countries":[{"iso_3166_1":"US","name":"United States of America"}],"release_date":"2026-01-02","revenue":0,"runtime":95,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"","title":"Con Gà và Nắm Thóc","video":false,"vote_average":4.561,"vote_count":33}},"tv_312541_credits":{"at":1772691621285,"data":{"cast":[{"adult":false,"gender":2,"id":1590281,"known_for_department":"Acting","name":"Huang Youming","original_name":"Huang Youming","popularity":0.6936,"profile_path":"/q5Ey7SvC49GEI3s5uY13PYiwUhm.jpg","character":"Zhang Yi","credit_id":"69798cf4b602424b1bcdba51","order":0},{"adult":false,"gender":1,"id":4430775,"known