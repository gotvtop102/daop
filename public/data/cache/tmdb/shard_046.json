{"version":1,"entries":{"person_2084084_translations":{"at":1774698738875,"data":{"id":2084084,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Wang Ming","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"王铭，2009年搭档王千源、许还幻出演了个人首部电视剧《地道战》，从而正式进入演艺圈，2010年出演个人首部电影《在一起》。2011年搭档刘涛、保剑锋主演剿匪电视剧《智取华山传奇》，2012年出演公路电影《觉》饰演男主韩义城，同年7月搭档曹颖、姚刚主演古装爱情电视剧《天仙配后传》。2016年搭档彭冠英、刘芸主演都市感情剧《小棉袄》饰演擎天柱，同年12月出演公益电影《援爱》饰演男主郝刚。2019年搭档王小利主演喜剧电影《一路不消停》，同年5月出演年代传奇励志电视剧《塞上风云记》。2020年搭档修睿、王智主演喜剧电影《八方来援》，同年7月搭档秦海璐、金瀚出演涉案缉毒电视剧《雷霆令》。","name":"王铭","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Wang Ming","primary":true}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"王銘，2009 年搭檔王千源、許還幻出演了個人首部電視劇《地道戰》，從而正式進入演藝圈，2010 年出演個人首部電影《在一起》。2011 年搭檔劉濤、保劍鋒主演剿匪電視劇《智取華山傳奇》，2012 年出演公路電影《覺》飾演男主韓義城，同年 7 月搭檔曹穎、姚剛主演古裝愛情電視劇《天仙配後傳》。2016 年搭檔彭冠英、劉藝主演都市感情劇《小棉襖》飾演柯博文，同年 12 月出演公益電影《援愛》飾演男主郝剛。2019 年搭檔王小利主演喜劇電影《一路不消停》，同年 5 月出演年代傳奇勵志電視劇《塞上風雲記》。2020 年搭檔修睿、王智主演喜劇電影《八方來援》，同年 7 月搭檔秦海璐、金瀚出演涉案緝毒電視劇《雷霆令》。","name":"王銘","primary":false}}]}},"person_3090347_translations":{"at":1774698748304,"data":{"id":3090347,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Zhang Shuyang","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"张姝阳","primary":true}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"張姝陽","primary":false}}]}},"person_4975319_translations":{"at":1774698749718,"data":{"id":4975319,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Muriel Halloint","primary":true}}]}},"movie_937101_detail_vi-VN":{"at":1