ns":[{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"Tomal Islam","primary":true}}]}},"person_2178031_translations":{"at":1774377109739,"data":{"id":2178031,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Liu Guanlin","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"刘冠麟，1981年12月19日出生于黑龙江，毕业于北京舞蹈学院音乐剧系。  2005年，参演电视剧《大汉天子3》，饰演季擒虎。 2008年3月，加盟了宁财神自编自导的12集古装剧《龙虎山客栈》。2011年1月，出演张纪中执导的古装动作戏《菊花醉》 。2013年，刘冠麟加盟了宁财神执导的古装职场轻喜剧《龙门镖局》 。2014年，与秦海璐、胡冰共同主演都市时尚情感作品《妈妈向前冲》  。同年参演电视剧《十月围城》。","name":"刘冠麟","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Liu Guanlin","primary":true}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"류관린","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Lưu Quán Lân","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"劉冠麟，1981 年 12 月 19 日出生於黑龍江，畢業於北京舞蹈學院音樂劇系。\n\n2005 年，參演電視劇《大漢天子 3》，飾演季擒虎。\n\n2008 年 3 月，加盟了寧財神自編自導的 12 集古裝劇《龍虎山客棧》。2011 年 1 月，出演張紀中執導的古裝動作戲《菊花醉》 。2013 年，劉冠麟加盟了寧財神執導的古裝職場輕喜劇《龍門鏢局》 。2014 年，與秦海璐、胡冰共同主演都市時尚情感作品《媽媽向前衝》 。同年參演電視劇《十月圍城》。","name":"劉冠麟","primary":false}}]}}}}