{"version":1,"entries":{"person_109512_translations":{"at":1773688718956,"data":{"id":109512,"translations":[{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"ist ein Irish kanadischen Film , Fernsehen und Bühne Schauspieler , am besten bekannt für seine Rolle als irische Einwanderer Mickey McGinnes auf der AMC - Fernsehserie , Hell on Wheels .  Er erschien 2015 im Film Dirty Weekend . Er hat auch eine komödiantische Rolle als gedankenloser, unglücklicher Ehemann namens \"Dual-Bag\" in einer Reihe von Fernsehwerbespots mit dem Titel \"The Doghouse\" für den Einzelhändler JC Penney gespielt.","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Phil Burke","primary":true}}]}},"movie_1505013_keywords":{"at":1773688719700,"data":{"id":1505013,"keywords":[{"id":246,"name":"dancing"},{"id":1691,"name":"dance"},{"id":740,"name":"aids"},{"id":409,"name":"africa"},{"id":6783,"name":"orphanage"},{"id":7404,"name":"uganda"},{"id":9766,"name":"hiv"},{"id":167696,"name":"healing"},{"id":250819,"name":"belonging"},{"id":262235,"name":"hiv/aids epidemic"},{"id":325120,"name":"orphans"}]}},"person_1624799_translations":{"at":1773688720226,"data":{"id":1624799,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Oleh Scherbyna","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Oleh Scherbyna","primary":true}}]}},"person_4247588_translations":{"at":1773688720945,"data":{"id":4247588,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Matthew Bamberg-Johnson","primary":true}}]}},"person_34986_translations":{"at":1773688720982,"data":{"id":34986,"translations":[{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"Ge