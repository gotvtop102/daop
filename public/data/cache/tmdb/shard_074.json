],"episode_run_time":[15],"first_air_date":"2021-04-21","genres":[{"id":16,"name":"Phim Hoạt Hình"},{"id":35,"name":"Phim Hài"}],"homepage":"https://www.bilibili.com/bangumi/media/md28223053/","id":121870,"in_production":true,"languages":["zh"],"last_air_date":"2023-04-19","last_episode_to_air":{"id":4227161,"name":"Episode 24","overview":"","vote_average":0,"vote_count":0,"air_date":"2023-04-19","episode_number":24,"episode_type":"finale","production_code":"","runtime":14,"season_number":2,"show_id":121870,"still_path":null},"name":"Lưỡng Bất Nghi","next_episode_to_air":null,"networks":[{"id":1605,"logo_path":"/mtmMg3PD4YGfrlmqpEiO6NL2ch9.png","name":"bilibili","origin_country":"CN"}],"number_of_episodes":48,"number_of_seasons":2,"origin_country":["CN"],"original_language":"zh","original_name":"两不疑","overview":"Lưỡng Bất Nghi kể về hoàng hậu xuất thân nhà quan võ, không giỏi cầm kỳ thi hoạ nhưng binh võ lại không thua ai. Nàng bước vào hoàng cung bị vua lạnh nhạt nhiều năm, chịu đủ loại uất ức. Nhưng đến một ngày, tai nạn nhỏ xảy ra, nàng phát hiện... Mình bị đổi thân thể với Hoàng thượng rồi!!! Sau khi đổi thân thể, hoàng hậu giúp hoàng thượng thượng triều, xuất binh đánh trận. Hoàng thượng giúp nàng quản lý hậu cung, mọi hiểu lầm dần được xoá bỏ. Đế hậu thân mật hơn xưa.","popularity":6.486,"poster_path":"/6yMkLloaRks6n8rROS82trCJtWK.jpg","production_companies":[{"id":165872,"logo_path":"/c4O4aaSYkJZS5nhufiveDturhnv.png","name":"Paper Plane Animation Studio","origin_country":"CN"},{"id":123270,"logo_path":"/4KxfGr13VXMr44og11hzpdwfQDQ.png","name":"bilibili","origin_country":"CN"},{"id":192566,"logo_path":"/4uEJwNYwJJF38kytkD1qmS4F4VN.png","name":"Manman Comics","origin_country":"CN"},{"id":192567,"logo_path":"/5N9GXoOWOhl6B3aaz5Uwx7XvrFu.png","name":"Lianshang Literature","origin_country":"CN"},{"id":192569,"logo_path":null,"name":"丹丹","origin_country":""},{"id":192568,"logo_path":null,"name":"CC","origin_country":""},{"id":192570,"logo_path":"/l7wZbtu8iT6q4bky6Q