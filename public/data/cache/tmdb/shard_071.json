e":"Mandarin","data":{"biography":"","name":"Zhang Sha Sha","primary":true}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"장사사","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"张沙沙","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"張沙沙","primary":false}}]}},"tv_88046_keywords":{"at":1774727156400,"data":{"id":88046,"results":[{"name":"secret organization","id":3271},{"name":"post-apocalyptic future","id":4458},{"name":"supernatural","id":6152},{"name":"based on comic","id":9717},{"name":"conspiracy","id":10410},{"name":"terrorism","id":13015},{"name":"super power","id":33637},{"name":"firefighter","id":192094},{"name":"shounen","id":207826},{"name":"anime","id":210024},{"name":"corrupt church","id":236595},{"name":"fantasy","id":293198},{"name":"adoring","id":325762}]}},"person_1645397_translations":{"at":1774727157270,"data":{"id":1645397,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Makoto Koichi (小市 眞琴, Koichi Makoto, February 17) is a Japanese stage actress, voice actress, and choreographer from Tokyo. She is currently affiliated with tomorrow jam, and previously with Atomic Monkey (April 2014–April 1, 2021) and Stay Luck (April 1, 2021–December 1, 2024). She is sometimes miscredited as 小市 真琴.","name":"Makoto Koichi","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Makoto Koichi (小市 眞琴, Koichi Makoto, 17 de febrero) es una actriz de teatro, actriz de voz y coreógrafa japonesa de Tokio. Actualmente está afiliada a tomorrow jam y anteriormente lo estuvo a Atomic Monkey (de abril de 2014 al 1 de abril de 2021) y Stay Luck (del 1 de abril de 2021 al 1 de diciembre de 2024). A veces se le acredita erróneamente como 小市 真琴.","name":"Makoto Koichi","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"小市眞琴","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"小市真琴是日本的女性聲優、舞台劇女演員。出身於東京都，所屬公司為 tomorrow jam。","name":"小市真琴","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"코이치 마코토","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Makoto Koichi","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"小市真琴（日语：小市 眞琴／こいち まこと Koichi Makoto，2月17日—）是日本的女性声优、舞台演员、编舞家，东京都出身。隶属于Stay Luck。\n\n高中时就读演剧科，并开始以演戏为目标。成为声优前主要是在A-Light（A-Theater）旗下从事舞台演员的工作。2010年11月开始使用目前的艺名。演出舞台剧《幸运☆星≒音乐☆舞台》时，曾观赏动画版的《幸运☆星》作为研究，并因此对声优界产生兴趣。\n\n喜欢小孩子，曾想要成为保姆，但由于不擅长读书而放弃。","name":"小市真琴","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"มาโกโตะ โคอิจิ","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Makoto Koiči","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Makoto Koichi","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Макото Коїчі","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"小市真琴是日本的女性聲優、舞台劇女演員。出身於東京都，所屬公司為 tomorrow jam。","name":"小市真琴","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Макото Коити","primary":false}}]}},"person_3091125_translations":{"at":1774727165433,"data":{"id":3091125,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"　　邱秋，出生于安徽省，中国内地配音女演员，毕业于北京电影学院表演系 。2006年，配音个人首部作品《少年包青天3》，从而正式开启了她的配音生涯。2007年，在古装武侠剧《碧血剑》中为温青青配音。2010年，在爱情剧《佳期如梦》中，为女主角尤佳期配音。2015年，在古装传奇剧《琅琊榜》中为刘涛饰演的穆霓凰配音从而获得关注 。2016年，在都市爱情剧《爱的阶梯》中为宋子涵配音。2017年2月，在都市情感剧《云巅之上》中为安心配音 。2018年，在古装宫廷剧《延禧攻略》中，为吴谨言饰演的魏璎珞配音。","name":"邱秋","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Qiu Qiu, a well-known voice director and voice actor in China, graduated from the Performance Department of Beijing Film Academy. In 2006, she officially started her dubbing career.","name":"Qiu Qiu","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Qiu Qiu","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Цю Цю","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"邱秋，出生於安徽省，中國內地配音女演員，畢業於北京電影學院表演系 。2006 年，配音個人首部作品《少年包青天 3》，從而正式開啟了她的配音生涯。2007 年，在古裝武俠劇《碧血劍》中為温青青配音。2010 年，在愛情劇《佳期如夢》中，為女主角尤佳期配音。2015 年，在古裝傳奇劇《琅琊榜》中為劉濤飾演的穆霓凰配音從而獲得關注 。2016 年，在都市愛情劇《愛的階梯》中為宋子涵配音。2017 年 2 月，在都市情感劇《雲巔之上》中為安心配音 。2018 年，在古裝宮廷劇《延禧攻略》中，為吳謹言飾演的魏瓔珞配音。","name":"邱秋","primary":false}}]}}}}