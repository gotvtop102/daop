{"version":1,"entries":{"person_3372608_translations":{"at":1774698737770,"data":{"id":3372608,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"　　金贤正，原名金天，1994年4月5日出生于内蒙古，中国内地影视演员，毕业于北京电影学院。2017年，出演田键执导，王昭、王婷主演的网剧《谁寄锦书来》饰演刘晓亮。2020年，出演由解航执导，秦俊杰、邓家佳主演的悬疑刑侦剧《通天塔》 饰演刺猬，同年主演了电影《绿纸条儿》在片中饰演向建国一角。2021年主演了由丁伟执导的青春励志网剧《悄悄喜欢你》在剧中饰演莫铖。2021年3月出演了由梁佳豪执导的青春题材创业剧《加油吧！程序员》在剧中饰演汤晨晨。2021年5月拍摄了《我凭本事进冷宫》饰演秦御。","name":"金贤正","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Jin Xianzheng","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Xianzheng Jin","primary":true}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"金賢正，原名金天，1994 年 4 月 5 日出生於內蒙古，中國內地影視演員，畢業於北京電影學院。2017 年，出演田鍵執導，王昭、王婷主演的網劇《誰寄錦書來》飾演劉曉亮。2020 年，出演由解航執導，秦俊傑、鄧家佳主演的懸疑刑偵劇《巴別塔》 飾演刺蝟，同年主演了電影《綠紙條兒》在片中飾演向建國一角。2021 年主演了由丁偉執導的青春勵志網劇《悄悄喜歡你》在劇中飾演莫鋮。2021 年 3 月出演了由梁佳豪執導的青春題材創業劇《加油吧！程序員》在劇中飾演湯晨晨。2021 年 5 月拍攝了《我憑本事進冷宮》飾演秦禦。","name":"金賢正","primary":false}}]}},"person_158904_translations":{"at":1774698753528,"data":{"id":158904,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Clare Torao is known for Cujo (1983), 48 Hrs. (1982) and Cobra (1986).","name":"Clare Torao","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}}]}},"tv_223911_detail_vi-VN":{"at":1774718566408,"data":{"adult":false,"backdrop_path":"/9R3tyMeAEvY53Da6fVguBEVlfxE.jpg","created_by":[{"id":2799581,"credit_id":"653634cb8cfcc700e96b03e7","name":"耳根","original_name":"耳根","gender":2,"profile_path":"/i8MBUagwfWjG38D1Zr61YCw3lLp.jpg"}],"episode_run_time":[21],"first_air_date":"2023-09-25","genres":[{"id":10759,"name":"Action & Adventure"},{"id":16,"name":"Phim Hoạt Hình