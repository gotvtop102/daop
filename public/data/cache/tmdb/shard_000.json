t cách mạnh mẽ. Khi một loạt vụ giết người liên quan đến ma cà rồng xảy ra, quá khứ đen tối và mối liên hệ thực sự của bảy chàng trai dần lộ diện. Bị cuốn vào mối thù truyền kiếp giữa ma cà rồng và người sói, Sooha phải đối mặt với sự thật rằng cô đang ở rất gần những sinh vật mà mình từng căm ghét nhất.","popularity":14.5618,"poster_path":"/mdhRgxbdW2ByAhMJLHckkd024H0.jpg","production_companies":[{"id":70163,"logo_path":"/cwUwQqO5SNrDJoC92XTOKg7c1Gc.png","name":"TROYCA","origin_country":"JP"},{"id":2883,"logo_path":"/rDYExnBV61jGQnkhVVrPN4Yl7O1.png","name":"Aniplex","origin_country":"JP"},{"id":285717,"logo_path":null,"name":"HYBE JAPAN","origin_country":"JP"},{"id":98553,"logo_path":"/qqyXcZlJQKlRmAD1TCKV7mGLQlt.png","name":"Crunchyroll","origin_country":"JP"},{"id":218052,"logo_path":"/ekDHmKkZgEawMh2tEffOzMXkaYM.png","name":"LINE Digital Frontier","origin_country":"JP"}],"production_countries":[{"iso_3166_1":"JP","name":"Japan"}],"seasons":[{"air_date":"2026-01-10","episode_count":12,"id":418785,"name":"Season 1","overview":"","poster_path":"/qgy4z9HsdotSpVUy44ZMUt7J9tL.jpg","season_number":1,"vote_average":7.8}],"spoken_languages":[{"english_name":"Japanese","iso_639_1":"ja","name":"日本語"}],"status":"Returning Series","tagline":"","type":"Scripted","vote_average":8.565,"vote_count":23}},"person_1268632_translations":{"at":1773124736267,"data":{"id":1268632,"translations":[{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"高橋努","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"高桥刚","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Tsutomu Takahashi","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"高橋努","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Cz