Er26H5yCSVQoKTeBdvUvg.jpg","season_number":1,"vote_average":7.3}],"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Ended","tagline":"Bạn đồng hành bất đắc dĩ mà...","type":"Miniseries","vote_average":6.8,"vote_count":178}},"person_4265155_translations":{"at":1773688716834,"data":{"id":4265155,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Yazeed Almajyul","primary":false}},{"iso_3166_1":"AE","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"","name":"Yazeed Almajyul","primary":true}}]}},"person_111584_translations":{"at":1773688724873,"data":{"id":111584,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Paul Lees","primary":true}}]}},"person_2280277_translations":{"at":1773688727322,"data":{"id":2280277,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Nie Zihao","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"聂子皓，1993年8月13日出生于四川省泸州市，中国内地男演员，毕业于北京电影学院。\n\n2015年9月，参演个人首部影视作品，在青春校园题材网络剧《最好的我们》中饰演具有“完美型人格“的盛淮南。2016年，参演由中汇影视、爱奇艺联合出品，马可，付辛博，周雨彤主演的玄幻网络剧《寻找前世之旅》，饰演“撩妹圣手”飞鸟 [3-5]；8月，参演的个人首部电影《那件疯狂的小事叫爱情》上映；11月，与吴奇隆、陈哲远共同出演，由江苏稻草熊影业有限公司出品的古装神话武侠剧《蜀山战纪2踏火行歌》，饰演白谷逸。2017年，与佟梦实、邢菲合作，出演由成志超执导的青春校园剧《热血狂篮》，饰演海明风。\n\n2018年，与鞠婧祎、于朦胧联袂主演经典古装神话剧《新白娘子传奇》，饰演锦毛鼠“景松”；7月，参与拍摄张震、倪妮主演的古装仙侠剧《宸汐缘》，饰演开阳。2019年4月，与范丞丞、程潇共同出演，由梁国冠、马华干执导的神话新武侠剧《灵域》，饰演杜少扬；8月，与邢昭林、肖燕合作，拍摄古装爱情轻喜剧《三嫁惹君心》，饰演云青贤。2020年1月，参与由天毅执导，黄景瑜、李沁领衔主演的现代军旅剧《亲爱的戎装》，饰演卓然；10月，由李阳执导，卜冠今、王星越领衔主演古装奇幻爱情轻喜剧《公子倾城》，饰演姬定岳。","name":"聂子皓","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Nie Zihao","primary":true}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"聶子皓，1993 年 8 月 13 日出生於四川省瀘州市，中國內地男演員，畢業於北京電影學院。\n\n2015 年 9 月，參演個人首部影視作品，在青春校園題材網絡劇《最好的我們》中飾演具有“完美型人格“的盛淮南。2016 年，參演由中匯影視、愛奇藝聯合出品，馬可，付辛博，周雨彤主演的玄幻網絡劇《尋找前世之旅》，飾演“撩妹聖手”飛鳥 [3 - 5]；8 月，參演的個人首部電影《那件瘋狂的小事叫愛情》上映；11 月，與吳奇隆、陳哲遠共同出演，由江蘇稻草熊影業有限公司出品的古裝神話武俠劇《蜀山戰紀 2 踏火行歌》，飾演白谷逸。2017 年，與佟夢實、邢菲合作，出演由成志超執導的青春校園劇《熱血狂籃》，飾演海明風。\n\n2018 年，與鞠婧禕、於朦朧聯袂主演經典古裝神話劇《新白娘子傳奇》，飾演錦毛鼠“景松”；7 月，參與拍攝張震、倪妮主演的古裝仙俠劇《宸汐緣》，飾演開陽。2019 年 4 月，與範丞丞、程瀟共同出演，由梁國冠、馬華幹執導的神話新武俠劇《靈域》，飾演杜少揚；8 月，與邢昭林、肖燕合作，拍攝古裝愛情輕喜劇《三嫁惹君心》，飾演雲青賢。2020 年 1 月，參與由天毅執導，黃景瑜、李沁領銜主演的現代軍旅劇《親愛的戎裝》，飾演卓然；10 月，由李陽執導，卜冠今、王星越領銜主演古裝奇幻愛情輕喜劇《公子傾城》，飾演姬定嶽。","name":"聶子皓","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"섭자호(聂子皓)","primary":false}},{"iso_3166_1":"SA","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"ني زي هاو، المولود في 13 أغسطس 1993 في لوتشو بمقاطعة سيتشوان، ممثل صيني من البر الرئيسي الصيني، وخريج أكاديمية بكين للأفلام.\n\nفي سبتمبر 2015، قام ببطولة أول أعماله السينمائية والتلفزيونية، حيث جسّد شخصية شينغ هواينان، صاحب الشخصية المثالية، في الدراما الإلكترونية الشبابية *معك*. وفي عام 2016، قام ببطولة الدراما الإلكترونية الخيالية *البحث عن الحياة الماضية*، من إنتاج مشترك بين شركة تشونغ هوي للأفلام والتلفزيون ومنصة آي كيو آي، إلى جانب ما كه، فو شينبو، وتشو يوتونغ، حيث لعب دور فاي بياو، خبير المغازلة. [3-5] وفي أغسطس من العام نفسه، عُرض فيلمه الأول *ذلك الشيء الصغير المجنون المسمى الحب*. في نوفمبر، شارك في بطولة مسلسل فنون القتال الخيالي التاريخي \"أسطورة شوشان 2: النيران المشتعلة\" مع نيكي وو وتشن تشيوان، من إنتاج شركة جيانغسو سترو بير للأفلام والتلفزيون، حيث جسّد شخصية باي غويي. وفي عام 2017، شارك في بطولة مسلسل \"كرة السلة الحماسية\" مع تونغ مينغشي وشينغ فاي، من إخراج تشنغ تشيتشاو، حيث لعب دور هاي مينغفنغ. وفي عام 2018، شارك في بطولة مسلسل \"أسطورة الأفعى البيضاء\" مع جو جينغي ويو مينغلونغ، حيث لعب دور جينغ سونغ، \"الفأر ذو الشعر الأبيض\". وفي يوليو، شارك في تصوير مسلسل \"الحب والقدر\" مع تشانغ تشن وني ني، حيث لعب دور كايانغ. في أبريل 2019، شارك في بطولة الدراما الأسطورية الجديدة *عالم الأرواح*، من إخراج ليانغ غوغوان وما هواغان، إلى جانب فان تشنغ تشنغ وتشنغ شياو، حيث جسّد شخصية دو شاويانغ. وفي أغسطس، تعاون مع شينغ تشاولين وشياو يان في الكوميديا ​​الرومانسية التاريخية *ثلاث زيجات لإثارة قلب السيد*، مؤدياً دور يون تشينغشيان. وفي يناير 2020، شارك في الدراما العسكرية المعاصرة *زيّي العزيز*، من إخراج تيان يي وبطولة هوانغ جينغيو ولي تشين، مؤدياً دور تشو ران. وفي أكتوبر، لعب دور جي دينغيو في الكوميديا ​​الرومانسية التاريخية الخيالية *أمير تشينغ تشنغ*، من إخراج لي يانغ وبطولة بو غوانجين ووانغ شينغيو.","name":"ني زي هاو","primary":false}}]}},"movie_1415974_credits":{"at":1773688732443,"data":{"id":1415974,"cast":[{"adult":false,"gender":2,"id":85047,"known_for_department":"Acting","name":"Nawazuddin Siddiqui","original_name":"Nawazuddin Siddiqui","popularity":1.3852,"profile_path":"/w1eXF7T60QlEC2gNfr99J3n8CgX.jpg","cast_id":1,"character":"Inspector Jatil Yadav","credit_id":"678286fc0690ac06e77b2e4e","order":0},{"adult":false,"gender":1,"id":223167,"known_for_department":"Acting","name":"Radhika Apte","original_name":"Radhika Apte","popularity":1.1333,"profile_path":"/wKPybRcSYcbgDiJZwELudrRNf0r.jpg","cast_id":13,"character":"Radha","credit_id":"69086993bb0103f387081972","order":1},{"adult":false,"gender":1,"id":110850,"known_for_department":"Acting","name":"Chitrangada Singh","original_name":"चित्रांगदा सिंह","popularity":0.6157,"profile_path":"/r9ekq6jFvY8MOpaRSORwNIYPr0P.jpg","cast_id":2,"character":"Meera Bansal","credit_id":"6782870e3881c79419bba307","order":2},{"adult":false,"gender":2,"id":78922,"known_for_department":"Acting","name":"Rajat Kapoor","original_name":"Rajat Kapoor","popularity":0.7901,"profile_path":"/8IF24mMUSspmXHbxCMMbMaz3WRj.jpg","cast_id":6,"character":"DGP Sameer Verma","credit_id":"69086952636211a6074c89d9","order":3},{"adult":false,"gender":1,"id":584324,"known_