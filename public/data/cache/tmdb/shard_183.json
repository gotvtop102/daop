oken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"","title":"American Skin","video":false,"vote_average":7.092,"vote_count":98}},"person_5356439_translations":{"at":1773211331807,"data":{"id":5356439,"translations":[]}},"person_2335916_translations":{"at":1773297823860,"data":{"id":2335916,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Brady M.K. Dunn","primary":true}}]}},"person_5115690_translations":{"at":1773405757286,"data":{"id":5115690,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Iona Yabut","primary":true}}]}},"person_5663296_translations":{"at":1773405759439,"data":{"id":5663296,"translations":[{"iso_3166_1":"PT","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Kobus","primary":true}}]}},"person_5975179_translations":{"at":1773470200211,"data":{"id":5975179,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"童思琦","primary":true}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"童思琦","primary":false}}]}},"person_1686321_translations":{"at":1773491792868,"data":{"id":1686321,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Gao Weiguang","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"Gao Vengo est un acteur et mannequin chinois. Il a gagné en 2006 la troisième place du concours \"New Silk Road Model Look\", ce qui a lancé sa carrière dans le mannequinat.","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"　　身高191CM的高伟光天生就是当模特的料，以06年参加新丝路中国模特大赛并成为亚军而被人得知关注。之后陆续参加08年香港秋冬时装周、2009-2011北京春夏及秋冬时装周的演出，以及拍摄各种知名杂志如《瑞丽·男人风尚》、《芭莎男士》、《时尚先生》、《ellemen》等，拍摄的广告也不计少数，都称其为亚洲最具影响力模特候选人。13年又因参演杨幂担任制片的电视剧《微时代》而又受瞩目，希望养眼的外表能够我们带来不止养眼的演技。\n\n　　高伟光从小受到的是最正统的教育，像普通学生一样考试、升学，甚至没上过任何兴趣班，即使初中时身高已经超过了180，也依然没想过去做模特或演员。曾经有自己非常想考取的大学，但第一次高考失利，错过了入学的机会，因此也决定离开家乡自己去外面的世界闯荡。在成都生活的那段时间，第一次接触到了模特的世界，从卖电脑到初试婚纱模特、到包揽了几乎整个成都大街小巷婚纱店照片的御用模特，再到闯入北京获得新丝路模特大赛亚军，终于一步步在模特圈里闯出了名气。2008年，因为想给自己的人生更广阔的空间，所以再次走入高考考场，以第八名的成绩考入中戏，开始为一个演员的职业生涯。","name":"高伟光","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"Cao Vỹ Quang, tên tiếng Anh: Vengo Gao, là một nam diễn viên Trung Quốc. Anh được biết đến qua vai diễn nổi tiếng \"Đông Hoa Đế Quân\" trong hai phần phim Tam sinh tam thế thập lý đào hoa và Tam sinh tam thế chẩm thượng thư.","name":"Cao Vỹ Quang","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"高偉光","primary":true}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"고위광","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"身高 191CM 的高偉光天生就是當模特的料，以 06 年參加新絲路中國模特大賽併成為亞軍而被人得知關注。之後陸續參加 08 年香港秋冬時裝周、2009 - 2011 北京春夏及秋冬時裝周的演出，以及拍攝各種知名雜誌如《瑞麗·男人風尚》、《芭莎男士》、《時尚先生》、《ellemen》等，拍攝的廣告也不計少數，都稱其為亞洲最具影響力模特候選人。13 年又因參演楊冪擔任製片的電視劇《微時代》而又受矚目，希望養眼的外表能夠我們帶來不止養眼的演技。\n\n高偉光從小受到的是最正統的教育，像普通學生一樣考試、升學，甚至沒上過任何興趣班，即使初中時身高已經超過了 180，也依然沒想過去做模特或演員。曾經有自己非常想考取的大學，但第一次高考失利，錯過了入學的機會，因此也決定離開家鄉自己去外面的世界闖蕩。在成都生活的那段時間，第一次接觸到了模特的世界，從賣電腦到初試婚紗模特、到包攬了幾乎整個成都大街小巷婚紗店照片的禦用模特，再到闖入北京獲得新絲路模特大賽亞軍，終於一步步在模特圈裏闖出了名氣。2008 年，因為想給自己的人生更廣闊的空間，所以再次走入高考考場，以第八名的成績考入中戲，開始為一個演員的職業生涯。","name":"高偉光","primary":false}}]}},"person_1373070_translations":{"at":1773644859155,"data":{"id":1373070,"translations":[{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"市川知宏","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Ichikawa Tomohiro is a Japanese actor. He was born in Tokyo and is currently under Kenon. He is the Grand Prix winner of the 21st JUNON Super Boy Contest. He is a member of MEN ON STYLE. He made his debut in 2009 in the romance comedy drama named Otomen.","name":"Tomohiro Ichikawa","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"市川知宏","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"이치카와 토모히로","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Tomohiro Ičikawa","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Томохіро Ічікава","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"市川知宏","primary":false}}]}}}}