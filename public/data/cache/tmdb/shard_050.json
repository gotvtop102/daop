,{"id":155291,"name":"cowboy"},{"id":236252,"name":"ex spouses"},{"id":240303,"name":"father daughter relationship"},{"id":247882,"name":"resilience"},{"id":276959,"name":"wild fire"},{"id":287700,"name":"rancher"}]}},"tv_263219_detail_vi-VN":{"at":1772691624218,"data":{"adult":false,"backdrop_path":"/y1k8KhifyLJxZUK3ObviZiQREPJ.jpg","created_by":[{"id":2795077,"credit_id":"696435b62f6133a99f9344b0","name":"Tian Han","original_name":"Tian Han","gender":2,"profile_path":"/P5KZl5Dj9sqh93iUhJlFiUYbsj.jpg"}],"episode_run_time":[],"first_air_date":"2026-01-10","genres":[{"id":18,"name":"Phim Chính Kịch"}],"homepage":"https://v.youku.com/v_show/id_XNTk2MjY4NTY5Mg==.html","id":263219,"in_production":false,"languages":["zh"],"last_air_date":"2026-01-25","last_episode_to_air":{"id":6835688,"name":"Episode 28","overview":"","vote_average":8,"vote_count":1,"air_date":"2026-01-25","episode_number":28,"episode_type":"finale","production_code":"","runtime":null,"season_number":1,"show_id":263219,"still_path":"/sVrHqR9vg6fzY61kBI0ByzfVlfD.jpg"},"name":"Tuyết Thu Tràn Sang Đông","next_episode_to_air":null,"networks":[{"id":1419,"logo_path":"/w2TeR3fvPZ9a617tNIF1oOfyPtk.png","name":"Youku","origin_country":"CN"}],"number_of_episodes":28,"number_of_seasons":1,"origin_country":["CN"],"original_language":"zh","original_name":"秋雪漫过的冬天","overview":"Bộ phim là câu chuyện chữa lành về hai con người gặp khó khăn, cùng an ủi và sưởi ấm nhau giữa bùn lầy cuộc sống. Châu Ngộ An sinh ra trong nghèo khó và phải gánh nợ cho bố, gặp được Khương Gia Tề lúc anh đang vướng mắc cả về gia đình và sự nghiệp. Tình hình đấu đá ở công ty đã đẩy hai con người vốn không quan hệ gì lại gần nhau. Vì Khương Gia Tề quyết bảo vệ lẽ phải, khiến CEO Cố Thần mất đi cơ hội xin cấp phép thuốc mới, Cố Thần đã thuê Châu Ngộ An để tìm cách đuổi Khương Gia Tề đi. Bắt đầu từ hiểu lầm, Khương Gia Tề và Châu Ngộ An dần hiểu về nhau, Châu Ngộ An nhận ra khía cạnh ấm áp nhất của Khương Gia Tề, cuối cùng hai người cứu rỗi lẫn nhau, cùng nhau thoát khỏi cuộc sống tăm tối. Dù nam nữ chính đều chìm xuống đáy cuộc đời nhưng vẫn luôn đối mặt bằng thái độ tích cực, không gục ngã trước khó khăn, họ cùng dìu dắt nhau vượt qua bao trắc trở. Cả bộ phim kể lại câu chuyện hai người đi từ quen biết đến hiểu lầm, rồi thấu hiểu và cứu rỗi nhau một cách đầy ấm áp và chữa lành.","popularity":4.1361,"poster_path":"/2LjFKTDjYhQAW7ehLytH7V4Ucho.jpg","production_companies":[{"id":177167,"logo_path":null,"name":"优酷","origin_country":""}],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"seasons":[{"air_date":"2026-01-10","episode_count":28,"id":409037,"name":"Season 1","overview":"","poster_path":"/AbnwpsxQFerdqcjCdyL6epdUv3X.jpg","season_number":1,"vote_average":8}],"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Ended","tagline":"","type":"Scripted","vote_average":7.5,"vote_count":4}},"person_1450372_translations":{"at":1772691624486,"data":{"id":1450372,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"春夏，本名李俊杰，中国演员、模特。生于云南昆明，代表作《踏血寻梅》。出道前曾为多本杂志书籍拍摄封面，后进入影视圈。 出演《我心灿烂》《岁月如金》《大好时光》等电视剧。\n\n2015年11月主演短片《高芙镇》入围第12届CIFF中国独立影像展剧情短片竞赛单元。\n\n2016年4月3日，凭借电影《踏血寻梅》获得第35届香港电影金像奖最佳女主角奖；同年10月，主演电影《脱皮爸爸》入围第29届东京国际电影节主竞赛单元。\n\n2017年8月，主演电影《刀背藏身》入围第41届蒙特利尔国际电影节主竞赛单元。\n\n春夏曾说：“生活不止眼前的苟且”，当然不止，但我们要找一个抵御的方式，我平衡的方式是看电影演戏吃东西睡觉，也推荐给大家。","name":"春夏","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Jessie Li, known professionally as Chun Xia (春夏), is a Chinese actress born as Li Jun Jie (李俊杰). She is best known for starring in Port of Call, which earned her a Hong Kong Film Award for Best Actress.","name":"Jessie Li","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"春夏","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"춘하","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"春夏，本名李俊傑，中國演員、模特。生於雲南昆明，代表作《踏血尋梅》。出道前曾為多本雜誌書籍拍攝封面，後進入影視圈。\n\n出演《我心燦爛》《歲月如金》《大好時光》等電視劇。\n\n2015 年 11 月主演短片《高芙鎮》入圍第 12 屆 CIFF 中國獨立影像展劇情短片競賽單元。\n\n2016 年 4 月 3 日，憑藉電影《踏血尋梅》獲得第 35 屆香港電影金像獎最佳女主角獎；同年 10 月，主演電影《脱皮爸爸》入圍第 29 屆東京國際電影節主競賽單元。\n\n2017 年 8 月，主演電影《刀背藏身》入圍第 41 屆蒙特利爾國際電影節主競賽單元。\n\n春夏曾説：“生活不止眼前的苟且”，當然不止，但我們要找一個抵禦的方式，我平衡的方式是看電影演戲吃東西睡覺，也推薦給大家。","name":"春夏","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Чунь Ся","primary":false}}]}},"person_3624649_translations":{"at":1772691630578,"data":{"id":3624649,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Alessandro Cucca","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"Alessandro Cucca","primary":true}}]}},"tv_236565_detail_vi-VN":{"at":1772691633287,"data":{"adult":false,"backdrop_path":"/lkzrT7Vpnd2OZ2bpKXjWsb9KFc0.jpg","created_by":[],"episode_run_time":[],"first_air_date":"2025-10-01","genres":[{"id":16,"name":"Phim Hoạt Hình"},{"id":10759,"name":"Action & Adventure"},{"id":35,"name":"Phim Hài"},{"id":10765,"name":"Sci-Fi & Fantasy"}],"homepage":"https://mushoku-eiyu-anime.com","id":236565,"in_production":false,"languages":["ja"],"last_air_date":"2025-12-17","last_episode_to_air":{"id":6550064,"name":"Episode 12","overview":"","vote_average":8,"vote_count":1,"air_date":"2025-12-17","episode_number":12,"episode_type":"finale","production_code":"","runtime":24,"season_number":1,"show_id":236565,"still_path":"/6oqjC4SkaGH4dTAzOpGdavwF9xP.jpg"},"name":"Anh Hùng Vô Chức: Thực Ra Cũng Chẳng Cần Kỹ Năng Gì Cả?!","next_episode_to_air":null,"networks":[{"id":614,"logo_path":"/hSdroyVthq3CynxTIIY7lnS8w1.png","name":"Tokyo MX","origin_country":"JP"}],"number_of_episodes"