y":0.3398,"profile_path":"/r7zpq7zv4paCEX72XdBWS7aE7pj.jpg","character":"Gong Tianying (voice)","credit_id":"68d4dc2da3720c3d0ba2bc55","order":7}],"crew":[{"adult":false,"gender":2,"id":3111282,"known_for_department":"Production","name":"Gong Yu","original_name":"龚宇","popularity":1.0284,"profile_path":"/nEGJzzpTynsJpbxETWpSU1pHZaX.jpg","credit_id":"68d4d996369e6ee49259d34f","department":"Crew","job":"Presenter"},{"adult":false,"gender":2,"id":3302935,"known_for_department":"Production","name":"Wang Xiaohui","original_name":"王晓晖","popularity":0.7694,"profile_path":"/ahRvsQbsrPnZvJHwltIqRlg3h7M.jpg","credit_id":"68d4d9ad05dcd76bd25b1322","department":"Production","job":"Executive Producer"},{"adult":false,"gender":0,"id":2463701,"known_for_department":"Production","name":"Jin Wenjun","original_name":"金文君","popularity":0.1744,"profile_path":null,"credit_id":"68d4d9ce6072f5c7b5a2bc33","department":"Production","job":"Producer"}],"id":280952}},"person_1853547_translations":{"at":1774698735550,"data":{"id":1853547,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"图特哈蒙，本名冯盛，中国配音员，原为北斗企鹅工作室主要成员之一，现是藤韵文化成员。参与配音的作品有动画《一人之下》《龙心战纪》《神明之胄》《从前有座灵剑山》，游戏《古剑奇谭二》《仙剑奇侠传五前传》等，也为电影电视剧作品配音，如《琅琊榜》《伪装者》等。\n\n原所属北斗企鹅工作室，现藤韵文化成员。现居北京。\n\n声音沉厚稳重，音色充满力量和沧桑感，有着古香古色的国风气质，是古装剧以及国风动漫配音的首选。\n\n其配音声线多为浑厚的大叔音，亦会多种方言，配音效果风格多变，喜感十足。\n\n2013年11月8日，以嘉宾身份参加第八届中国北京国际文化创意产业博览会。\n\n2014年，参与由卢恒宇、李姝洁执导的动画电影《十万个冷笑话》的配音工作，为片中反派人物鸟不拉屎大王配音。\n\n2015年，参与手机游戏《新仙剑奇侠传》配音 ；在《梦塔防》首部资料片中为少年诸葛亮配音 。\n\n2016年9月，出席爱奇艺动漫游戏嘉年华 ；同年，参与原创动画《凸变英雄》配音；10月，为中央人民广播电台娱乐广播《名著经典》栏目中播出的《福尔摩斯探案全集》献声 。\n\n2017年4月，参与同名小说改编的动画《全职高手》配音；4月22日，出席香蕉计划BIG嘉年华；5月5日，参加动画《万古仙穹》媒体试映会。\n\n2020年11月6日，参与配音电影《未来的未来》上映 。\n\n2021年，参与动画电影《西游记之再世妖王》配音。参与动画片《紫川》配音。\n\n2022年2月1日，参演配音的动画电影《枕刀歌之尘世行》上映。\n\n2022年9月28日，参加第六届网络青晚。\n\n2022年，退出北斗企鹅工作室，加入藤韵文化。参加《我是特优声·剧团季》","name":"冯盛","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Feng Sheng (冯盛), also known by the alias Tutehameng (图特哈蒙), is a Chinese voice actor. He has been affiliated with the talent agency TrioPen Studio and Tengyun Culture.","name":"Sheng Feng","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"馮盛","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Фэн Шэн","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"圖特哈蒙，本名馮盛，中國配音員，原為北鬥企鵝工作室主要成員之一，現是藤韻文化成員。參與配音的作品有動畫《一人之下》《龍心戰紀》《神明之胄》《從前有座靈劍山》，遊戲《古劍奇譚二》《仙劍奇俠傳五前傳》等，也為電影電視劇作品配音，如《琅琊榜》《偽裝者》等。\n\n原所屬北鬥企鵝工作室，現藤韻文化成員。現居北京。\n\n聲音沉厚穩重，音色充滿力量和滄桑感，有著古香古色的國風氣質，是古裝劇以及國風動漫配音的首選。\n\n其配音聲線多為渾厚的大叔音，亦會多種方言，配音效果風格多變，喜感十足。\n\n2013 年 11 月 8 日，以嘉賓身份參加第八屆中國北京國際文化創意產業博覽會。\n\n2014 年，參與由盧恆宇、李姝潔執導的動畫電影《十萬個冷笑話》的配音工作，為片中反派人物鳥不拉屎大王配音。\n\n2015 年，參與手機遊戲《新仙劍奇俠傳》配音 ；在《夢塔防》首部資料片中為少年諸葛亮配音 。\n\n2016 年 9 月，出席愛奇藝動漫遊戲嘉年華 ；同年，參與原創動畫《凸變英雄》配音；10 月，為中央人民廣播電台娛樂廣播《名著經典》欄目中播出的《福爾摩斯探案全集》獻聲 。\n\n2017 年 4 月，參與同名小説改編的動畫《全職高手》配音；4 月 22 日，出席香蕉計劃 BIG 嘉年華；5 月 5 日，參加動畫《萬古仙穹》媒體試映會。\n\n2020 年 11 月 6 日，參與配音電影《未來的未來》上映 。\n\n2021 年，參與動畫電影《西遊記之再世妖王》配音。參與動畫片《紫川》配音。\n\n2022 年 2 月 1 日，參演配音的動畫電影《枕刀歌之塵世行》上映。\n\n2022 年 9 月 28 日，參加第六屆網絡青晚。\n\n2022 年，退出北鬥企鵝工作室，加入藤韻文化。參加《我是特優聲·劇團季》","name":"馮盛","primary":false}}]}},"movie_44837_keywords":{"at":1774698742803,"data":{"id":44837,"keywords":[]}},"person_17027_translations":{"at":1774698754938,"data":{"id":17027,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Charlene Lee McKenna (Irish: Searlaoin Nic Chionaoith; born March 26, 1984) is an Irish actress.\n\nShe became a household name in Ireland after starring as Jennifer Jackson in the miniseries Pure Mule (2005). She appeared on Irish television in Single-Handed 2 (2008), Whistleblower (2008), and Raw (2008–2013).\n\nFor Raw, she won Best Actress (Television) at the Irish Film & Television Awards, and for Whistleblower, she won Outstanding Actress in a Mini-Series at the Monte Carlo Television Festival.","name":"Charlene McKenna","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"AT","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"查莲妮·麦肯纳","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"查蓮妮·麥肯納","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Шарлин Маккенна","primary":false}}]}}}}