{"version":1,"entries":{"person_3275151_translations":{"at":1773146659275,"data":{"id":3275151,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Sakshi Vaidya","primary":false}},{"iso_3166_1":"IN","iso_639_1":"te","name":"తెలుగు","english_name":"Telugu","data":{"biography":"","name":"Sakshi Vaidya","primary":true}}]}},"person_1211164_translations":{"at":1773211331456,"data":{"id":1211164,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Kris Johnson","primary":true}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Кріс Джонсон","primary":false}}]}},"person_1081095_translations":{"at":1773319437809,"data":{"id":1081095,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Diana Pang Dan is a Chinese dancer and actress in Hong Kong and Mainland China.","name":"Diana Pang Dan","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"彭丹，1974年11月10日出生于湖南长沙，香港演员，舞蹈家。第十届全国青联常委，甘肃省政协委员，中国致公党中央文体委员。中国健康扶贫工程理事会名誉会长。\n\n14岁时被公派到美国茱莉亚学院留学，由于学习成绩优秀，成为该院第一位拿到全额奖学金的华裔学生；在美深造的八年期间，连续三届荣获“世界亚洲小姐”选美冠军、“美国中国小姐”选美冠军、“美国华裔小姐”选美冠军，成为唯一一位在世界选美舞台上荣获三连冠的东方女性；  1995年，主演了英语影片《落鸟》，这是彭丹的处女作；  2000年，主演了国庆献礼片《开着火车上北京》，获中宣部精神文明建设“五个一工程”奖，并成为第一位获此奖项的港台演员；2004年，主演了历史题材片《黄埔军人》，获好莱坞国际电影星光奖“最佳故事片奖”等四奖项；  2006年，彭丹参演了传记电影《张思德》，该片荣获中宣部精神文明建设“五个一工程”奖、中国电影华表奖“最佳故事片奖”、长春国际电影节“最佳故事片奖”和中国电影百花奖“最佳故事片奖”；2009年，主演了爱国故事片《可爱的中国》，该片成为中宣部六十周年国庆献礼片四部重点推荐片之一；  2013年，彭丹编导并主演的历史片《南泥湾》，被国家广电总局确定为“党的十八大重点献礼影片”，彭丹获得“2013年最佳新锐导演奖”和“第五届澳门国际电影节最佳编剧大奖”；  2014年，获得首届中美国际电视节最佳女主角奖。","name":"彭丹","primary":true}},{"iso_3166_1":"SG","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"彭丹","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"彭丹，曾為香港女演員。她曾聯獲美國的華裔小姐、中國小姐、亞裔小姐三項冠軍之後到香港發展。\n\n彭丹赴香港發展，並於亞洲小姐參賽後，在香港娛樂圈發展。彭丹主演多部三級情色片，比如《極度獸性》，《聊齋艷譚之幽媾》，《六魔女》等。彭丹因為身材出眾，有 36F 的上圍而有「波神」之稱。她擅長一字馬、芭蕾舞，其一字馬橋段在王晶導演的電影《紅燈區》中成為「彭神丹」的絕技。除此之外，彭丹也經常在獎門人系列中出現，其中經常在節目中表演拱橋及「魔鬼濕柴」（魔鬼身材）「E 字馬」(一字馬) 而令香港觀眾熟悉。近年主要在中國大陸發展，專拍紅色主旋律電影。","name":"彭丹","primary":false}}]}},"person_1839362_translations":{"at":1773384113213,"data":{"id":1839362,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Park Hwan-Hee","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"朴奂喜","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"박환희","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"朴煥熙","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"樸煥熙","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Пак Хван Хі","primary":false}}]}},"person_6057679_translations":{"at":1773405759650,"data":{"id":6057679,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Gary Trower","primary":true}}]}},"person_5076420_translations":{"at":1773470205286,"data":{"id":5076420,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Lu Xuanle","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"吕炫乐","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"呂炫樂","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","engli