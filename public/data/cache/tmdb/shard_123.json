{"version":1,"entries":{"person_1640965_translations":{"at":1774722354910,"data":{"id":1640965,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Liang Zhao","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Liang Zhao","primary":true}}]}},"person_4873036_translations":{"at":1774722356210,"data":{"id":4873036,"translations":[{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"Maria Therese Bassetti","primary":true}}]}},"person_2887356_translations":{"at":1774722357769,"data":{"id":2887356,"translations":[{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"Родилась в Москве 15 октября 2003 года. С детства увлекалась творчеством и любила публичные выступления. Ее кинокарьера началась еще в 9-летнем возрасте. Является студенткой МГИМО.\n\nС 2012 года начала сниматься в рекламе и стала ведущей передачи «Детское Движение Москвы». Через год получила первую небольшую роль в кино – в мелодраме «Возраст любви», где сыграла дочь Ольги и Максима Надю. С 2014 по 2016 год работала на канале «Карусель» ведущей шоу «Навигатор. Апгрейд».  С 2013 года ее начали постоянно приглашать на съемки различных кинопроектов.","name":"Маргарита Дьяченкова","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Margarita Dyachenkova","primary":false}}]}},"person_2051603_translations":{"at":1774722360372,"data":{"id":2051603,"translations":[{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Naman Jain","primary":false}},{"iso_3166_1":"IN","iso_639_1":"hi","name":"हिन्दी","english_name":"Hindi","data":{"biography":"","name":"Naman Jain","primary":true}}]}},"person_2641622_translations":{"at":1774722361841,"data":{"id":2641622,"translations":[{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"ジェシー（1996年6月11日 - ）は、日本のアイドル、俳優、ファッションモデルであり、男性アイドルグループ・SixTONESのメンバーである。旧芸名はルイス・ジェシー。","name":"ジェシー","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Jesse","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"杰西","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"傑西","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Jesse Lewis","primary":false}}]}}}}