original_name":"Sorawit Muangkaew","popularity":0.1071,"profile_path":null,"credit_id":"698dbcc024f7a03e57fb208b","department":"Writing","job":"Writer"},{"adult":false,"gender":1,"id":4674558,"known_for_department":"Creator","name":"MTRD.S","original_name":"มิ้ว","popularity":0.5821,"profile_path":null,"credit_id":"698dbd8f49f88d16c5f25b35","department":"Writing","job":"Novel"}],"id":278146}},"person_1048644_translations":{"at":1774721247370,"data":{"id":1048644,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Sarah Greene (born 24 July 1984) is an Irish actress and singer. She is best known for portraying Lorraine Waldron onn Normal People, Bibi Garvey on Bad Sisters, Maxine Carlson on Ransom, and Hecate Poole in Penny Dreadful.","name":"Sarah Greene","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Sarah Greene ist eine irische Schauspielerin.\n\n2010 spielte Sie \"Amber\" im Theaterstück \"Grimm\" am Peacock Theatre in Dublin. 2011 stellte Greene \"Sinead Mulligan\" im Film \"The Guard\" dar.\n\n2013 und 2014 war Sarah Greene neben Daniel Radcliffe im Theaterstück \"The Cripple of Inishmaan\" zu sehen. Für ihre Darstellung der Helen McCormick erhielt sie Nominierungen für den Tony Award und den Laurence Olivier Award als beste Nebendarstellerin. 2014 ergatterte Greene eine Rolle in der Fernsehserie \"The Assets\". In \"Noble\" spielte Sarah Greene mit der jungen Christina Noble eine der Hauptrollen. 2014 war sie als Prinzessin Judith in der Fernsehserie \"Vikings\" zu sehen.\n\nJudith sollte eine der Hauptcharaktere in der dritten Staffel der Serie werden. Greene lehnte dieses Angebot jedoch ab, um am Broadway auftreten zu können.\n\nSeit 2015 ist Sarah Greene in Penny Dreadful zu sehen.\n\n2019 begann sie als \"Detective Cassie Maddox\" eine der Hauptrollen bei \"Dublin Murders\" zu spielen.","name":"","primary":false}},{"iso_3166_1":"GR","iso_639_1":"el","name":"ελληνικά","english_name":"Greek","data":{"biography":"Η Σάρα Γκριν (24 Ιουλίου 1984) είναι Ιρλανδή ηθοποιός και τραγουδίστρια. Κέρδισε αναγνώριση για την απεικόνιση της Έλεν ΜακΚόρμικ στις παραγωγές του Γουέστ Εντ και του Μπρόντγουεϊ του Ο υπολοχαγός του Ίνισμορ. Για την ερμηνεία της στον ρόλο, ήταν υποψήφια για το βραβείο Λόρενς Ολίβιετου 2014 για την καλύτερη ηθοποιό σε υποστηρικτικό ρόλο και το βραβείο Tony του 2014 για την καλύτερη ηθοποιό σε θεατρικό έργο. Κέρδισε ιρλανδικό βραβείο κινηματογράφου και τηλεόρασης για την καλύτερη ηθοποιό - δράμα, ως Εκάτη Πουλ στις σειρές Showtime and Sky Penny Dreadful, καθώς και ως Μαξίν στη σειρά Ransom του CBS.","name":"","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"שרה גרין","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Сара Ґрін","primary":false}}]}},"person_1133904_translations":{"at":1774721249861,"data":{"id":1133904,"translations":[{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Oliver Coopersmith","primary":true}}]}}}}