slations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Sharon Chan is a Hong Kong actress most well-known for her career with broadcaster TVB.","name":"Sharon Chan Man-Chi","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"陈敏之，1979年1月17日出生于香港，中国香港女演员、歌手。\n\n1994年以模特儿身份进入娱乐圈。2000年成为小室哲哉在香港的五名徒弟之一。2001年签约香港电视广播有限公司，成为旗下艺员。2002年拍摄第一部电视剧《情事缉私档案.》。2006年与佘诗曼、林峰合作主演古装武侠剧《覆雨翻云》，饰演虚夜月。2007年参与拍摄由唐基明执导的喜剧《铁嘴银牙》。2010年领衔主演电视剧《公主嫁到》，饰演永河公主。2011年12月5日凭借电视剧《怒火街头》里的何利贞一角获TVB万千星辉颁奖典礼最佳女配角奖。2014年6月，陈敏之参演的电视剧《点金胜手》播出。","name":"陈敏之","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"Trần Mẫn Chi (陳敏之) (sinh ngày 17/1/1979) là người mẫu, diễn viên Hồng Kông. Cô hiện là nghệ sĩ theo hợp đồng của hãng TVB, thường được biết tới với danh hiệu \"Thiên hậu chân dài\" hay \"Người đẹp chân dài\".","name":"","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"陳敏之，本名陳敏之，香港女演員及主持，現為無綫電視經理人合約藝員，曾拍攝多套電視劇集，亦有主持時事、綜藝旅遊節目及音樂節目。她於 1990 年代初期以模特兒身分入行，及至 2001 年加入 TVB 後才開始嶄露頭角。她以擁有 43 吋長腿聞名，獲譽為「索腿天後」。","name":"陳敏之","primary":true}}]}},"tv_95730_detail_vi-VN":{"at":1773688726360,"data":{"adult":false,"backdrop_path":"/4ZQBTq0WghXYgsJO6vKtKNw5aBU.jpg","created_by":[{"id":2015754,"credit_id":"5dd99fec8e2e000015eea875","name":"Cian O'Clery","original_name":"Cian O'Clery","gender":2,"profile_path":null},{"id":1594488,"credit_id":"5dd99ff80cd4460019280ef0","name":"Karina Holden","original_name":"Karina Holden","gender":1,"profile_path":null}],"episode_run_time":[58],"first_air_date":"2019-11-19","genres":[{"id":99,"name":"Phim Tài Liệu"},{"id":10764,"name":"Reality"}],"homepage":"https://iview.abc.net.au/show/love-on-the-spectrum","id":95730,"in_production":true,"languages":["en"],"last_air_date":"2021-06-08","last_episode_to_air":{"id":3013758,"name":"Episode 5","overview":"","vote_average":0,"vote_count":0,"air_date":"2021-06-08","episode_number":5,"episode_type":"finale","production_code":"","runtime":43,"season_number":2,"show_id":95730,"still_path":"/1DT6qxZ0lQAAbUCnZQlTQq13O1D.jpg"},"name":"Love on the Spectrum","next_episode_to_air":null,"networks":[{"id":18,"logo_path":"/kMvN5R8g6L0SY5r9YZw9foYGQr0.png","name":"ABC TV","origin_country":"AU"}],"number_of_episodes":9,"number_of_seasons":2,"origin_country":["AU"],"original_language":"en","original_name":"Love on the Spectrum","overview":"","popularity":0.8837,"poster_path":"/zMsuBnjsKDMUrAZ0Ey6Ux3bVtn7.jpg","production_companies":[{"id":33438,"logo_path":"/geKQwKBQr4XOHDCmBzWjP3UwVjJ.png","name":"Northern Pictures","origin_country":"AU"}],"production_countries":[{"iso_3166_1":"AU","name":"Australia"}],"seasons":[{"air_date":"2019-11-19","episode_count":4,"id":136345,"name":"Season 1","overview":"","poster_path":"/2C3MzcyDlPlcmNhaebRcJwH41XR.jpg","season_number":1,"vote_average":10},{"air_date":"2021-05-18","episode_count":5,"id":195915,"name":"Season 2","overview":"","poster_path":"/tQwCGnhMMnw6KExYJMsslDbD38E.jpg","season_number":2,"vote_average":0}],"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Returning Series","tagline":"","type":"Documentary","vote_average":7.325,"vote_count":41}},"person_1829151_translations":{"at":1773688726777,"data":{"id":1829151,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Cem Yiğit Üzümoğlu is a Turkish theatre, TV and cinema artist. He graduated from Hacettepe University Ankara State Conservatory Acting Department. He studied physical theatre and modern dance in India and Poland. He took part in many theatre plays. In April 2017, he was awarded the \"Most Successful Young Generation Artist of the Year Award\" with \"Troas\" at the 21st Afife Theatre Awards. The young actor took part in the plays \"Troas\" and \"Kalp\" in 2018. In 2019, he is acting in the play \"Evlat\" directed by Ibrahim Çiçek.\n\nHis first role on television was the role of \"Hakan Sahin\" in the series Adi Efsane, which was broadcast on Kanal D in 2017. The series lasted 29 episodes. Uzumoglu was highly appreciated for his performance in the series.\n\nIn 2018, he played the character of \"Emir\" in Netflix's first Turkish original series Hakan: Muhafiz.\n\nIn 2020, Netflix original series Rise of Empires: Ottoman series as the lead role. In the documentary / series type project about the Conquest of Istanbul, Uzumoglu took part as \"Fatih Sultan Mehmed\".\n\nIn 2021, he starred as the lead role in the Netflix original film Kin. He played the character of \"Emre / Tuncay Kökdemir\" in the film.\n\nIn 2023, he opened his first photography exhibition titled \"Loners In Wilderness\" at Bina / Bant Mag. He opened his first photography exhibition titled \"Loners In Wilderness\" in 2023 at Bina / Bant Mag. The exhibition includes 46 black and white photographs selected among nearly 2000 photographs taken with an analogue camera.\n\nImdb mini bio by: yusufpiskin","name":"Cem Yiğit Üzümoğlu","primary":false}},{"iso_3166_1":"TR","iso_639_1":"tr","name":"Türkçe","english_name":"Turkish","data":{"biography":"","name":"Cem Yiğit Üzümoğlu","primary":true}}]}},"person_35515_translations":{"at":1773688728808,"data":{"id":35515,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"June Squibb (born November 6, 1929) began working in musical theatre at the St. Louis Muny and trained at the Cleveland Play House, and at the HB Studio. While at the Cleveland Play House, she performed in productions of Marseilles, The Play's the Thing, Goodbye, My Fancy, The Heiress, Detective Story, Antigone, Ladies in Retirement and Bloomer Girl. In 1958, she played Dulcie in The Boyfriend Off-Broadway. In 1959, she starred in an Off-Broadway revival of Lend an Ear with Elizabeth Allen. She made her Broadway debut in the original production of Gypsy starring Ethel Merman, taking over the role of stripper Electra in 1960. Squibb appeared in The Happy Time, which opened in 1968 and was nominated for the Tony Award for Best Musical. In-between these periods, she did modelling work for romance novels and appeared in commercials. In 1995, she appeared in the play Sacrilege on Broadway, which starred Ellen Burstyn. Squibb played many roles in national tours, regional theatre, summer stock and off-Broadway.  In 2012, she played Stella Gordon in Dividing the Estate at the Dallas Theater Center in which she received standout reviews.  She was nominated for the Academy Award for Best Supporting Actress for Alexander Payne's film Nebraska (2013). In 2015, she was inducted into the Cleveland Play House Hall of Fame. Squibb will appear in the Disney+ film Godmothered.","name":"June Squibb","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"June Louise Squibb (Vandalia, Illinois, 6 de novembro de 1929) é uma atriz americana. Ela desempenhou papéis coadjuvantes em filmes como Alice, Perfume de Mulher, A Idade da Inocência, In & Out e Longe do Paraíso. Também atuou em séries de televisão como Ghost Whisperer e na Broadway, incluindo a realização na produção original de Gypsy. Ela interpretou a esposa de Jack Nicholson no filme de Alexander Payne About Schmidt, e a esposa de Bruce Dern em Payne Nebraska, que estreou no 2013 Festival de Cannes e para o qual ela recebeu um Oscar nomeação para Melhor Atriz Coadjuvante.","name":"","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"준 스큅","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"美国演员","name":"琼·斯奎布","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"June Squibb (nata il 6 novembre 1929) iniziò a lavorare nel teatro musicale al St. Louis Muny e si formò alla Cleveland Play House e all'HB Studio. Mentre era alla Cleveland Play House, si è esibita in produzioni di Marseilles, The Play's the Thing, Goodbye, My Fancy, The Heiress, Detective Story, Antigone, Ladies in Retirement e Bloomer Girl. Nel 1958, ha interpretato Dulcie in The Boyfriend Off-Broadway. Nel 1959, ha recitato in un revival Off-Broadway di Lend an Ear con Elizabeth Allen. Ha fatto il suo debutto a Broadway nella produzione originale di Gypsy con Ethel Merman, assumendo il ruolo della spogliarellista Electra nel 1960. Squibb è apparso in The Happy Time, che ha debuttato nel 1968 ed è stato nominato per il Tony Award come miglior musical. Tra questi periodi, ha lavorato come modella per romanzi rosa ed è apparsa in spot pubblicitari. Nel 1995 è apparsa nella commedia Sacrilege a Broadway, interpretata da Ellen Burstyn. Squibb ha interpretato molti ruoli in tournée nazionali, teatri regionali, stock estivi e off-Broadway. Nel 2012, ha interpretato Stella Gordon in Dividing the Estate al Dallas Theater Center, dove ha ricevuto recensioni straordinarie. È stata nominata per l'Oscar come migliore attrice non protagonista per il film di Alexander Payne Nebraska (2013). Nel 2015 è stata inserita nella Cleveland Play House Hall of Fame. Squibb apparirà nel film Disney+ Godmothered.","name":"","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"美國演員","name":"瓊·斯奎布","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"ג'ון סקוויב","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Джун Скуибб","primary":false}}]}},"tv_243649