і.","name":"Аой Юкі","primary":false}}]}},"person_3850987_translations":{"at":1773470200651,"data":{"id":3850987,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Qiao Su","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"乔苏","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Цяо Су","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"乔苏","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"喬蘇","primary":false}}]}},"person_2576408_translations":{"at":1773470204418,"data":{"id":2576408,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"周历杰，1997年7月6日出生于浙江温州，中国内地男演员。\n\n2019年4月，周历杰主演电视剧《冰糖炖雪梨》，剧中饰演喻言。","name":"周历杰","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Zhou Lijie","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"周曆傑","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Чжоу Ли Цзе","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Chu Lịch Kiệt","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"주력걸","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"周曆傑，1997 年 7 月 6 日出生於浙江温州，中國內地男演員。\n\n2019 年 4 月，周曆傑主演電視劇《冰糖燉悉尼》，劇中飾演喻言。","name":"周曆傑","primary":false}}]}},"person_1798797_translations":{"at":17734917