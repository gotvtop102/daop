489,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"张卫健，香港著名男歌手和演员。最初凭借韦小宝、不懂、孙悟空等古灵精怪的形象为人们熟知，在表演方面的天赋征服了许多观众。然而他进入娱乐圈的最初目的是为了当歌手，1991年首次担纲出演《老友鬼鬼》便一炮走红，之后由香港华纳唱片公司推出的首张个人粤语专辑《真真假假》也登上了排行榜冠军。1999年《少年英雄方世玉》的热播使张卫健成为两岸三地家喻户晓的明星。2009年1月12日，张卫健和张茜结束10年爱情长跑，在菲律宾圣奥古斯汀教堂举行婚礼。","name":"张卫健","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Dicky Cheung Wai-kin (Chinese: 張衛健; born 8 February 1965) is a Hong Kong actor and singer.","name":"Dicky Cheung Wai-Kin","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Trương Vệ Kiện","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"張衛健，香港著名男歌手和演員。最初憑藉韋小寶、不懂、孫悟空等古靈精怪的形象為人們熟知，在表演方面的天賦徵服了許多觀眾。然而他進入娛樂圈的最初目的是為了當歌手，1991 年首次擔綱出演《老友鬼鬼》便一炮走紅，之後由香港華納唱片公司推出的首張個人粵語專輯《真真假假》也登上了排行榜冠軍。1999 年《少年英雄方世玉》的熱播使張衞健成為兩岸三地家喻戶曉的明星。2009 年 1 月 12 日，張衞健和張茜結束 10 年愛情長跑，在菲律賓聖奧古斯汀教堂舉行婚禮。","name":"張衛健","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"張衛健，香港著名男歌手和演員。最初憑藉韋小寶、不懂、孫悟空等古靈精怪的形象為人們熟知，在表演方面的天賦徵服了許多觀眾。然而他進入娛樂圈的最初目的是為了當歌手，1991 年首次擔綱出演《老友鬼鬼》便一炮走紅，之後由香港華納唱片公司推出的首張個人粵語專輯《真真假假》也登上了排行榜冠軍。1999 年《少年英雄方世玉》的熱播使張衛健成為兩岸三地家喻戶曉的明星。2009 年 1 月 12 日，張衛健和張茜結束 10 年愛情長跑，在菲律賓聖奧古斯汀教堂舉行婚禮。","name":"張衛健","primary":true}}]}},"movie_1053626_detail_vi-VN":{"at":1773688722173,"data":{"adult":false,"backdrop_path":"/8YXVuFszpr7huyZZlPm515HDxcg.jpg","belongs_to_collection":{"id":1053628,"name":"Ultraman Trigger & Decker Collection","poster_path":null,"backdrop_path":null},"budget":0,"genres":[{"id":28,"name":"Phim Hành Động"},{"id":12,"name":"Phim Phiêu Lưu"},{"id":18,"name":"Phim Chính Kịch"},{"id":878,"name":"Phim Khoa Học Viễn Tưởng"}],"homepage":"","id":1053626,"imdb_id":"tt23950632","origin_country":["JP"],"original_language":"ja","original_title