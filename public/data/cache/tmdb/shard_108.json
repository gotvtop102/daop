 Hoài và có những người bạn tốt đi cùng khiến cuộc sống trung học của Cảnh Cảnh không còn cô đơn nữa. Ngồi cùng bàn ba năm, Cảnh Cảnh và Dư Hoài dần trưởng thành, họ mang theo những ngốc nghếch, ngây thơ của thời học sinh để chia tay tuổi trẻ.\n\nSau khi thi tốt nghiệp trung học, người con trai đặc biệt nhất trong lòng Cảnh Cảnh cũng biến mất. Sau nhiều năm từ biệt, lúc gặp lại, Cảnh Cảnh lại nhớ về những ước định năm đó. Nhớ mãi không quên, Dư Hoài, Lộ Tinh Hà cùng tình yêu thời học trò năm nào của mình…","popularity":2.3404,"poster_path":"/jBiWSSukY3hjy7iYC9bMmZ2JXvr.jpg","production_companies":[{"id":172414,"logo_path":"/fNxBFqWr7eWEgNeBDvvCxsSItXx.png","name":"iQIYI","origin_country":"CN"}],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"seasons":[{"air_date":"2016-04-08","episode_count":24,"id":102797,"name":"Season 1","overview":"","poster_path":"/jBiWSSukY3hjy7iYC9bMmZ2JXvr.jpg","season_number":1,"vote_average":0}],"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Ended","tagline":"","type":"Scripted","vote_average":8.5,"vote_count":11}},"person_2409935_translations":{"at":1773688727677,"data":{"id":2409935,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"林鼓子是日本声优，静冈县出身，81produce所属。","name":"林鼓子","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Coco Hayashi (林 鼓子, Hayashi Koko, born May 15, 2002) is a Japanese voice actress and former child actress. She was born in Hamamatsu City, Shizuoka Prefecture. She is affiliated with mitt management. She was formerly affiliated with 81 Produce.","name":"Coco Hayashi","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Coco Hayashi (林 鼓子, Hayashi Koko, 15 de mayo de 2002) es una actriz de voz japonesa y ex actriz infantil. Nació en la ciudad de Hamamatsu, prefectura de Shizuok