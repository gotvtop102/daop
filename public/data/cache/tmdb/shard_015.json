{"version":1,"entries":{"movie_1502910_detail_vi-VN":{"at":1773688717457,"data":{"adult":false,"backdrop_path":"/ouB35KdyJV7DpKCbevmgJbJRn3t.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":28,"name":"Phim Hành Động"},{"id":35,"name":"Phim Hài"}],"homepage":"","id":1502910,"imdb_id":"tt32440581","origin_country":["ZA"],"original_language":"en","original_title":"Cop & a Half","overview":"Giữa lòng Johannesburg náo nhiệt, hai con người trái ngược buộc phải trở thành đồng đội bất đắc dĩ: một cảnh sát nguyên tắc đến cứng nhắc và một gã chỉ điểm dẻo miệng chẳng mấy đáng tin. Khi cả hai bị ném vào cuộc săn lùng đường dây ma túy khét tiếng, những mâu thuẫn dở khóc dở cười nhanh chóng biến thành một thứ đồng đội kỳ lạ. Và trên hành trình vừa nghẹt thở vừa tràn ngập tiếng cười ấy, họ gây ra không ít hỗn loạn — nhưng cũng có thể là hy vọng duy nhất để hạ gục băng nhóm tàn bạo nhất thành phố.","popularity":1.1769,"poster_path":"/t35vgIEv7m58dPwNChUcsndl4JI.jpg","production_companies":[{"id":271754,"logo_path":null,"name":"Cheeky Studios","origin_country":"ZA"},{"id":182847,"logo_path":"/v22brDWuFgoyWAblcHorCc3R4ey.png","name":"The Department of Trade, Industry and Competition (South Africa)","origin_country":"ZA"}],"production_countries":[{"iso_3166_1":"ZA","name":"South Africa"}],"release_date":"2025-06-25","revenue":0,"runtime":84,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"","title":"Cớm Nửa Mùa","video":false,"vote_average":8,"vote_count":2}},"tv_79680_credits":{"at":1773688719059,"data":{"cast":[{"adult":false,"gender":2,"id":1652371,"known_for_department":"Acting","name":"Daveed Diggs","original_name":"Daveed Diggs","popularity":1.3778,"profile_path":"/codalhZzB4LvJTSGOnOyrTEsqsF.jpg","character":"Andre Layton","credit_id":"5affbd72925141366a002fb6","order":0},{"adult":false,"gender":1,"id":1175394,"known_for_department":"Acting","name":"Mickey Sumner","original_name":"Mickey Sumner","popula