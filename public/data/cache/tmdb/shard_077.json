{"version":1,"entries":{"person_2156487_translations":{"at":1773543128415,"data":{"id":2156487,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"北斗企鹅工作室成员，有声主播，Cosplay爱好者。早期作为有声主播时曾用名“霙念汝”，后参演动画配音时，多用“沈念如”或“念汝”。沈念如，新生代优秀配音演员，北斗企鹅工作室成员。声线多变，表演情感丰富细腻，功底扎实，是非常有实力的新人演员。2016年，在动画电影《哆啦A梦 新大雄的日本诞生》中为利姆配音，同年，为电视动画《灵契》中的女主秦诗瑶配音。","name":"沈念如","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Shen Nianru","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"沈念如","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Шэнь Нянь Жу","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Nianru Shen","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"北鬥企鵝工作室成員，有聲主播，Cosplay 愛好者。早期作為有聲主播時曾用名“霙念汝”，後參演動畫配音時，多用“沈念如”或“念汝”。沈念如，新生代優秀配音演員，北鬥企鵝工作室成員。聲線多變，表演情感豐富細膩，功底紮實，是非常有實力的新人演員。2016 年，在動畫電影《哆啦 A 夢 新大雄的日本誕生》中為利姆配音，同年，為電視動畫《靈契》中的女主秦詩瑤配音。","name":"沈念如","primary":false}}]}},"tv_316015_credits":{"at":1773060335868,"data":{"cast":[{"adult":false,"gender":1,"id":2375175,"known_for_department":"Acting","name":"Fu Jing","original_name":"Fu Jing","popularity":0.7499,"profile_path":"/xYBRk48dUNNlq648Hvo0ecJhSSX.jpg","character":"Fang Xinyan","credit_id":"69ad19622ef5c1ff95fcb7b1","order":0},{"adult":false,"gender":2,"id":3252809,"known_for_department":"Acting","name":"Cheng Haofeng","original_name":"Cheng Haofeng","popularity":0.5156,"profile_path":"/tR5WctQuDIihitv6aV2AEM8nwdI.jpg","character":"Jiang Haiyang","credit_id":"69ad197b5f6013a98d80e424","order":1},{"adult":false,"gender":2,"id":2390065,"known_for_department":"Acting","name":"Li Chao","original_name":"Li Chao","popularity":0