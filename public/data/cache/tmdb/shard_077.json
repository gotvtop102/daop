{"version":1,"entries":{"person_1310288_translations":{"at":1773688717896,"data":{"id":1310288,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"外形娇媚、性格柔顺的龚慈恩是香港著名女星，她在台湾40集电视连续剧《雪山飞狐》中一人分饰两个角色——聪明机智的程灵素和娇柔俏丽的冰雪儿，令大陆观众为之着迷。1997年，龚慈恩接拍亚视武侠巨作《雪花神剑》，成功演绎了剧中女主角聂小凤瑰丽多情的一生，其精湛演技更凭借该人物的复杂丰满而大鸣大放，广受美评，并为雪花一剧及亚视博得崇高赞誉和巨大深远的人文影响。","name":"龚慈恩","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Mimi Kung Chi-Yan is a Chinese film and television actress.","name":"Mimi Kung","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"龔慈恩，香港女演員以及主持，舊名龔施茜，暱稱公仔，前亞洲電視女藝員；是現任無綫電視非戲劇組合約藝員。現為銀河海潤旗下藝員。","name":"龔慈恩","primary":true}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Cung Từ Ân","primary":false}}]}},"movie_524124_keywords":{"at":1773688719832,"data":{"id":524124,"keywords":[]}},"person_1715111_translations":{"at":1773688720563,"data":{"id":1715111,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Todd A. Robinson","primary":true}}]}},"person_131738_translations":{"at":1773688720895,"data":{"id":131738,"translations":[{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Michael Gaglio","primary":true}}]}},"person_1247368_translations":{"at":1773688721073,"data":{"id":1247368,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Lawrence Lau Sek-Yin (Chinese: 劉錫賢) is a Hong Kong actor.","name":"Lawrence Lau Sek-Yin","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"刘锡贤（Lau Shek Yin），生于香港，籍贯广东广州 ，亚洲电视合约艺员，1985 年于香港演艺学院 戏剧系（导演）毕业， 曾于无线电视任编剧，于1988年转投亚洲 电视。在亚视早期经常都在该台电视剧中 演出，但随着亚视因亏损连年，减少剧集 制作，他现时多数担任主持，亦获评为亚 视之实力派。\n\n由于体重达100公斤，故人称“肥仔贤”。","name":"刘锡贤","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"劉錫賢（Lau Shek Yin），生於香港，籍貫廣東廣州 ，亞洲電視合約藝員，1985 年於香港演藝學院 戲劇系（導演）畢業， 曾於無線電視任編劇，於 1988 年轉投亞洲 電視。在亞視早期經常都在該台電視劇中 演出，但隨著亞視因虧損聯年，減少劇集 製作，他現時多數擔任主持，亦獲評為亞 視之實力派。\n\n由於體重達 100 公斤，故人稱“肥仔賢”。","name":"劉錫賢","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Shek-Yin Lau","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Lưu Tích Hiền","primary":false}}]}},"person_5168256_translations":{"at":1773688721824,"data":{"id":5168256,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Adonis Tanța","primary":true}}]}},"person_1168779_translations":{"at":1773688734357,"data":{"id":1168779,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"An actress, known for The Shadows (2014), The Looking Glass (2011) and Krypton (2018).","name":"Natalia Kostrzewa","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"一位女演员，以《影子》（2014 年）、《镜子》（2011 年）和《氪星》（2018 年）而闻名。","name":"娜塔莉亚·科斯特泽瓦","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"一位女演員，以《影子》（2014 年）、《鏡子》（2011 年）和《氪星》（2018 年）而聞名。","name":"娜塔莉亞·科斯特澤瓦","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Наталья Кострцева","primary":false