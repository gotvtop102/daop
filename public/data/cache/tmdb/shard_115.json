{"version":1,"entries":{"movie_1640489_detail_vi-VN":{"at":1774722349839,"data":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":878,"name":"Phim Khoa Học Viễn Tưởng"}],"homepage":"","id":1640489,"imdb_id":null,"origin_country":["CN"],"original_language":"zh","original_title":"未来之心","overview":"Hai nhà phát minh Yu Shu và Liang Lan tạo ra \"Siêu vỏ não\" (The Hyper-Cortex), một trí tuệ nhân tạo đột phá có khả năng tái tạo các hệ sinh thái đã tuyệt chủng. Nhưng khi con trai họ lâm bệnh nặng, trong tuyệt vọng, Liang Lan hợp tác với nhà đầu tư bí ẩn, ông He, để xây dựng \"Công viên Mecha-Eden\" đầy lợi nhuận, trong khi Yu Shu, một người theo chủ nghĩa thuần túy, bỏ trốn cùng con trai, tin rằng tạo vật của họ quá thiêng liêng để bị đem ra trưng bày. Nhiều năm sau, khi thời gian của con trai họ sắp hết, Yu Shu trở về, giao nộp mảnh ghép cuối cùng của câu đố. Mã nguồn bị đánh cắp, bị biến chất, và những sinh vật hùng vĩ trong thần thoại trở thành cỗ máy hủy diệt. Trong hỗn loạn, một gia đình tan vỡ phải tìm cách đoàn tụ trước khi con quái vật khổng lồ, tạo vật của họ, nuốt chửng thế giới...","popularity":0.5703,"poster_path":"/3RmGh1w3lBpKiFKnK2LBfbk7U7U.jpg","production_companies":[],"production_countries":[],"release_date":"2026-02-26","revenue":0,"runtime":0,"spoken_languages":[],"status":"Released","tagline":"","title":"Trái Tim Của Tương Lai","video":false,"vote_average":4,"vote_count":1}},"person_4010208_translations":{"at":1774722352854,"data":{"id":4010208,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Ramin Nassiri","primary":false}},{"iso_3166_1":"PS","iso_639_1":"ps","name":"پښتو","english_name":"Pushto","data":{"biography":"","name":"Ramin Nassiri","primary":true}}]}},"tv_314297_credits":{"at":1774722361004,"data":{"cast":[{"adult":false,"gender":0,"id":6075799,"known_for_department":"Acting","name":"Karen Doherty","original_name":"Karen Doh