so_639_1":"en","name":"English"}],"status":"Returning Series","tagline":"","type":"Scripted","vote_average":7.241,"vote_count":56}},"person_70690_translations":{"at":1773676833533,"data":{"id":70690,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Kenneth Lo Wai-Kwong (Chinese: 盧惠光) is a Hong Kong actor, martial artist, and stuntman. He was a member of the Jackie Chan Stunt Team.","name":"Ken Lo Wai-Kwong","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"노혜광","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"　　卢惠光于1959年3月17日出生于泰国，是一名泰国华侨，也曾经是一位泰拳冠军（香港泰拳比赛七连冠）。上世纪80年代进入香港影坛。曾出演过徐克执导的《打工皇帝》。虽是几分钟的镜头，共拍了三天，但从那时起卢惠光才发现自己有喜欢拍电影的感觉。于是就兼职拍拍电影。他1986年开始正式为成龙的“威禾”影业拍摄第一部影片《扭计杂牌军》，这是一部成家班成员共同演出的电影，由钱升玮指导，成龙本人也在影片开始时有客串表演。后来他又演过李修贤的两部作品《皇家饭》和《霹雳先锋》，卢惠光开始进入成家班的时候，基本都是在配角的边缘徘徊。直到1994年卢惠光出演《醉拳2》才开始技惊四座一举成名，继而成为成龙的死党兼保镖。黎强权时代的“空中三连踢”，卢惠光时代的“一字马”都可以说是成家班在不同时代的典范表现，这也是成家班的实力和创造力的完美体现。他还参拍电影《宝贝计划》、《新警察故事》、《少年阿虎》、《雷霆战警》、《尖峰时刻》、《醉拳2》以及电视剧《斗鱼》。","name":"卢惠光","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"盧惠光於 1959 年 3 月 17 日出生於泰國，是一名泰國華僑，也曾經是一位泰拳冠軍（香港泰拳比賽七聯冠）。上世紀 80 年代進入香港影壇。曾出演過徐克執導的《打工皇帝》。雖是幾分鐘的鏡頭，共拍了三天，但從那時起盧惠光才發現自己有喜歡拍電影的感覺。於是就兼職拍拍電影。他 1986 年開始正式為成龍的“威禾”影業拍攝第一部影片《扭計雜牌軍》，這是一部成家班成員共同演出的電影，由錢升瑋指導，成龍本人也在影片開始時有客串表演。後來他又演過李修賢的兩部作品《皇家飯》和《霹靂先鋒》，盧惠光開始進入成家班的時候，基本都是在配角的邊緣徘徊。直到 1994 年盧惠光出演《醉拳 2》才開始技驚四座一舉成名，繼而成為成龍的死黨兼保鏢。黎強權時代的“空中三聯踢”，盧惠光時代的“一字馬”都可以説是成家班在不同時代的典範表現，這也是成家班的實力和創造力的完美體現。他還參拍電影《寶貝計劃》、《新警察故事》、《少年阿虎》、《雷霆戰警》、《火拼時速》、《醉拳 2》以及電視劇《鬥魚》。","name":"盧惠光","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"盧惠光","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Lô Huệ Quang","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Кен Ло","primary":false}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"Ken Lo Wai-Kwong","primary":false}}]}},"movie_1621496_detail_vi-VN":{"at":1773676836814,"data":{"adult":false,"backdrop_path":"/sufvriBjIYVnHkIcWuMnnVg58QA.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":28,"name":"Phim Hành Động"},{"id":12,"name":"Phim Phiêu Lưu"},{"id":14,"name":"Phim Giả Tượng"}],"homepage":"","id":1621496,"imdb_id":null,"origin_country":["CN"],"original_language":"zh","original_title":"猿山异闻录","overview":"Theo truyền thuyết, xa xưa có một ngọn núi tên là núi Viên Hầu. Trên núi có một quốc gia gọi là nước Viên. Trong nước Viên có một con vượn trắng hiếm có. Nước Viên tôn thờ vượn trắng như một vị thần và gọi là \"Viên Thần\". Dân chúng thờ cúng ngày đêm để cầu bình an. Gần đây, có tin đồn rằng \"Viên Thần\" giận dữ và không bảo vệ nước Viên nữa, vì vậy nên nhà vua mới bệnh mãi không khỏi. Điều này khiến cho cả nước lo sợ.","popularity":0.5878,"poster_path":"/dhk4xNejRdGKr9b7XXAOX77MLkq.jpg","production_companies":[],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"release_date":"2026-01-29","revenue":0,"runtime":74,"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Released","tagline":"","title":"Viên Sơn Dị Văn Lục","video":false,"vote_average":4.5,"vote_count":2}},"person_4468400_translations":{"at":1773676842249,"data":{"id":4468400,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Emily Anne Corcoran is a Canadian actress known for her work in film and television. She has been working as an actor since she was a young teenager. Emily received a Bachelor of Fine Arts in Acting from the University of Alberta in 2020. As of 2021 Emily resides and works in Toronto, O