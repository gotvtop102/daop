ty":0.3259,"profile_path":"/h3EfFsOttrNhS9AXrhHQzyjs1pS.jpg","cast_id":17,"character":"Sally","credit_id":"67ab985c6be6ab6e139ba94d","order":14},{"adult":false,"gender":1,"id":2541544,"known_for_department":"Acting","name":"Liu Ruiqiao","original_name":"劉芮僑","popularity":1.1663,"profile_path":"/kk16E9ggORYpOMdOQFdCKZHc67V.jpg","cast_id":18,"character":"Baby","credit_id":"67ab9879f71a3783e1bb32c7","order":15}],"crew":[{"adult":false,"gender":1,"id":228461,"known_for_department":"Directing","name":"Barbara Wong Chun-Chun","original_name":"Barbara Wong","popularity":0.9138,"profile_path":"/tSYT1KT82nwYO811CyRBqENFYW2.jpg","credit_id":"620b954aca8354006ae9fa5f","department":"Directing","job":"Director"},{"adult":false,"gender":1,"id":228461,"known_for_department":"Directing","name":"Barbara Wong Chun-Chun","original_name":"Barbara Wong","popularity":0.9138,"profile_path":"/tSYT1KT82nwYO811CyRBqENFYW2.jpg","credit_id":"620b9554c15b55001b83f36f","department":"Writing","job":"Writer"},{"adult":false,"gender":2,"id":118737,"known_for_department":"Production","name":"Alvin Lam","original_name":"林小強","popularity":0.4232,"profile_path":"/9rnTgNArK9pOmfRZ6CmsStG5vfD.jpg","credit_id":"67cd38c4ad486b43ebe2bb5d","department":"Production","job":"Producer"}]}},"person_74021_translations":{"at":1774721251067,"data":{"id":74021,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Li Bin (李滨) is a Chinese actress born in 1929 in Beijing.","name":"Li Bin","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"李滨，回族，北京人民艺术剧院演员。从小受官僚家庭教育影响，姐妹兄弟7人中有多位从艺，其中最有名是五哥——著名交响乐指挥大师李德伦；姐姐黎频也是北京人艺著名的表演艺术家。\n\n1949年解放后，李滨参加了解放军四野文工团，开始了表演生涯。北京人民艺术剧院成立后，李滨成了其中的一员，1957年因政治运动下放哈尔滨市，后重返人艺。话剧作品有《龙须沟》、《茶馆》、《骆驼祥子》、《关汉卿》、《新北京人》等。\n\n另有电影1988年《顽主》、《爱情麻辣烫》、《甲方乙方》、《我的父亲母亲》、《梅兰芳》、《建国大业》等，电视剧《编辑部的故事》、《重案六组》、《玫瑰刺》、《激情永远燃烧》等。","name":"李滨","primary":true}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"李濱","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"李濱，回族，北京人民藝術劇院演員。從小受官僚家庭教育影響，姐妹兄弟 7 人中有多位從藝，其中最有名是五哥——著名交響樂指揮大師李德倫；姐姐黎頻也是北京人藝著名的表演藝術家。\n\n1949 年解放後，李濱參加了解放軍四野文工團，開始了表演生涯。北京人民藝術劇院成立後，李濱成了其中的一員，1957 年因政治運動下放哈爾濱市，後重返人藝。話劇作品有《龍鬚溝》、《茶館》、《駱駝祥子》、《關漢卿》、《新北京人》等。\n\n另有電影 1988 年《頑主》、《愛情麻辣燙》、《甲方乙方》、《我的父親母親》、《梅蘭芳》、《建國大業》等，電視劇《編輯部的故事》、《重案六組》、《玫瑰刺》、《激情永遠燃燒》等。","name":"李濱","primary":false}}]}},"person_1115666_translations":{"at":1774721252579,"data":{"id":1115666,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Luo Jin","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"罗晋，1981年11月30日出生于江西省宜春市铜鼓县，中国内地影视男演员，毕业于北京电影学院表演系2002级本科。\n\n2003年，出演个人首部电视剧《售楼处的故事》，从而正式进入演艺圈。2006年，主演战争剧《战争目光》。2007年，出演个人首部电影《金碧辉煌》；同年，出演民国情感剧《梦幻天堂》 。2008年，主演年代剧《美丽的南方》。2009年，出演古装剧《三国》。2010年3月15日，其主演的古装宫廷剧《美人心计》在上海电视台电视剧频道首播；同年，主演年代励志剧《阿诚》 。","name":"罗晋","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"La Tấn (30/11/1981) xuất thân từ Giang Tây tỉnh Nghi Xuân, tốt nghiệp học viện Điện ảnh Bắc Kinh. Anh đang có cuộc sống hôn nhân hạnh phúc cùng với nữ diễn viên Đường Yên. Các tác phẩm nổi bật có sự tham gia của La Tấn: Tam Quốc, Cẩm Tú Vị Ương, Tam Sinh Tam Thế Thập Lý Đào Hoa (điện ảnh), Mỹ Nhân Tâm Kế, Phong Thần Diễn Nghĩa, An Gia...","name":"La Tấn","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"羅晉","primary":true}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"뤄진","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"羅晉，1981 年 11 月 30 日出生於江西省宜春市銅鼓縣，中國內地影視男演員，畢業於北京電影學院表演系 2002 級本科。\n\n2003 年，出演個人首部電視劇《售樓處的故事》，從而正式進入演藝圈。2006 年，主演戰爭劇《戰爭目光》。2007 年，出演個人首部電影《金碧輝煌》；同年，出演民國情感劇《夢幻天堂》 。2008 年，主演年代劇《美麗的南方》。2009 年，出演古裝劇《三國》。2010 年 3 月 15 日，其主演的古裝宮廷劇《美人心計》在上海電視台電視劇頻道首播；同年，主演年代勵志劇《阿誠》 。","name":"羅晉","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"","primary":false}}]}}}}