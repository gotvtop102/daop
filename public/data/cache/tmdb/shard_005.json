ile_path":null,"credit_id":"645746761b70ae0145ec86b2","department":"Editing","job":"Editor"},{"adult":false,"gender":2,"id":588387,"known_for_department":"Writing","name":"Zou Jingzhi","original_name":"邹静之","popularity":1.2806,"profile_path":"/xQS42Kf6kNxjh9cljPmPPckzDMY.jpg","credit_id":"64574630156cc7015e760da6","department":"Writing","job":"Screenplay"},{"adult":false,"gender":2,"id":12453,"known_for_department":"Directing","name":"Wong Kar-Wai","original_name":"王家衞","popularity":3.4714,"profile_path":"/iI4IxsIA5DMhIFHcD6C2FyZGKwc.jpg","credit_id":"645746dd77d23b015392e76e","department":"Art","job":"Art Direction"},{"adult":false,"gender":0,"id":3456396,"known_for_department":"Production","name":"Zhang Hao","original_name":"張浩","popularity":0.5452,"profile_path":null,"credit_id":"67357bbbd4ffba1e8b2ad336","department":"Production","job":"Line Producer"},{"adult":false,"gender":0,"id":3773431,"known_for_department":"Visual Effects","name":"Peng Zhang","original_name":"Peng Zhang","popularity":0.4387,"profile_path":null,"credit_id":"67ba02f1a96dc18979beab60","department":"Crew","job":"Special Effects"}]}},"person_2288847_translations":{"at":1774722359590,"data":{"id":2288847,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Gong Min-jeung is a South Korean actress. She graduated with a bachelor's degree from the Film Art Department of Konkuk University.\n\nShe's known for her roles in three Hong Sang-soo films, Yourself and Yours, On the Beach at Night Alone, and Grass. Also for her roles in television dramas such as Temperature of Love (2017), Familiar Wife (2018) and Hometown Cha-Cha-Cha (2021). In 2020, she won the Fantastic Best Actor Special Mention Award in the 24th Bucheon International Fantastic Film Festival for Zombie Crush: Heyri.","name":"Gong Min-jeung","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"공민정","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Кон Мин Джон","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"孔敏真（ 공민정，Gong Min-jeung）是韓國女演員。畢業於建國大學電影藝術系，獲學士學位。龔於2009年在一部獨立短片中首次亮相。在演了許多小角色後，她在 2012 年獨立電影《人人都想以我的名字死》中獲得了她的第一個配角，並在多部短片和獨立電影中積累了演技，如《狗》、《妖精》和《道德街頭規則》。在出演了洪尚秀的三部作品《你自己和你的》 、 《獨自在海邊》和《草地》後，給觀眾留下了深刻的印象，隨後又首次出演電視劇《愛情的溫度》（2017） . 在她的電視作品中，如《熟悉的妻子》 （2018 年）和《甜蜜的零食》（2020 年），她以豐富多彩的表演贏得了聲譽。2020年憑藉《殭屍粉碎：黑裡》獲得第24屆富川國際奇幻電影節奇幻最佳男演員特別提及獎。迄今為止，她最受歡迎的角色是海岸村恰恰恰電視劇中的牙科護士表美善。","name":"孔敏真","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"本名金敏贞，韩国女演员。2009年通过短篇电影《参观》出道，之后多数出演短篇电影和独立电影，曾参演洪常秀执导的《你自己与你所有》、《独自在夜晚的海边》及《草叶集》。2017年开始参演电视剧，代表角色有《海岸村恰恰恰》中的表美善和《小女子》中的张玛丽。《精神病房也会迎来清晨》许智颜《和我老公结婚吧》杨珠兰。","name":"孔敏贞","primary":false}},{"iso_3166_1":"MY","iso_639_1":"my","name":"","english_name":"Burmese","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"本名金敏貞，韓國女演員。2009 年通過短篇電影《參觀》出道，之後多數出演短篇電影和獨立電影，曾參演洪常秀執導的《你自己與你所有》、《獨自在夜晚的海邊》及《草葉集》。2017 年開始參演電視劇，代表角色有《海岸村恰恰恰》中的表美善和《小女子》中的張瑪麗。《精神病房也會迎來清晨》許智顏《和我老公結婚吧》楊珠蘭。","name":"孔敏貞","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Kim Min-jeong (en hangul: 김민정, nacida el 30 de septiembre de 1986), más conocida por su nombre artístico Gong Min-jeung (en hangul: 공민정), es una actriz surcoreana. Graduada del Departamento de Arte Cinematográfico de la Universidad de Konkuk.\n\nDebutó en 2009 con el cortometraje independiente «Gugyeong» (Visita), tras lo cual apareció en varios cortometrajes y películas independientes entre 2011 a 2015. Posteriormente, empezó a aparecer también en largometrajes y dramas televisivos. En 2020 ganó el premio Fantastic Best Actor Special Mention en el 24.º Festival Internacional de Cine Fantástico de Bucheon por Zombie Crush: Heyri.","name":"Gong Min-jeung","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"Gong Min-jeung","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"コン・ミンジョン","primary":false}}]}}}}