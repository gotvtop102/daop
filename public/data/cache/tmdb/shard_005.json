history","id":12026},{"name":"post world war ii","id":160224},{"name":"alternative reality","id":175629},{"name":"antagonistic","id":325766}]}},"person_2164723_translations":{"at":1773211330526,"data":{"id":2164723,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"王东，1978年7月30日出生于辽宁省，中国内地影视男演员、模特。\n\n2001年，在香港以模特身份拍摄平面杂志而进入演艺界；2006年，签约香港ELITE模特公司；2011年，参演个人首部电视剧《爱@幸福》；2012年，凭借微电影《勇敢做自己》获第二届南方微电影大赛最佳男主角；2015年，主演都市爱情电视剧《克拉恋人》饰演沈东军 ；同年11月，主演电视剧《亲爱的！好久不见》饰演容若诚。2016年，领衔主演三国题材巨制电视剧《军师联盟》饰演司马孚；同年8月主演科幻悬疑电影《暗影特工局》；并主演电影《最美的地方遇见你》。2017年4月，主演时尚悬疑偶像剧《归还世界给你》饰演墨许。 2017年10月，出演古装玄幻剧《将夜》。2017年12月，出演电视剧《流星花园》。2018年1月，主演都市情感剧《都挺好》饰演柳青。 2018年5月，出演都市职场剧《完美关系》；出演职场励志奋斗能量剧《正青春》，饰演王益。2019年1月，出演古装玄幻剧《将夜2》，饰演叶青；2019年4月，主演都市反谍剧《暴风眼》饰演乔西川；出演古装电视剧《玲珑》，饰演佛篆；出演古装剧《今夕何夕》，饰演闻邺；同年8月，领衔主演的都市职场励志剧《最酷的世界》男主角路芒；出演悬疑剧《拾光的秘密》，饰演夏匡正。","name":"王东","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Wang Dong is a Chinese actor and model born in Liaoning Province. He first entered showbiz in 2001 as a graphic model for a print magazine in Hong Kong. His acting career began in 2011 after participating in his first TV series \"Love@Happiness\". In 2012, he won the Best Actor award in the Second Southern Microfilm Contest for his role in the microfilm \"Be Brave to Be Yourself\".","name":"Wang Dong","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Wang Dong","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Ван Дун","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"王東，1978 年 7 月 30 日出生於遼寧省，中國內地影視男演員、模特。\n\n2001 年，在香港以模特身份拍攝平面雜志而進入演藝界；2006 年，籤約香港 ELITE 模特公司；2011 年，參演個人首部電視劇《愛@幸福》；2012 年，憑借微電影《勇敢做自己》獲第二屆南方微電影大賽最佳男主角；2015 年，主演都市愛情電視劇《克拉戀人》飾演沈東軍 ；同年 11 月，主演電視劇《親愛的！好久不見》飾演容若誠。2016 年，領銜主演三國題材巨制電視劇《軍師聯盟》飾演司馬孚；同年 8 月主演科幻懸疑電影《暗影特工局》；並主演電影《最美的地方遇見你》。2017 年 4 月，主演時尚懸疑偶像劇《歸還世界給你》飾演墨許。\n\n2017 年 10 月，出演古裝玄幻劇《將夜》。2017 年 12 月，出演電視劇《流星花園》。2018 年 1 月，主演都市情感劇《都挺好》飾演柳青。\n\n2018 年 5 月，出演都市職場劇《完美關係》；出演職場勵志奮鬥能量劇《正青春》，飾演王益。2019 年 1 月，出演古裝玄幻劇《將夜 2》，飾演葉青；2019 年 4 月，主演都市反諜劇《暴風眼》飾演喬西川；出演古裝電視劇《玲瓏》，飾演佛篆；出演古裝劇《今夕何夕》，飾演聞鄴；同年 8 月，領銜主演的都市職場勵志劇《最酷的世界》男主角路芒；出演懸疑劇《拾光的秘密》，飾演夏匡正。","name":"王東","primary":false}}]}},"movie_498517_credits":{"at":1773319434385,"data":{"id":498517,"cast":[{"adult":false,"gender":0,"id":1968410,"known_for_department":"Acting","name":"Adeeb Safadi","original_name":"Adeeb Safadi","popularity":0.4175,"profile_path":null,"cast_id":1,"character":"Saleem","credit_id":"5a6dcbc1925141076301805e","order":0},{"adult":false,"gender":1,"id":1968411,"known_for_department":"Acting","name":"Sivane Kretchner","original_name":"Sivane Kretchner","popularity":0.097,"profile_path":null,"cast_id":2,"character":"Sarah","credit_id":"5a6dcbcfc3a368556c01c034","order":1},{"adult":false,"gender":2,"id":41641,"known_for_department":"Acting","name":"Ishai Golan","original_name":"Ishai Golan","popularity":0.5602,"profile_path":"/lU6rRzngIOGnqx7sOmtidZlmQzQ.jpg","cast_id":3,"character":"David","credit_id":"5a6dcbde9251410757017a78","order":2},{"adult":false,"gender":0,"id":1682614,"known_for_department":"Acting","name":"Hanan Hillo","original_name":"Hanan Hillo","popularity":0.6136,"profile_path":"/4DSMnTNtAEw1gl6tjrsuFtA8Dmi.jpg","cast_id":4,"character":"Maryam","credit_id":"5a6dcbeac3a368554701e573","order":3},{"adult":false,"gender":1,"id":1079533,"known_for_department":"Acting","name":"Maisa Abd Elhadi","original_name":"ميساء عبد الهادي","popularity":0.501,"profile_path":"/oB1GjX3FcVjvmFa4casNGc7XR6f.jpg","cast_id":5,"character":"Bisan","credit_id":"5a6dcbf8c3a368556201b512","order":4},{"adult":false,"gender":2,"id":1585765,"known_for_dep