理人合約，和陳小春、朱永棠組成風火海，成為繼草蜢之後第二隊跳舞組合。風火海第一張大碟於 1994 年推出，名為《愛情風火海》，翌年推出第二張大碟《歡樂世界》，三人參與電影古惑仔系列後便開始分開發展。","name":"謝天華","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"謝天華","primary":false}}]}},"person_224034_translations":{"at":1773688726205,"data":{"id":224034,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Chun Wong","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"秦煌、原名梁日成，1948年6月出生，香港无线电视甘草演员。\n\n其妻为资深广播人莫佩雯。秦煌由佳艺电视转投无线电视后服务了超过二十年，参演过110出剧集，一直都饰演胖胖的好人。例如金庸笔下的老顽童周伯通、《鹿鼎记》里的茅十八等，虽然有时候也会演出坏人令人跌破眼镜，例如《施公奇案》的僧格正雄等。秦煌先后参演过20部金庸剧，是演出金庸剧最多的演员。","name":"秦煌","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"秦煌、原名梁日成，1948 年 6 月出生，香港無線電視甘草演員。\n\n其妻為資深廣播人莫佩雯。秦煌由佳藝電視轉投無線電視後服務了超過二十年，參演過 110 出劇集，一直都飾演胖胖的好人。例如金庸筆下的老頑童周伯通、《鹿鼎記》裏的茅十八等，雖然有時候也會演出壞人令人跌破眼鏡，例如《施公奇案》的僧格正雄等。秦煌先後參演過 20 部金庸劇，是演出金庸劇最多的演員。","name":"秦煌","primary":true}}]}},"tv_200875_detail_vi-VN":{"at":1773688727995,"data":{"adult":false,"backdrop_path":"/2746UvsbkZINd873Yd3o3TxOwCP.jpg","created_by":[{"id":1113116,"credit_id":"682cac47989cf65c7edb32d8","name":"Andy Muschietti","original_name":"Andy Muschietti","gender":2,"profile_path":"/4ndnP2NNavhfGtJqihD4FVDsYMY.jpg"},{"id":1094761,"credit_id":"682cac56bb2a3d77b7f563d1","name":"Barbara Muschietti","original_name":"Barbara Muschietti","gender":1,"profile_path":"/65vHzXRLw0G8iJdWvx28GgllZ2P.jpg"},{"id":131947,"credit_id":"682d0d7b363fe5d2f6e25497","name":"Jason Fuchs","original_name":"Jason Fuchs","gender":2,"profile_path":"/fevls3rxpa1GQx4kSPNKNjRemKW.jpg"}],"episode_run_time":[],"first_air_date":"2025-10-26","genres":[{"id":18,"name":"Phim Chính Kịch"},{"id":9648,"name":"Phim Bí Ẩn"}],"homepage":"https://www.hbo.com/content/it-welcome-to-derry","id":200875,"in_production":true,"languages":["en"],"las