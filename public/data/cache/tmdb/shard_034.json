_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Evelyn Burke","primary":true}}]}},"movie_1053626_keywords":{"at":1773688722156,"data":{"id":1053626,"keywords":[{"id":1701,"name":"hero"},{"id":9715,"name":"superhero"},{"id":11100,"name":"giant monster"},{"id":9663,"name":"sequel"},{"id":9951,"name":"alien"},{"id":14909,"name":"alien invasion"},{"id":155755,"name":"mysterious woman"},{"id":161791,"name":"kaiju"},{"id":238131,"name":"death of hero"},{"id":266698,"name":"kyodai hero"},{"id":269769,"name":"based on tv series"},{"id":281450,"name":"ultraman"},{"id":283844,"name":"returning hero"}]}},"person_1326172_translations":{"at":1773688723604,"data":{"id":1326172,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Lee Kwang-soo (Korean: 이광수; born 14 July 1985) is a South Korean actor, entertainer, and model. He made his acting debut in the sitcom Here He Comes (2008). He then received further recognition for his roles in medical melodrama It's Okay, That's Love (2014), neo-noir film Confession (2014), black comedy film Collective Invention (2015), one-act play Puck! (2016), sitcom The Sound of Your Heart (2016) and drama Live (2018), drama comedy film Inseparable Bros (2019).\n\nBesides acting, Lee is also known for being one of the regular cast members of the South Korean variety show Running Man since 2010.","name":"Lee Kwang-soo","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"이광수","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"李光洙（朝鲜语：이광수／李光洙 Lee Kwang Soo，1985年7月14日－），韩国著名男演员、主持和模特儿，身高190公分， Running Man成员。\n\n曾是模特儿，于2008年以《KTF Show－二十岁篇》广告出道；2009年拍摄MBC日日剧《穿透屋顶的High Kick》后开始为人熟悉；2010年出演SBS综艺节目《Running Man》后晋身为综艺新星，在节目海外拍摄时获得压倒性人气，被冠以“亚洲王子”的称号，于电影界亦成为崛起的新势力。","name":"李光洙","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"李光洙","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Ли Кван Су","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"Lee Kwang-soo é um ator, apresentador e modelo sul-coreano. Ele fez sua estreia como ator no sitcom Here He Comes e recebeu reconhecimento por seus papéis nos dramas televisivos It's Okay, That's Love, The Sound of Your Heart e Live, além dos filmes Confession, Collective Invention e Inseparable Bros.\n\nAlém de atuar, Lee também é conhecido por ser um dos membros regulares do programa de variedades sul-coreano Running Man da SBS desde 2010.","name":"Lee Kwang Soo","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"李光洙（朝鮮語：이광수／李光洙 Lee Kwang Soo，1985 年 7 月 14 日－），韓國著名男演員、主持和模特兒，身高 190 公分， Running Man 成員。\n\n曾是模特兒，於 2008 年以《KTF Show－二十歲篇》廣告出道；2009 年拍攝 MBC 日日劇《穿透屋頂的 High Kick》後開始為人熟悉；2010 年出演 SBS 綜藝節目《Running Man》後晉身為綜藝新星，在節目海外拍攝時獲得壓倒性人氣，被冠以“亞洲王子”的稱號，於電影界亦成為崛起的新勢力。","name":"李光洙","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"Lee Kwang-soo (이광수), né le 14 juillet 1985, est un acteur et mannequin sud-coréen. Il a fait ses débuts d'acteur dans la sitcom Here He Comes (2008), puis s'est fait connaître pour ses rôles dans It's Okay, That's Love, Confession, Collective Invention, Puck!, The Sound of Your Heart, Live et Inseparable Bros.\n\nIl est également célèbre pour sa participation à l'émission sud-coréenne Running Man depuis 2010.","name":"Lee Kwang-soo","primary":false}}]}},"person_2116057_translations":{"at":1773688731394,"data":{"id":2116057,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Joma Labayen","primary":false}},{"iso_3166_1":"PH","iso_639_1":"tl","name":"","english_name":"Tagalog","data":{"biography":"","name":"Joma Labayen","primary":true}}]}},"movie_1059073_detail_vi-VN":{"at":1773688733970,"data":{"adult":false,"backdrop_path":"/6GGsUgmef5MIfJnnp2fGvkFWRg6.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":10749,"name":"Phim Lãng Mạn"},{"id":18,"name":"Phim Chính Kịch"}],"homepage":"","id":1059073,"imdb_id":"tt24515124","origin_country":["US"],"original_language":"en","original_title":"Winter Spring Summer or Fall","overview":"Winter Spring Summer or Fall 2024 là câu chuyện về Remi, một cô gái có kế hoạch rõ ràng cho tương lai, và Barnes, chàng trai phóng khoáng, sống hết mình cho hiện tại. Cuộc gặp gỡ giữa họ diễn ra trong bốn ngày quan trọng của năm, mỗi mùa mang đến một lựa chọn và thử thách mới. Khi tình cảm dần lớn lên, Remi phải quyết định: đi theo con đường đã định hay bước vào thế giới đầy bất ngờ cùng Barnes.","popularity":3.7377,"poster_path":"/mEPi5ISa5RmzpzeDfwkhX0CcNsf.jpg","production_companies":[{"id":2090,"logo_path":"/jYlUttNqcN5u1pzMQrh5AEhZ27t.png","name":"Motion Picture Corporation of America","origin_country":"US"},{"id":64216,"logo_path":"/Eg9VjIFt743LPYaK8Ag0fuhWGo.png","name":"Brad Krevoy Television","origin_country":"US"},{"id":96765,"logo_path":"/gGzebro8XLAZmC9uJbUlhMtDxq5.png","name":"Wall Fly","origin_country":"US"}],"production_countries":[{"iso_3166_1":"US","name":"United States of America"}],"release_date":"2024-12-27","revenue":0,"runtime":97,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"","title":"Bốn Mùa Yêu","video":false,"vote_average":7.3,"vote_count":226}},"person_2151104_translations":{"at":1773688736720,"data":{"id":2151104,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Rao Xiaozhi","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"饶晓志，舞台剧与电影导演，中国话剧最高奖金狮导演奖获得者。毕业于中央戏剧学院导演系，其执导了多部享誉国内的舞台剧作品。2008年，与李亚鹏共同创立春天戏剧工作室。2009年5月，执导了绅士喜剧《你好，打劫！》 ；同年执导了话剧版《将爱情进行到底》 。2012年12月，执导了绅士喜剧《咸蛋》 。2014年10月，执导了改编自作家孔二狗同名原著的舞台剧《东北往事》 。2015年4月，执导了话剧《蠢蛋》 ；同年12月，执导了由作家饶雪漫同名小说改编的舞台剧《左耳》 。2014年12月，饶晓志凭借《你好，打劫！》等作品在第九届中国话剧金狮奖中获得最佳导演奖 。2016年末，由其导演的同名话剧《你好，疯子！》改编而成的电影登陆全国院线，作为其银幕导演处女作，本片入围第八届澳门电影节主竞赛单元，争夺最佳影片大奖。2018年11月由饶晓志编剧、导演的荒诞喜剧电影《无名之辈》全国热映，获得业内外一致高度关注和好评，票房达7.9亿。","name":"饶晓志","primary":true}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"饒曉志","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"饒曉志，舞台劇與電影導演，中國話劇最高獎金獅導演獎獲得者。畢業於中央戲劇學院導演系，其執導了多部享譽國內的舞台劇作品。2008 年，與李亞鵬共同創立春天戲劇工作室。2009 年 5 月，執導了紳士喜劇《你好，打劫！》 ；同年執導了話劇版《將愛情進行到底》 。2012 年 12 月，執導了紳士喜劇《鹹蛋》 。2014 年 10 月，執導了改編自作家孔二狗同名原著的舞台劇《東北往事》 。2015 年 4 月，執導了話劇《蠢蛋》 ；同年 12 月，執導了由作家饒雪漫同名小説改編的舞台劇《左耳》 。2014 年 12 月，饒曉志憑藉《你好，打劫！》等作品在第九屆中國話劇金獅獎中獲得最佳導演獎 。2016 年末，由其導演的同名話劇《你好，瘋子！》改編而成的電影登陸全國院線，作為其銀幕導演處女作，本片入圍第八屆澳門電影節主競賽單元，爭奪最佳影片大獎。2018 年 11 月由饒曉志編劇、導演的荒誕喜劇電影《無名之輩》全國熱映，獲得業內外一致高度關注和好評，票房達 7.9 億。","name":"饒曉志","primary":false}}]}},"person_2395142_translations":{"at":1773688736811,"data":{"id":2395142,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Martin Razpopov is an actor, known for Black Widow (2020) and The King's Man (2020).","name":"Martin Razpopov","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Мартин Разпопов","pri