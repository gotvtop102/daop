ame":"child abuse"},{"id":6259,"name":"psychopath"},{"id":12332,"name":"apocalypse"},{"id":15076,"name":"cat and mouse"},{"id":155437,"name":"children on the run"},{"id":168490,"name":"dead parents"},{"id":170865,"name":"child kidnapping"},{"id":212425,"name":"trapped in a house"},{"id":285979,"name":"prisoners"},{"id":305726,"name":"grieving mother"},{"id":309974,"name":"absurd"},{"id":325120,"name":"orphans"},{"id":350689,"name":"children"},{"id":355145,"name":"orphan girl"}]}},"person_215910_translations":{"at":1773689216489,"data":{"id":215910,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Rana Daggubati is an Indian film actor, producer, Visual Effects co-ordinator,and photographer known for his works in Telugu cinema, Tamil cinema and Bollywood.\n\nAs a Visual Effects producer, Rana won the State Nandi Award for Best Special Effects in 2006 for the Telugu film Sainikudu starring Mahesh Babu. In 2006, he received the National Film Award for co-producing Bommalata – A Bellyful of Dreams. In 2010, he made his acting debut with the Telugu blockbuster Leader, for which he won the Filmfare Award for Best Male Debut – South. He received critical acclaim for his performance in the 2012 crime thriller film Krishnam Vande Jagadgurum. In 2015, he starred as the main antagonist in Baahubali: The Beginning, which recorded the highest gross opening for an Indian film.","name":"Rana Daggubati","primary":false}},{"iso_3166_1":"IN","iso_639_1":"te","name":"తెలుగు","english_name":"Telugu","data":{"biography":"","name":"Rana Daggubati","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"印度电影演员、制片人、视觉效果协调员和摄影师，以其在泰卢固语电影、泰米尔电影和宝莱坞的作品而闻名。\n\n作为视觉效果制作人，Rana 于 2006 年凭借由 Mahesh Babu 主演的泰卢固语电影 Sainikudu 获得了国家南迪最佳特效奖。2006年，他因联合制作《Bommalata – A Bellyful of Dreams》而获得国家电影奖。2010 年，他在泰卢固语大片《领袖》中首次亮相，并因此获得了 Filmfare 奖最佳男处女作奖 - 南方。他因在 2012 年犯罪惊悚电影 Krishnam Vande Jagadgurum 中的表演而广受好评。2015年，他在《巴霍巴利王：开端》中出演主要反派，该片创下了印度电影的最高票房纪录。","name":"拉纳·达格巴帝","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"印度電影演員、製片人、視覺效果協調員和攝影師，以其在泰盧固語電影、泰米爾電影和寶萊塢的作品而聞名。\n\n作為視覺效果製作人，Rana 於 2006 年憑藉由 Mahesh Babu 主演的泰盧固語電影 Sainikudu 獲得了國家南迪最佳特效獎。2006 年，他因聯合製作《Bommalata – A Bellyful of Dreams》而獲得國家電影獎。2010 年，他在泰盧固語大片《領袖》中首次亮相，並因此獲得了 Filmfare 獎最佳男處女作獎 - 南方。他因在 2012 年犯罪驚悚電影 Krishnam Vande Jagadgurum 中的表演而廣受好評。2015 年，他在《帝國戰神：巴霍巴利王》中出演主要反派，該片創下了印度電影的最高票房紀錄。","name":"拉納·達格巴帝","primary":false}}]}}}}