h từ sự đồng hành của người thân và bạn bè. Cuối cùng, với thái độ sống lạc quan, anh đã thực hiện được ước mơ của mình.","popularity":3.0805,"poster_path":"/pqHsHwcl5CwHaOsc1woAOCSKzvR.jpg","production_companies":[{"id":74457,"logo_path":"/mPsCbXC5k20bpKErrbOQd1fG0L7.png","name":"Tencent Video","origin_country":"CN"}],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"seasons":[{"air_date":"2025-12-15","episode_count":27,"id":428418,"name":"Season 1","overview":"","poster_path":"/owYG6cMOxnUIdavhyLmpyoWGv2f.jpg","season_number":1,"vote_average":7}],"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Ended","tagline":"","type":"Scripted","vote_average":7.5,"vote_count":5}},"person_4502519_translations":{"at":1773689206190,"data":{"id":4502519,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Fan Xinyuan","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"范馨源","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"范馨源","primary":true}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"範馨源","primary":false}}]}},"person_1238660_translations":{"at":1773689208209,"data":{"id":1238660,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Eri Sakurai","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"桜井映里","primary":true}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Eri Sakurai","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"櫻井映裏","primary":false}}]}},"person_1105322_translations":