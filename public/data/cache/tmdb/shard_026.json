Tony Dean Smith","popularity":0.6922,"profile_path":"/tjgwvfzNXQNLrFbfqH8TdQVN7j5.jpg","credit_id":"67b3795f48116a50c3e0c554","department":"Editing","job":"Editor"}]}},"person_1253298_translations":{"at":1773688730660,"data":{"id":1253298,"translations":[{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"何璧坚","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Ho Bik-Kin","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"何璧堅，已故香港電影人、電視劇演員。\n\n何璧堅早年出身於電影界，曾參與多部粵語片的幕後編導工作，偶爾也在幕前演出。1970 年代他加入無綫電視成為基本演員，多數都是在武俠劇中飾演高僧的角色。","name":"何璧堅","primary":true}}]}},"person_3519938_translations":{"at":1773688731341,"data":{"id":3519938,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Richard Arma","primary":false}},{"iso_3166_1":"PH","iso_639_1":"tl","name":"","english_name":"Tagalog","data":{"biography":"","name":"Richard Arma","primary":true}}]}},"person_5897647_translations":{"at":1773688731899,"data":{"id":5897647,"translations":[{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"선재스님","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Seonjae","primary":false}}]}},"person_5888702_translations":{"at":1773688735758,"data":{"id":5888702,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Lily Safra","primary":true}}]}},"person_2579735_translations":{"at":1773688737970,"data":{"id":2579735,"translations":[{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"Подготовительные курсы на актерский факультет ВГИКа. Поступил в Щепкинское театральное училище на курс В.Коршунова. В 2000 году окончил Театральное училище им. Щепкина и был зачислен в труппу Московского ТЮЗа.","name":"Алексей Алексеев","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Aleksey Alekseev","primary":false}}]}},"person_226709_translations":{"at":1773688738130,"data":{"id":226709,"translations":[{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"В 1984 году окончил Государственный институт театрального искусства (режиссерский факультет и факультет актерского мастерства). После института в качестве актера и режиссера работал в московских театрах. С 1984-1988 в театре им. Гоголя играл в спектаклях: \"А этот выпал из гнезда\" (\"Полет над гнездом кукушки\") Д.Вассермана, \"Декамерон\" Д.Бокаччо, \"Берег\" Ю.Бондарева и др. С 1990-1992 в московском театре-кабарэ \"Летучая мышь\" в спектакле: \"Чтение новой пьесы\" Гр.Гурвича С 1988 по 1990 - в театре на \"Юго-Западе\" в спектакле \"Ревизор\" в роли Хлестакова. С 1991 по 1992 в творческом объединении \"АТВ\" выпустил телепрограмму \"Оба-на!\", которую критика отмечала как \"событие в телевизионном эфире\". В 1992 году - лауреат Первой премии \"Золотой Остап\", присуждаемой за наивысшие достижения в жанре сатиры и юмора. С 1992 по 1995 - телепрограмма \"Угол шоу\", которая неизменно имела высокий рейтинг в течение трех лет. В 1994 году удостоен премии \"Овация\" за лучшую телевизионную программу. С 1996 года снял 48 серийный проект \"Доктор Угол\". Сериал признан одним из лучших на канале НТВ. В 1996 году вышла в свет книга \"Оба-на!\", куда вошли рассказы, сценарии и телевизионные пьесы, написанные Игорем Угольниковым. Тогда же вышел диск с песнями в его исполнении, которые звучали в ранее созданных им программах.  С 1996 года - заместитель директора Дирекции телевизионного вещания Всероссийской Государственной телерадиовещательной компании. 1996 - в качестве продюсера создал ток-шоу \"V.I.P.- Особо важные персоны\", не имеющее аналогов в мире. 1997-1998 - постановщик и ведущий ежедневного развлекательного ток-шоу \"Добрый вечер\", аналогов которого на отечественном телевидении не существовало. 1998 - автор сценария и режиссер телевизионного музыкального фильма \"Это несерьезно\". С 1999 года - Вице-президент Российского фонда Культуры. Председатель Телерадиовещательной организации Союзного государства.","name":"Игорь Угольников","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Igor Ugolnikov","primary":false}}]}}}}