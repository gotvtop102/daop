3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Хікару Тоно","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"遠野光是日本的女性聲優。出身於東京都，所屬公司為響。","name":"遠野光","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Hikaru Tono","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Хикару Тоно","primary":false}}]}},"person_1433191_translations":{"at":1774377105150,"data":{"id":1433191,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Matthew Ninaber","primary":true}}]}},"person_12676_translations":{"at":1774377105793,"data":{"id":12676,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Dong Jie  (born April 19, 1980) is a Chinese actress and dancer.\n\nDescription above from the Wikipedia article Dong Jie, licensed under CC-BY-SA, full list of contributors on Wikipedia","name":"Dong Jie","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"Dong Jie è un'attrice e ballerina cinese.","name":"Dong Jie","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"董洁，1980年4月19日出生于辽宁省大连市，毕业于中国人民解放军艺术学院舞蹈系，中国内地影视女演员。\n\n2000年，因参加央视春晚开始受到关注；同年，被导演张艺谋选中出演电影《幸福时光》，她凭借该剧获得第7届中国电影华表奖电影新人奖及第47届西班牙巴利亚多利德国际电影节最佳女演员奖。2003年，其主演的民国爱情剧《金粉世家》取得央视年度收视冠军，董洁个人也凭借该剧开始在影视领域崭露头角；同年，她还凭借爱情片《地下铁》提名第27届大众电影百花奖最佳女演员。2015年，因出演都市家庭轻喜剧《虎妈猫爸》提名第22届上海电视节白玉兰奖最佳女配角 。2017年，拍摄古装宫斗剧《如懿传》和古装历史剧《三国机密》。\n\n2018年，在东方卫视《新舞林大会》总决赛中胜出，获得总冠军。","name":"董洁","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"董潔","primary":true}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Đổng Khiết","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"董潔，1980 年 4 月 19 日出生於遼寧省大聯市，畢業於中國人民解放軍藝術學院舞蹈系，中國內地影視女演員。\n\n2000 年，因參加央視春晚開始受到關注；同年，被導演張藝謀選中出演電影《幸福時光》，她憑藉該劇獲得第 7 屆中國電影華表獎電影新人獎及第 47 屆西班牙巴利亞多利德國際電影節最佳女演員獎。2003 年，其主演的民國愛情劇《金粉世家》取得央視年度收視冠軍，董潔個人也憑藉該劇開始在影視領域嶄露頭角；同年，她還憑藉愛情片《地下鐵》提名第 27 屆大眾電影百花獎最佳女演員。2015 年，因出演都市家庭輕喜劇《虎媽貓爸》提名第 22 屆上海電視節白玉蘭獎最佳女配角 。2017 年，拍攝古裝宮鬥劇《如懿傳》和古裝歷史劇《三國機密》。\n\n2018 年，在東方衞視《新舞林大會》總決賽中勝出，獲得總冠軍。","name":"董潔","primary":false}}]}},"person_3653494_translations":{"at":1774377106312,"data":{"id":3653494,"translations":[{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"神田聖司","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Masakazu Kanda","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"神田聖司","primary":false}}]}},"person_1094134_translations":{"at":1774377106789,"data":{"id":1094134,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Actor, musician, dancer and songwriter Kolton Stewart was born in Toronto, Canada and has had a keen interest in performing from an early age. As a TV actor, he is well known for his role on the hit Netflix/YTV television series \"Some Assembly Required\" playing the role of Jarvis, and as Carter Vaughn in the hit Crave series \"Heated Rivalry.\" He won \"Best Performance in a TV Series - Leading Young Actor\" at the 36th Annual Young Artist Awards (YAA) in Los Angeles, joining the likes of Brad Pitt, Zac Efron, and Leonardo DiCaprio as a recipient of the prestigious award.\n\nWhen he was 13 years old he began making YouTube Videos and it caught the eye of Ellen DeGeneres. Kolton was asked by Ellen DeGeneres to perform on her show with his friend Myles in 2012 after she saw his first ever YouTube video, singing a cover of \"I Won't Give Up\" by Jason Mraz which went viral, garnering hundreds of thousands of views in its first week.\n\nKolton has gone on to have an illustrious film/TV career with credits including Disenchanted (the sequel to Enchanted), Sneakerella, My Life With The Walter Boys, Locke and Key, The Expanse and My Big Fat Greek Wedding 2. Kolton is also a theatre actor with credits including Disney's The Lion King as Young Simba on the Broadway National Tour, and playing the lead role of Roger in RENT at the world renowned Stratford Shakespeare Festival in 2023.","name":"Kolton Stewart","primary":true}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"קולטון סטיוארט","primary":false}}]}},"person_2588506_translations":{"at":1774377109368,"data":{"id":2588506,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Jay Lycurgo (born 6 February 1998) is an English actor. He is known for his roles as Tim Drake in Titans (2021–2023), Nathan Byrne in the Netflix series The Bastard Son & The Devil Himself (2022), and as a gang member in The Batman (2022).\n\nDescription above from the Wikipedia article Jay Lycurgo, licensed under CC-BY-SA, full list of contributors on Wikipedia","name":"Jay Lycurgo","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"GR","iso_639_1":"el","name":"ελληνικά","english_name":"Greek","data":{"biography":"","name":"","primary":false}