ูทิศ สตรีวิทยา 2 ต่อมาเข้าศึกษาในระดับปริญญาตรีที่​ คณะนิติศาสตร์ มหาวิทยาลัยศรีปทุม เพียง 1 ปีการศึกษา ปัจจุบันได้ย้ายมาศึกษาที่ คณะศิลปกรรมศาสตร์ มหาวิทยาลัยศรีนครินทรวิโรฒ สาขาศิลปะการแสดง เอกการแสดงและกำกับการแสดง","name":"รัตนวดี วงศ์ทอง","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"拉塔纳瓦迪·旺通","primary":false}},{"iso_3166_1":"MX","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Rattanawadee Wongthong","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"拉塔納瓦迪·旺通","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"ミム・ラッタナワディー","primary":false}}]}},"person_3970120_translations":{"at":1774377073107,"data":{"id":3970120,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"许翔，中国内地男演员。1994年9月30日生于江西。毕业于少林寺塔沟武术学校。技能特长：三节棍、九节鞭、枪、蛇拳、马术、绘画。出演乌尔善导演电影《封神三部曲》；参演电影《征途》；参演徐纪周导演电视剧《特战荣耀》饰阿莱一角（合作演员：杨洋、李一桐、蒋璐霞）。","name":"许翔","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Xu Xiang","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"許翔","primary":false}}]}},"person_1286328_translations":{"at":1774377073538,"data":{"id":1286328,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Haley Lu Richardson (born March 7, 1995) is an American actress. Following early television roles on the Disney Channel sitcom Shake It Up (2013) and the ABC Family supernatural drama Ravenswood (2013–2014), she received recognition for her roles in the critically acclaimed coming-of-age film The Edge of Seventeen (2016) and the psychological horror film Split (2016). She went on to garner a nomination for the Gotham Independent Film Award for Best Actress for her breakthrough role in Columbus (2017), and earned critical praise for her roles as Maci in Support the Girls (2018) and Stella Grant in Five Feet Apart (2019).","name":"Haley Lu Richardson","primary":true}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"Haley Lu Richardson est une actrice américaine de cinéma et de télévision, surtout connue pour ses rôles principaux comme Maggie Townsend dans le long métrage \"The Bronze\" et comme Casey dans le film indépendant \"Columbus\".","name":"","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Haley Lu Richardson (* 7. März 1995) ist eine US-amerikanische Schauspielerin. Nach frühen Fernsehrollen in der Disney-Channel-Sitcom Shake It Up (2013) und der ABC-Family-Serie Ravenswood (2013–2014) spielte sie in dem Coming-of-Age-Film The Edge of Seventeen (2016) und dem Psychothriller Split (2016) mit.\n\nRichardson hatte ihren Durchbruch in dem Independent-Drama Columbus (2017), für das sie eine Nominierung für den Gotham Independent Film Award als beste Darstellerin erhielt. Sie spielte weiterhin in von Kritikern gefeierten Independent-Filmen wie Support the Girls (2018), Unpregnant (2020) und After Yang (2022). Außerdem spielte sie in der zweiten Staffel der HBO-Anthologieserie The White Lotus (2022) und in der romantischen Komödie Love at First Sight (2023) mit.\n\nQuelle: Wikipedia","name":"","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"헤일리 루 리처드슨","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"💥Хейли Лу Ричардсон. Родилась в 1995-ом году в Финиксе, Аризона, США. Росла в семье со старшей сестрой. Отец работал архитектором гольф полей, а мать была графическим дизайнером. Училась дома. Работает актрисой. Личную жизнь предпочитает держать в тайне\n\n🏆Главные награды🏆: Номинация на Золотой глобус (2023) [Белый лотос]\n\n🎬Главные проекты🎬: «Белый лотос» (2022), «Колумбус» (2017), «В метре друг от друга» (2019), «Сплит» (2016), «Пять футов друг от друга» (2019)\n\n⭐Интересный факт⭐: Хейли с детства занимается танцами и переехала в Лос-Анджелес ради карьеры, не имея актёрских связей и поддержки индустрии","name":"Хейли Лу Ричардсон","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"ヘイリー・ルー・リチャードソン","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"היילי לו ריצ'רדסון","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"海莉·卢·理查森（Haley Lu Richardson，1995年3月7日-），美国女演员。在迪士尼频道情景喜剧《Shake It Up》（2013 年）和 ABC 家庭超自然剧《Ravenswood》（2013-2014 年）中担任早期电视角色后，她因在广受好评的成长电影《十七岁的边缘》（2016 年）和心理恐怖片《分裂》（2016 年）中的角色而获得认可。她凭借在《哥伦布》（2017 年）中的突破性角色获得了哥谭独立电影奖最佳女主角提名，并因在《支持女孩》（2018 年）中饰演梅西和在《五英尺之隔》（2019 年）中饰演斯特拉·格兰特而获得评论界的赞誉。","name":"海莉·卢·理查森","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Гейлі Лу Річардсон","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"海莉·盧·理查森（Haley Lu Richardson，1995 年 3 月 7 日-），美國女演員。在迪士尼頻道情景喜劇《Shake It Up》（2013 年）和 ABC 家庭超自然劇《Ravenswood》（2013 - 2014 年）中擔任早期電視角色後，她因在廣受好評的成長電影《十七歲的邊緣》（2016 年）和心理恐怖片《分裂》（2016 年）中的角色而獲得認可。她憑藉在《哥倫布》（2017 年）中的突破性角色獲得了哥譚獨立電影獎最佳女主角提名，並因在《支持女孩》（2018 年）中飾演美斯和在《五英尺之隔》（2019 年）中飾演斯特拉·格蘭特而獲得評論界的讚譽。","name":"海莉·盧·理查森","primary":false}}]}},"person_2011101_translations":{"at":1774377085609,"data":{"id":2011101,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Prince Kanwaljit Singh","primary":false}},{