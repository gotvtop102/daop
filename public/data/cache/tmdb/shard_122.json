":"Swedish","iso_639_1":"sv","name":"svenska"}],"status":"Released","tagline":"","title":"Giá Trị Tình Cảm","video":false,"vote_average":7.531,"vote_count":692}},"person_70106_translations":{"at":1773688720791,"data":{"id":70106,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Nicholas Tse Ting-Fung (Chinese: 謝霆鋒, born 29 August 1980) is a Hong Kong singer-songwriter, actor and musician, and son of actor Patrick Tse. He is a member of the Emperor Entertainment Group. Throughout his career, he has been a singer, an actor, a director, a producer, and a composer. He originally learned martial arts for the screen and television, which he continues to practice. He has won the Hong Kong Film Award for Best Actor (2011).","name":"Nicholas Tse Ting-Fung","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"사정봉","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"谢霆锋(1980年8月29日)，中国香港著名的国语、粤语流行歌手，演员，音乐人（作曲、作词、编曲和制作人）。谢霆锋是80后歌手中最早在华语乐坛取得突破而名声大噪且波及大江南北和两岸三地的超级偶像，他的流行引发了新世纪的偶像热潮，结束了垄断华语乐坛近十年的“四大天王”时代，成为当今亚洲地区最有影响力的标志性偶像人物。他也是近年来在华语影坛取得成功的偶像巨星，是亚洲地区新生代的偶像代表人物，被誉为“亚洲天王巨星”、“中国首席偶像”、“新生代领军人物”。","name":"谢霆锋","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"Tạ Đình Phong (Nicholas Tse) là nam ca sĩ, diễn viên, nhạc sĩ, nhà sản xuất âm nhạc nổi tiếng người Hồng Kông. Tạ Đình Phong là một thành viên của Tập đoàn Giải trí Anh Hoàng (Emperor Entertainment Group). Tạ Đình Phong chính thức gia nhập làng giải trí với tư cách là ca sĩ vào năm 1996. Ban đầu anh đam mê học võ thuật qua TV và sau đó tự mình luyện tập. Phim điện ảnh đầu tay năm 1998 là phim hình sự Thời niên thiếu Trần Hào Nam đã giúp anh giành giải trong hạng mục Nam diễn viên mới xuất sắc nhất tại Giải thưởng Phim Hồng Kông. Năm 2003, anh thành lập công ty Post Production Office Limited, một trong những công ty có ảnh hưởng lớn nhất tại Hồng Kông trong lĩnh vực cung cấp phim điện ảnh, trò chơi điện tử và quảng cáo. Công ty này thu về hơn 1 tỷ đô la Hồng Kông mỗi năm. Năm 2011, anh được trao giải Nam diễn viên xuất sắc nhất tại Giải thưởng Điện ảnh Hồng Kông.","name":"Tạ Đình Phong","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"謝霆鋒","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"謝霆鋒 (1980 年 8 月 29 日)，香港著名的國語、粵語流行歌手，演員，音樂人（作曲、作詞、編曲和製作人）。謝霆鋒是 80 後歌手中最早在華語樂壇取得突破而名聲大噪且波及大江南北和兩岸三地的超級偶像，他的流行引發了新世紀的偶像熱潮，結束了壟斷華語樂壇近十年的“四大天王”時代，成為當今亞洲地區最有影響力的標誌性偶像人物。他也是近年來在華語影壇取得成功的偶像巨星，是亞洲地區新生代的偶像代表人物，被譽為“亞洲天王巨星”、“中國首席偶像”、“新生代領軍人物”。","name":"謝霆鋒","primary":true}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"Nicholas Tse Ting-Fung","primary":false}}]}},"tv_65930_credits":{"at":1773688723064,"data":{"cast":[{"adult":false,"gender":2,"id":1325962,"known_for_department":"Acting","name":"Daiki Yamashita","original_name":"山下大輝","popularity":1.5386,"profile_path":"/rQNdJdZewk7VGP16ZNbpfJ9ZeMd.jpg","character":"Izuku Midoriya (voice)","credit_id":"57b8b9c79251413f06000107","order":0}],"crew":[{"adult":false,"gender":2,"id":4306477,"known_for_department":"Sound","name":"Hideo Masu","original_name":"升秀夫","popularity":0.1637,"profile_path":"/sl0Jwjc7lHba1usJlLK7xmejnMW.jpg","credit_id":"68d80f359dfaa2792dc75b84","department":"Sound","job":"Theme Song Performance"},{"adult":false,"gender":2,"id":4306474,"known_for_department":"Sound","name":"Motoo Fujiwara","original_name":"藤原基央","popularity":0.3347,"profile_path":"/3zDGoJt9wrFpc25gbntJMHTgME6.jpg","credit_id":"68d80f40c99913e8d0bb0408","department":"Sound","job":"Theme Song Performance"},{"adult":false,"gender":2,"id":4306476,"known_for_department":"Sound","name":"Yoshifumi Naoi","original_name":"直井