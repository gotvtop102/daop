07,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Montana Jordan (born March 8, 2003) is an American actor. He is best known for his role as Georgie Cooper Jr. in The Big Bang Theory franchise, appearing as a series regular in Young Sheldon (2017–2024). He reprises the role as a lead actor in the spin-off Georgie & Mandy's First Marriage (2024–present).","name":"Montana Jordan","primary":true}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Montana Jordan es un actor estadounidense conocido por interpretar a George Cooper, hermano de Sheldon Cooper en la serie El Joven Sheldon.","name":"","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Montana Jordan ist ein US-amerikanischer Schauspieler. Er ist bekannt für seine Rolle als Georgie Cooper in der Serie Young Sheldon.\n\nQuelle: Wikipedia","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"蒙大拿·喬丹","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"蒙大拿·州约旦","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"蒙大拿·喬丹","primary":false}}]}},"person_1251442_translations":{"at":1773688738752,"data":{"id":1251442,"translations":[{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"声優、作家。1978年4月26日生まれ、岐阜県出身。A型。アニメ『DD北斗の拳』のケンシロウや、『イナズマイレブン』の立向居勇気、『東京喰種トーキョーグール』の滝澤政道など、人気作品の声を務める。漫画原作者 、作家としても活躍。\n\n特技：パントマイム　日舞（深水流）\n\n趣味：写真　釣り　自転車　パソコン　ゲーム","name":"立花慎之介","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Shinnosuke Tachibana (立花 慎之介, Tachibana Shinnosuke, April 26, 1978) is a Japanese voice actor, singer, narrator and mystery writer from Gifu. He is married to voice actress Ao Takahashi and is the CEO of Black Ship.\n\nAfter gratudating from Aoni Juku Tokyo School 18th term he joined Production Baobab. In 2003, he made his voice actor debut as Kyo in the TV anime E's Otherwise. He belonged to Production Baobab until May 2011. In June of the same year he joined Axl One. On January 5, 2017, he reported his marriage to Ao Takahashi on his blog. On March 31, 2018, he left Axl One to establish, together with Jun Fukuyama, their own agency: Black Ship.","name":"Shinnosuke Tachibana","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"立花慎之介，日本男性聲優，出身於岐阜縣。過去曾隸屬於 Production baobab，在2011年6月1日移籍於 AXL ONE，並於2018年3月31日離開，移籍到與福山潤一同創立的BLACK SHIP。在2017年1月1日與聲優高梁碧結婚。","name":"立花慎之介","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"타치바나 신노스케","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"ชินโนสึเกะ ทาจิบานะ","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Šinnosuke Tačibana","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"立花慎之介（日语：立花 慎之介／たちばな しんのすけ Tachibana Shinnosuke，1978年4月26日—），日本男性声优，出身于岐阜县。过去曾隶属于Production baobab，在2011年6月1日移籍于AXL ONE，并于2018年3月31日离开，移籍到与福山润一同创立的BLACK SHIP。在2017年1月1日与声优高梁碧结婚。","name":"立花慎之介","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Shinnosuke Tachibana","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"立花慎之介，日本男性聲優，出身於岐阜縣。過去曾隸屬於 Production baobab，在 2011 年 6 月 1 日移籍於 AXL ONE，並於 2018 年 3 月 31 日離開，移籍到與福山潤一同創立的 BLACK SHIP。在 2017 年 1 月 1 日與聲優高梁碧結婚。","name":"立花慎之介","primary":fa