tive Producer"},{"adult":false,"gender":2,"id":1934902,"known_for_department":"Directing","name":"Derek Doneen","original_name":"Derek Doneen","popularity":0.1677,"profile_path":null,"credit_id":"688923c9b82354c481de1288","department":"Production","job":"Co-Executive Producer"},{"adult":false,"gender":0,"id":5594471,"known_for_department":"Production","name":"Mike Langer","original_name":"Mike Langer","popularity":0,"profile_path":null,"credit_id":"688923d47750ce806aa7d09c","department":"Production","job":"Co-Executive Producer"}]}},"tv_262251_keywords":{"at":1773689207278,"data":{"id":262251,"results":[{"name":"playing cards","id":287886},{"name":"henshin heroes","id":291531},{"name":"tokusatsu","id":317204}]}},"person_2555028_translations":{"at":1773689210712,"data":{"id":2555028,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Michael Kupfer-Radecky","primary":true}}]}},"person_1225575_translations":{"at":1773689212819,"data":{"id":1225575,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"John Albert Elway Jr. (born June 28, 1960) is an American former professional football quarterback who spent his entire 16-year career with the Denver Broncos of the National Football League (NFL). Following his playing career, he then spent 11 years with the Broncos in various front office positions, eventually being promoted to general manager. Elway and former backup quarterback and head coach Gary Kubiak are the only individuals to be associated with all three of the Broncos' Super Bowl wins.\n\nDescription above from the Wikipedia article John Elway, licensed under CC-BY-SA, full list of contributors on Wikipedia","name":"John Elway","primary":true}}]}},"person_41088_translations":{"at":1773689215352,"data":{"id":41088,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Jason Jordan Segel (born January 18, 1980) is an American actor. He is best known for his role as Marshall Eriksen in the CBS sitcom How I Met Your Mother from 2005 to 2014. He began his career with director and producer Judd Apatow on the television series Freaks and Geeks (1999–2000) and Undeclared (2001–2002) before gaining prominence for his leading roles in various successful comedy films in which he has starred, written, and produced.\n\nSegel has starred in many comedic films such as Knocked Up (2007), Forgetting Sarah Marshall (2008), I Love You, Man (2009), Bad Teacher (2011), The Five-Year Engagement (2012), This Is 40 (2012), and Sex Tape (2014), as well as family films such as Despicable Me (2010), and The Muppets (2011). For his role as David Foster Wallace in The End of the Tour (2015) he received a nomination for the Independent Spirit Award for Best Male Lead. He also starred in the dramas Jeff, Who Lives at Home (2011), The Discovery (2017), Our Friend (2019), and Windfall (2022).\n\nIn 2023, he began starring as a therapist in the Apple TV+ series Shrinking, which he also co-created alongside Bill Lawrence and Brett Goldstein. For his performance he earned a Primetime Emmy Award for Outstanding Lead Actor in a Comedy Series nomination.","name":"Jason Segel","primary":true}},{"iso_3166_1":"GR","iso_639_1":"el","name":"ελληνικά","english_name":"Greek","data":{"biography":"","name":"Τζέισον Σίγκελ","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Jason Jordan Segel (* 18. Januar 1980 in Los Angeles, Kalifornien) ist ein US-amerikanischer Schauspieler und Drehbuchautor. Bekannt wurde er durch die Rolle des Marshall Eriksen in der US-Sitcom How I Met Your Mother.\n\nVon 1999 bis 2000 gelang Segel der Durchbruch in der Fox-Fernsehserie Voll daneben, voll im Leben, in der er den kiffenden Nick Andopolis verkörperte. In den Jahren 2001 und 2002 spielte er in sieben von 17 Episoden der Serie American Campus – Reif für die Uni? mit, dabei stellte er den Exfreund von Lizzie Exley, Eric, dar. Von 2005 bis 2014 spielte er in der US-Sitcom How I Met Your Mother des Fernsehsenders CBS die Rolle des Juristen Marshall Eriksen; die Rolle in der überaus erfolgreichen Serie machte ihn international bekannt. Des Weiteren schrieb er das Drehbuch zu Nie wieder Sex mit der Ex und dem Blockbuster Männertrip. Für die Kinofilme Die Muppets und Fast verheiratet schrieb Segel jeweils das Drehbuch und spielte die männliche Hauptrolle. Der von ihm gesungene Song Man or Muppet gewann einen Oscar.\n\nFür eine der wenigen ernsten Rollen, seine Hauptrolle in The End of the Tour, erhielt er mehrere Nominierungen für Filmpreise.\n\nQuelle: Wikipedia","name":"","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"제이슨 시걸","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"杰森·席格尔（Jason Segel），1980年1月18日出生于美国加利福尼亚州洛杉矶，演员、编剧、制片人。\n\n1999年，他在美剧《怪胎与书呆》里成为常驻角色 ，次年凭借此剧获得青年艺人大奖电视剧最佳年轻演员群戏的提名。2002年，主演了喜剧电影《懒虫陷情记》 。2005年，开始在CBS美剧《老爸老妈的浪漫史》里饰演男主角Marshall Eriksen，并出演到2014年的最后一季。2008年，和克里斯汀·贝尔一同主演了喜剧电影《忘掉莎拉·马歇尔》，他在这部电影中首次担任编剧。2011年，出演电影《坏老师》；同年自编自演了迪士尼的音乐动画电影《布偶大电影》，在片饰演男主角Gary。2012年，和艾米莉·布朗特一同主演了电影《五年之约》。2014年，自编自演了R级喜剧《性爱录像带》。2015年，出演电影《旅程终点》。","name":"杰森·席格尔","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"ג'ייסון סיגל","primary":false}},{"iso_3166_1":"RS","iso_639_1":"sr","name":"Srpski","english_name":"Serbian","data":{"biography":"","name":"Џејсон Сигел","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"💥Джейсон Джордан Сигел. Родился в 1980-ом году в Лос-Анджелесе, Калифорния, США. Рос в семье с 2-мя старшими братьями. Отец работал адвокатом, а мать была учительницей. Учился в школе Гарвард-Уэстлейк в Лос-Анджелесе. Работает актёром, сценаристом, режиссёром и продюсером. Личную жизнь предпочитает держать в тайне\n\n🎬Главные проекты🎬: «Как я встретил вашу маму» (2005), «В пролёте» (2008), «Немножко беременна» (2007), «Домашнее видео» (2014), «Очень плохая училка» (2011)\n\n⭐Интересный факт⭐: Джейсон сам написал сценарий фильма «В пролёте», вложив в историю личный опыт расставания, а многие сцены были сняты с минимальными правками прямо по его тексту","name":"Джейсон Сигел","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Джейсон Сіґел","primary":false}},{"iso_3166_1":"IN","iso_639_1":"ta","name":"தமிழ்","english_name":"Tamil","data":{"biography":"","name":"ஜேசன் செகெல்","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"เจสัน ซีเจล","primary":false}},{"iso_3166_1":"LV","iso_639_1":"lv","name":"Latviešu","english_name":"Latvian","data":{"biography":"","name":"Džeisons Sīgels","primary":false}},{"iso_3166_1":"IN","iso_639_1":"mr","name":"","english_name":"Marathi","data":{"biography":"","name":"जेसन सीगेल","primary":false}},{"iso_3166_1":"IR","iso_639_1":"fa","name":"فارسی","english_name":"Persian","data":{"biography":"","name":"جیسون سیگل","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"ジェイソン・シーゲル","primary":false}},{"iso_3166_1":"IN","iso_639_1":"hi","name":"हिन्दी","english_name":"Hindi","data":{"biography":"","name":"जेसन सेगल","primary":false}},{"iso_3166_1":"GE","iso_639_1":"ka","name":"ქართული","english_name":"Georgian","data":{"biography":"","name":"ჯეისონ სიგელი","primary":false}},{"iso_3166_1":"SG","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"杰森·席格尔","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"傑森·席格爾","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"積遜·斯高（Jason Segel），1980 年 1 月 18 日出生於美國加利福尼亞州洛杉磯，演員、編劇、製片人。\n\n1999 年，他在美劇《怪胎與書呆》裏成為常駐角色 ，次年憑藉此劇獲得青年藝人大獎電視劇最佳年輕演員群戲的提名。2002 年，主演了喜劇電影《懶蟲陷情記》 。2005 年，開始在 CBS 美劇《老爸老媽的浪漫史》裏飾演男主角 Marshall Eriksen，並出演到 2014 年的最後一季。2008 年，和克里斯汀·貝爾一同主演了喜劇電影《忘掉莎拉·馬歇爾》，他在這部電影中首次擔任編劇。2011 年，出演電影《MISS 愛教壞》；同年自編自演了迪士尼的音樂動畫電影《慈善星輝布公仔》，在片飾演男主角 Gary。2012 年，和艾米莉·布朗特一同主演了電影《五年之約》。2014 年，自編自演了 R 級喜劇《春光乍網》。2015 年，出演電影《旅程終點》。","name":"積遜·斯高","primary":false}},{"iso_3166_1":"SA","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"","name":"جيسون سيغل","primary":false}},{"iso_3166_1":"BG","iso_639_1":"bg","name":"български език","english_name":"Bulgarian","data":{"biography":"","name":"Джейсън Сийгъл","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"Jason Jordan Segel (nato il 18 gennaio 1980) è un attore americano. È noto soprattutto per il suo ruolo di Marshall Eriksen nella sitcom CBS How I Met Your Mother dal 2005 al 2014. Ha iniziato la sua carriera con il regista e produttore Judd Apatow nelle serie televisive Freaks and Geeks (1999–2000) e Undeclared (2001–2002), prima di guadagnare notorietà per i suoi ruoli da protagonista in vari film comici di successo in cui ha recitato, scritto e prodotto.\n\nSegel ha recitato in molti film comici come Knocked Up (2007), Forgetting Sarah Marshall (2008), I Love You, Man (2009), Bad Teacher (2011), The Five-Year Engagement (2012), This Is 40 (2012) e Sex Tape (2014), oltre a film familiari come Cy Picy Me (2010) e The Muppets (2011). Per il suo ruolo di David Foster Wallace in The End of the Tour (2015) ha ricevuto una nomination all'Independent Spirit Award come Miglior Protagonista Maschile. Ha inoltre recitato nei drammi Jeff, Who Lives at Home (2011), The Discovery (2017), Our Friend (2019) e Windfall (2022).\n\nNel 2023 ha iniziato a recitare come terapeuta nella serie Shrinking di Apple TV+, che ha anche co-creato insieme a Bill Lawrence e Brett Goldstein. Per la sua interpretazione ha ricevuto una nomination al Primetime Emmy Award come miglior attore protagonista in una serie comica.","name":"","primary":false}}]}},"person_1431569_translations":{"at":1773689216921,"data":{"id":1431569,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"John Jabaley","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Джон Джебели","primary":false}}]}},"person_4024001_translations":{"at":1773689217252,"data":{"id":4024001,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Tuss Thotsawat Sing-uppo is an actor, singer and former bartender from Udon Thani. After graduating from Udonpittayanukul School, he went on to study in the Faculty of Law at Khon Kaen University.","name":"Thotsawat Singuppo","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"ทศวรรษ สิงอุปโป","primary":true}}]}},"tv_273112_detail_vi-VN":{"at":1773689220599,"data":{"adult":false,"backdrop_path":"/x6QjTRPtCu0FMtf8FFts7yZSldO.jpg","created_by":[],"episode_run_time":[45],"first_air_date":"2025-12-29","genres":[{"id":18,"name":"Phim Chính Kịch"},{"id":9648,"name":"Phim Bí Ẩn"},{"id":80,"name":"Phim Hình Sự"}],"homepage":"https://v.youku.com/v_show/id_XNjQzMzUyNTgxMg==.html","id":273112,"in_production":false,"languages":["zh"],"last_air_date":"2026-01-09","last_episode_to_air":{"id":6787978,"name":"Episode 21","overview":"","vote_average":10,"vote_count":2,"air_date":"2026-01-09","episode_number":21,"episode_type":"finale","production_code":"","runtime":49,"season_number":1,"show_id":273112,"still_path":"/yY3HjSyS4BcIHbbQJ7uyiAAoPvs.jpg"},"name":"Phá Kén","next_episode_to_air":null,"networks":[{"id":1419,"logo_path":"/w2TeR3fvPZ9a617tNIF1oOfyPtk.png","name":"Youku","origin_country":"CN"}],"number_of_episodes":21,"number_of_seasons":1,"origin_country":["CN"],"original_language":"zh","original_name":"剥茧","overview":"\"Phá Kén\" kể về pháp y trẻ tuổi nhất của Cục công an Li Thành, Tề Tư Triết (La Vân Hi). Sau một vụ tai nạn giao thông, anh mất đi bạn gái Du Phi nhưng lại phát hiện đằng sau vụ việc tưởng chừng như là tai nạn ấy có thể ẩn giấu một bàn tay bí ẩn.Để điều tra sự thật, Tề Tư Triết gia nhập đội pháp y hình sự của Cục Công an Hà Thành và bị cuốn vào hàng loạt vụ án kỳ lạ đầy ám ảnh. Các nạn nhân đã qua đời từ lâu được tìm thấy bị bao phủ bởi vô số tơ nhện, trong khi những thi thể mất tích lại xuất hiện trong phòng thí nghiệm, ngâm trong dung dịch formalin...Trong quá trình điều tra, anh hợp tác chặt chẽ với Chúc Thanh Việt (Lưu Nhã Sắt) và Hàn Phong (Giang Kỳ Lâm). Bộ ba cùng nhau “phá kén” từng vụ án quái lạ và dần hé lộ những bí mật đáng sợ. Đồng thời, vụ án chất cấm “Kim Cương Nguyên Chất” liên quan đến cái chết của Du Phi năm xưa cũng dần lộ diện, chỉ là phần nổi của tảng băng chìm...","popularity":2.7068,"poster_path":"/yeKMKaSvkZjAzUhrInVCTASqQIs.jpg","production_companies":[{"id":69484,"logo_path":"/2xtmvbEse87LM7OJXVksv7DToZx.png","name":"Alibaba Pictures Group","origin_country":"CN"},{"id":48460,"logo_path":"/7m3BMwdstKRqw7qg5vSYW2S0HrR.png","name":"Youku","origin_country":"CN"}],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"seasons":[{"air_date":"2025-12-29","episode_count":21,"id":421243,"name":"Season 1","overview":"","poster_path":"/pJTNJWjQcGylDj2K8wPGJQ6T1kB.jpg","season_number":1,"vote_average":9.8}],"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Ended","tagline":"","type":"Scripted","vote_average":8.875,"vote_count":8}}}}