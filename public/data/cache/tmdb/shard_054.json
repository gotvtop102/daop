imary":true}}]}},"person_2729109_translations":{"at":1774373057847,"data":{"id":2729109,"translations":[{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"รัตท์ริชา ประภากิติ","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Ciize Rutricha Phapakithi is a Thai actress. In 2022, Ciize received a bachelor's degree in Chinese for International Trade from the Chinese International College at Bangkok University. Her nickname, Ciize, comes from the Chinese \"Xi Shi\" (张西施 ), one of the legendary Four Beauties. Her father chose it to influence her to grow up as beautiful as the Four Beauties. Her younger sister, \"Cherry\" Phitsinee Saejung (or Cheriie) is a singer under the label Labo.\n\nSince she began in the entertainment industry in 2015, Ciize is a talent under GMMTV. She was previously the main dancer of the project girl group SIZZY (ซิสซี่; formerly SISSY) formed by GMMTV in 2019. In 2023, they signed with Riser Music although they never released music under the label, ultimately disbanding on October 16, 2024.\n\nOn July 6, 2023, Ciize changed her name to Rutricha Phapakithi as someone else shared her exact birth name.","name":"Rutricha Phapakithi","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Ciize Rutricha Phapakithi","primary":false}}]}},"person_4004415_translations":{"at":1774373068019,"data":{"id":4004415,"translations":[{"iso_3166_1":"SA","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"ممثل فلسطيني، مواليد 4 ابريل 1977. شارك في العديد من المسرحيات  كما شارك في العديد من حلقات المسلسل الكوميدي الشهير \"وطن ع وتر\"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Mohammed Titi","primary":false}},{"iso_3166_1":"AE","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"","name":"Mohammed Titi","primary":true}}]}},"person_5108943_translations":{"at":1774373077768,"data":{"id":5108943,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"李镇泽","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Li Zhenze","primary":false}}]}},"person_1683103_translations":{"at":1774373080539,"data":{"id":1683103,"translations":[{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Emma Johnson","primary":true}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Эмма Джонсон","primary":false}}]}},"person_150125_translations":{"at":1774373085457,"data":{"id":150125,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Ju Ji-hoon is a South Korean actor. He began as a model but transitioned into acting with his breakout role as Crown Prince Lee Shin in 2006's Princess Hours.  Ju Ji-hoon is perhaps most widely known for his role Haewonmak in the box office smash hit films Along with the Gods: The Two Worlds and Along with the Gods: The Last 49 days and his role of Prince Yi Chang in the Netflix Historical Zombie TV series Kingdom.","name":"Ju Ji-hoon","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"Joo Ji Hoon est un acteur et mannequin sud-coréen.\n\nIl commença sa carrière en tant que modèle en 2003 pour plusieurs marques telles Calvin Klein, Levi's ou encore Reebok. Son talent pour le mannequinat lui vaudra plusieurs récompenses.","name":"Ji-hoon Ju","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"주지훈","primary":true}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Ju Ji-hoon ((16 de mayo de 1982) es un actor y modelo surcoreano.\n\nSu primer rol en la actuación fue como el príncipe heredero Lee Shin en el drama Princess Hours, transmitido en 2006. Ha actuado en varias películas como Antique (2008), I Am a King (2012) y Marriage Blue (2013). Es conocido además por su papel como el príncipe heredero Lee Chang en la serie de Netflix Kingdom.","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"朱智勋，韩国男演员。1982年5月16日出生于韩国首尔，毕业于韩国京畿大学。\n\n2006年因出演电视剧《宫》中“李信”一角而走红 ，并凭此获2006年MBC演技大赏“最佳男新人奖” 。2007年出演人气剧集《魔王》再次受到人们关注。2008年1月18日，出席《2007亚洲模特颁奖礼》，获得“模特明星奖”。2008年11月，参演电影《西洋古董洋果子店》 ，并以此获得第45届韩国百想艺术大赏电影类“最佳人气奖” 。2010年，出演韩国国防部为纪念朝鲜战争60周年而特别制作的音乐剧《生命的航海》 ，以此获得了“年度音乐剧之星”奖，并受到了国防部总长的嘉奖 。2015年12月31日，因剧集《假面》获得韩国SBS演技大奖中篇剧集优秀男演员奖和10代明星奖。2017年出演大热电影《与神同行》，在其中饰演武力高强毒舌搞笑的解怨脉一角，受到了观众的喜爱。","name":"朱智勋","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"朱智勛","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"チュ・ジフン","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Чжу Чжи Хун","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"朱智勳，韓國男演員。1982 年 5 月 16 日出生於韓國首爾，畢業於韓國京畿大學。\n\n2006 年因出演電視劇《宮》中“李信”一角而走紅 ，並憑此獲 2006 年 MBC 演技大賞“最佳男新人獎” 。2007 年出演人氣劇集《魔王》再次受到人們關注。2008 年 1 月 18 日，出席《2007 亞洲模特頒獎禮》，獲得“模特明星獎”。2008 年 11 月，參演電影《西洋古董洋果子店》 ，並以此獲得第 45 屆韓國百想藝術大賞電影類“最佳人氣獎” 。2010 年，出演韓國國防部為紀念朝鮮戰爭 60 週年而特別製作的音樂劇《生命的航海》 ，以此獲得了“年度音樂劇之星”獎，並受到了國防部總長的嘉獎 。2015 年 12 月 31 日，因劇集《假面》獲得韓國 SBS 演技大獎中篇劇集優秀男演員獎和 10 代明星獎。2017 年出演大熱電影《與神同行》，在其中飾演武力高強毒舌搞笑的解怨脈一角，受到了觀眾的喜愛。","name":"朱智勳","primary":false}}]}},"person_1327616_translations":{"at":1774373089634,"data":{"id":1327616,"translations":[{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Odine Johne","primary":false}},{"iso_3166_1":"CH","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Odine Johne","primary":true}}]}},"person_106951_translations":{"at":1774373094466,"data":{"id":106951,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Paul Lazenby","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Пол Лэзенби","primary":false}}]}},"person_215055_translations":{"at":1774373097008,"data":{"id":215055,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Yeun Sang-Yeop (Korean: 연상엽; born December 21, 1983), known professionally as Steven Yeun (/jʌn/ YUHN), is an American actor. Yeun initially became famous for playing Glenn Rhee in The Walking Dead (2010–2016). He earned critical acclaim for the films Burning (2018) and  Minari (2020). The latter earned him a nomination for the Academy Award for Best Actor, making him the first Asian American actor to be nominated. Time magazine named him one of the 100 most influential people in the world in 2021. In 2023, he starred in the dark comedy series Beef (2023), for which he won two Primetime Emmy Awards and a Golden Globe Award.\n\nYeun has also appeared in the films Okja (2017), Sorry to Bother You (2018), The Humans (2021) and Nope (2022). He has also voiced main characters in animated television series such as Voltron: Legendary Defender (2016–2018), Tales of Arcadia (2016–2021), Stretch Armstrong and the Flex Fighters (2017–2018), Final Space (2018–2021), Tuca & Bertie (2019–2022), and Invincible (2021–present).\n\nDescription above from the Wikipedia article Steven Yeun, licensed under CC-BY-SA, full list of contributors on Wikipedia.","name":"Steven Yeun","primary":true}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"스티븐 연","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"連相燁","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"史蒂文·元(Steven Yeun)，出生于首尔，在密歇根州长大的Yeun在进修心理学专业时，也开始了他的演艺生涯。Yeun参加过很多戏剧演出和电影的拍摄。\n\n另外，他还在热播剧《生活大爆炸》，以及喜剧片《我的名字叫杰瑞》中客串出演。在万圣节开播的美剧《行尸走肉》第一季中饰演格伦。","name":"史蒂文·元","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"Steven Yeun (hangul: 스티븐연; nascido com o nome coreano Yeun Sang-yeop (hangul: 연상엽; rr: Yeon Sang-yeop; MR: Yǒn Sangyǒp; Seul, 21 de dezembro de 1983) é um ator sul-coreano, naturalizado norte-americano, mais conhecido por ter feito o papel de Glenn Rhee na série The Walking Dead e o papel de Jacob Yi no filme Minari: Em Busca de Felicidade, pelo qual foi indicado ao Oscar de Melhor Ator Principal.\n\nSteven Yeun nasceu em Seul, na Coreia do Sul, filho de Je Yeun e June Yeun, também sul-coreanos. Seu pai era um arquiteto na Coreia do Sul antes de se mudar com sua família para Regina, no Canadá. Mais tarde, mudam-se para Michigan.\n\nSteven Yeun foi criado em Troy, em um lar cristão. Seus pais tinham duas lojas de cosméticos em Detroit. Steven Yeun recebeu um diploma de bacharel em psicologia, no College Kalamazoo, em 2005. Em Kalamazoo, ele conheceu a comediante Jordan Klepper, através da irmã de Klepper, e depois seguiram para Chicago, onde juntarem-se ao The Second City. Atualmente, reside em Los Angeles.","name":"","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Стивен Ян","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Steven Yeun (Koreanisch: 연상엽; geboren als Yeun Sang-yeop am 21. Dezember 1983) ist ein südkoreanisch-amerikanischer Schauspieler. Yeun erlangte zunächst Bekanntheit durch seine Rolle als Glenn Rhee in der Fernsehserie The Walking Dead (2010–2016). Später spielte er die Hauptrolle in Minari (2020) und war auch als ausführender Produzent tätig, wofür er große Anerkennung erhielt und für den Oscar als Bester Hauptdarsteller nominiert wurde.  Er war damit der erste asiatisch-amerikanische Schauspieler, der in dieser Kategorie nominiert wurde. Yeun war auch in den Filmen I Origins (2014), Okja (2017), Mayhem (2017), Burning (2018), Sorry to Bother You (2018) und Nope (2022) zu sehen und lieh Hauptfiguren in Fernsehserien wie Voltron: Legendary Defender (2016–2018), Tuca & Bertie (2019) und Invincible (2021-heute) seine Stimme, unter anderen.","name":"","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"Стівен Юн (кор. 연상엽; при народженні Юн Сан Йоп, 21 грудня 1983) — південнокорейсько-американський актор.\n\nСпочатку Юн став відомим завдяки ролі Ґленна Рі в телесеріалі «Ходячі мерці» (2010—2016). Пізніше він знявся та став виконавчим продюсером фільму «Мінарі» (2020), який приніс йому визнання критиків і номінацію на премію «Оскар» за найкращу чоловічу роль, ставши першим азіатсько-американським актором, номінованим у цій категорії.\n\nЮн також з'являвся у фільмах «I Origins» (2014), Okja (2017), Mayhem (2017), Burning (2018), Sorry Not (2018) і Nope (2022), а також озвучував головних героїв у таких телесеріалах, як «Вольтрон: Легендарний захисник» (2016–2018), Tuca & Bertie (2019) та Непереможний (2021-дотепер), серед інших.","name":"Стівен Юн","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"สตีเว่น ยอน","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"BY","iso_639_1":"be","name":"беларуская мова","english_name":"Belarusian","data":{"biography":"","name":"Стывен Йон","primary":false}},{"iso_3166_1":"IR","iso_639_1":"fa","name":"فارسی","english_name":"Persian","data":{"biography":"","name":"استیون ین","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"史蒂文·元 (Steven Yeun)，出生於首爾，在密歇根州長大的 Yeun 在進修心理學專業時，也開始了他的演藝生涯。Yeun 參加過很多戲劇演出和電影的拍攝。\n\n另外，他還在熱播劇《生活大爆炸》，以及喜劇片《我的名字叫傑瑞》中客串出演。在萬聖節開播的美劇《行屍走肉》第一季中飾演格倫。","name":"史蒂文·元","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"סטיבן יאון","primary":false}}]}},"person_4687612_translations":{"at":1774373099463,"data":{"id":4687612,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Andrew Tong","primary":true}}]}},"movie_521034_keywords":{"at":1774373102540,"data":{"id":521034,"keywords":[{"id":2105,"name":"garden"},{"id":9180,"name":"yorkshire"},{"id":13014,"name":"orphan"},{"id":15101,"name":"based on children's book"},{"id":158987,"name":"post war"},{"id":207883,"name":"1940s"}]}}}}