slations":{"at":1773491792228,"data":{"id":2709020,"translations":[{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Bruce was born and bred in the dirty soil of Chelsea New York. After graduating the original High School of Performing Arts and Carnegie Mellon he has been an actor, writer & director in film, TV and theater. Bruce is co founder of FBC Films which is committed to producing horror & sci fi with Asian & Black casts/crew. Their short film, \"Memorable Minorities - No to Yesterday\" was part of 2016 Boston Sci Fi festival. Through FBC he also produced, directed, wrote and acted in the web series' The Battle Below & the upcoming Legacy Breed. Bruce is a graduate of the original High School of Performing Arts in New York and Carnegie-Mellon.","name":"Bruce Faulk","primary":true}}]}}}}