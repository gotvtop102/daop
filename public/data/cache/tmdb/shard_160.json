words":[{"id":1664,"name":"eroticism"},{"id":156580,"name":"ghost story"}]}},"person_1185786_translations":{"at":1774211357400,"data":{"id":1185786,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Liu ShiShi (Cecilia Liu) graduated from Beijing Dance Academy, major in Ballet. During her college time, she once had a opportunity to play a role in a TV series. It was that chance that open a new path for the ballerina's future. Upon her graduation from the Academy, she decided to choose acting as her career.\n\nShiShi is best known for her role as RuoXi in Chinese period drama Scarlet Heart, 2011. Due to the great success of this TV series and her great performance during and after Scarlet Heart, she was named as one of the \"Chinese Four Promising Young Famale actresses\" by the famous Chinese paper-media Nan Du Entertainment Weekly in 2013.\n\nLiu ShiShi has been married to Taiwanese actor Nicky Wu on Jan 20th 2015, whom she met on the set of Scarlet Heart in 2011.\n\nNow ShiShi is focusing on big screen, preferring roles that realistic complex, challenging and nurturing.","name":"Liu Shishi","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"류시시","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"刘诗诗（1987年3月10日－），本名刘诗施，回族，中国大陆知名女演员，毕业于北京舞蹈学院芭蕾舞系02级本科班。2004年因出演电视剧《月影风荷》步入演艺圈。2007年正式签约经纪公司，先后出演《射雕英雄传》、《仙剑奇侠传三》、《天涯织女》、《怪侠一枝梅》等多部电视剧。2011年因主演《步步惊心》走红。之后她开始进军大银幕，拍摄了《不二神探》、《回到爱开始的地方》、《绣春刀》、《深夜前的五分钟》、《心理罪之城市之光》等电影作品。","name":"刘诗诗","primary":true}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"Lưu Thi Thi là một nữ diễn viên người Trung Quốc. Cô tốt nghiệp khoa múa ba lê của Học viện múa Bắc Kinh, nhưng sau đó cô chuyển hướng trở thành diễn viên và thành công với vai diễn Mã Nhĩ Thái Nhược Hy trong Bộ bộ kinh tâm, bộ phim truyền hình mà cô đóng cặp với Ngô Kỳ Long.","name":"Lưu Thi Thi","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"劉詩詩","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Лю Ши Ши","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"劉詩詩（1987 年 3 月 10 日－），本名劉詩施，回族，中國大陸知名女演員，畢業於北京舞蹈學院芭蕾舞系 02 級本科班。2004 年因出演電視劇《月影風荷》步入演藝圈。2007 年正式簽約經紀公司，先後出演《射鵰英雄傳》、《仙劍奇俠傳三》、《天涯織女》、《怪俠一枝梅》等多部電視劇。2011 年因主演《步步驚心》走紅。之後她開始進軍大銀幕，拍攝了《不二神探》、《回到愛開始的地方》、《繡春刀》、《深夜前的五分鐘》、《心理罪之城市之光》等電影作品。","name":"劉詩詩","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"หลิวซือซือ","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}}]}},"person_2202330_translations":{"at":1774211359394,"data":{"id":2202330,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Erol Yavan","primary":false}},{"iso_3166_1":"TR","iso_639_1":"tr","name":"Türkçe","english_name":"Turkish","data":{"biography":"","name":"Erol Yavan","primary":true}}]}},"movie_759608_detail_vi-VN":{"at":1774211360535,"data":{"adult":false,"backdrop_path":"/tGJqbzpefX249Qsk2GUAp5inOHk.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Phim Tài Liệu"}],"homepage":"","id":759608,"imdb_id":"tt14663504","origin_country":["GB"],"original_language":"en","original_title":"Cristiano Ronaldo: The One and Only","overview":"Là chủ nhân của 5 Quả Bóng Vàng và 4 Chiếc Giày Vàng, Ronaldo không chỉ là một trong những cầu thủ xuất sắc nhất mà còn là biểu tượng truyền cảm hứng về sự nỗ lực không ngừng nghỉ để chạm đến ước mơ.","popularity":0.2781,"poster_path":"/jZw30RB2JPEdeNzVXoq6eNg9gp3.jpg","production_companies":[{"id":9286,"logo_path":"/pT1nP1IVtabim8LSXP5qNZk6pYY.png","name":"The Orchard","origin_country":"US"}],"production_countries":[{"iso_3166_1":"US","name":"United States of America"}],"release_date":"2020-02-04","revenue":0,"runtime":63,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"","title":"Cristiano Ronaldo: Bàn Chân Vàng","video":false,"vote_average":7.4,"vote_count":5}},"person_1079119_translations":{"at":1774211383035,"data":{"id":1079119,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Liu Mintao","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"刘敏涛，1976年1月10日出生于山东省烟台市，毕业于中央戏剧学院，中国内地女演员。\n\n1992年，刘敏涛首次出演电影《祝你好运》。1997年主演历史传奇剧《凤阳小子朱元璋》。1999年出演人物传记题材剧《朱德元帅》。2000年领衔主演百集电视剧《新编聊斋》的第一部《人鬼情缘》。2002年在电视剧《冬至》中饰演反一号。2004年参演孔笙执导的《前门楼子九丈九》。2005年主演古装探案剧《大宋提刑官2》。2006年主演电视剧《福贵》。2011年5月12日主演纪念汶川地震的电影《北川重生》上映。2012年6月21日参演的悬疑电影《黑暗中的救赎》上映，同年参演电视剧《向幸福前进》。2013年领衔主演励志温情剧《守婚》。2014年4月18日荣获得第1届中国电视演员形象榜演员行业形象金榜。2015年8月31日出演的民国谍战悬疑剧《伪装者》在湖南卫视金鹰独播剧场播出。同年参演电视剧《琅琊榜》。2016年主演都市情感励志剧《因为遇见你》 。2017年特别出演古装传奇剧《凰权·弈天下》。2018年2月，参演民国传奇剧《南烟斋笔录》。","name":"刘敏涛","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"劉敏濤","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Lưu Mẫn Đào","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"劉敏濤，1976 年 1 月 10 日出生於山東省煙台市，畢業於中央戲劇學院，中國內地女演員。\n\n1992 年，劉敏濤首次出演電影《祝你好運》。1997 年主演歷史傳奇劇《鳳陽小子朱元璋》。1999 年出演人物傳記題材劇《朱德元帥》。2000 年領銜主演百集電視劇《新編聊齋》的第一部《人鬼情緣》。2002 年在電視劇《冬至》中飾演反一號。2004 年參演孔笙執導的《前門樓子九丈九》。2005 年主演古裝探案劇《大宋提刑官 2》。2006 年主演電視劇《福貴》。2011 年 5 月 12 日主演紀念汶川地震的電影《北川重生》上映。2012 年 6 月 21 日參演的懸疑電影《黑暗中的救贖》上映，同年參演電視劇《向幸福前進》。2013 年領銜主演勵志温情劇《守婚》。2014 年 4 月 18 日榮獲得第 1 屆中國電視演員形象榜演員行業形象金榜。2015 年 8 月 31 日出演的民國諜戰懸疑劇《偽裝者》在湖南衞視金鷹獨播劇場播出。同年參演電視劇《琅琊榜》。2016 年主演都市情感勵志劇《因為遇見你》 。2017 年特別出演古裝傳奇劇《凰權·弈天下》。2018 年 2 月，參演民國傳奇劇《南煙齋筆錄》。","name":"劉敏濤","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Лю Минь Тао","primary":false}}]}},"tv_314827_detail_vi-VN":{"at":1774211384613,"data":{"adult":false,"backdrop_path":"/p5Ph00SkahKcJHyi0bA2B3QwmqK.jpg","created_by":[],"episode_run_time":[],"first_air_date":"2026-02-25","genres":[{"id":18,"name":"Phim Chính Kịch"}],"homepage":"https://v.qq.com/x/cover/mzc00200c7e0k1b.html","id":314827,"in_production":false,"languages":["zh"],"last_air_date":"2026-03-04","last_episode_to_air":{"id":6982927,"name":"Episode 23","overview":"","vote_average":0,"vote_count":0,"air_date":"2026-03-04","episode_number":23,"episode_type":"finale","production_code":"","runtime":null,"season_number":1,"show_id":314827,"still_path":null},"name":"枕红妆","next_episode_to_air":null,"networks":[{"id":2007,"logo_path":"/6Lfll43wYG2eyereOBjpYFRSGs4.png","name":"Tencent Video","origin_country":"CN"}],"number_of_episodes":23,"number_of_seasons":1,"origin_country":["CN"],"original_language":"zh","original_name":"枕红妆","overview":"","popularity":0.738,"poster_path":"/3O2Fij9fgITIaK14OO7DsW6ZZZ4.jpg","production_companies":[],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"seasons":[{"air_date":"2026-02-25","episode_count":23,"id":502080,"name":"Season 1","overview":"","poster_path":null,"season_number":1,"vote_average":0}],"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Ended","tagline":"","type":"Scripted","vote_average":0,"vote_count":0}},"person_2864044_translations":{"at":1774211393009,"data":{"id":2864044,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_na