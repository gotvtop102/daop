},"person_1541932_translations":{"at":1774698740020,"data":{"id":1541932,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"刘以豪（Jasper Liu），1986年8月12日出生于台湾，中国台湾男演员，独立乐团“轻晨电”的团长兼吉他手，毕业于大叶大学视觉传达设计系。\n\n2008年，参加“新光三越超级男模大赛”，获得总决赛第三名，从而正式进入演艺圈。2011年，出演个人首部电视剧《我可能不会爱你》 。2012年，担任郭采洁演唱歌曲《该忘了》的MV男主角 。2013年，主演台湾偶像剧《没有名字的甜点店》，在剧中饰演男主角Allen侯衍任 。2014年，主演台湾偶像剧《喜欢一个人》；同年，担任杨丞琳演唱歌曲《点水》的MV男主角。2015年，主演台湾偶像剧《他看她的第二眼》。2016年，担任动画电影《樱桃小丸子：来自意大利的少年》台湾版的配音工作，为男主角安德烈配音；同年，获得第11届首尔国际电视节亚洲明星奖 。2017年，主演都市爱情偶像剧《玛丽苏遇上杰克苏》，从而正式进军中国内地荧屏；同年，在年代剧《台湾往事》中饰演男主角林清文 。2018年，主演浪漫爱情电影《比悲伤更悲伤的故事》；10月5日，获得釜山电影节亚洲之星大赏亚洲面孔奖；11月28日，获得亚洲明星盛典最佳选择奖（AAA Choice赏）；12月22日，获得首届“星和璀璨星光夜”魅力闪亮之星奖。2019年，主演都市剧《极道千金》。","name":"刘以豪","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Jasper Liu Yi Hao is a Taiwanese actor, model, and musician. From 2009 to 2016, Liu was a member of the electronic post-rock band 輕晨電Morning Call, playing guitar and backup vocals. He released his debut extended play U on September 4, 2020. Liu started as a model before crossing over to acting and gained popularity in Taiwan, Hong Kong, Korea, and Japan. He is referred to as \"Taiwanese Rain\" by the Taiwanese media due to his resemblance to the Korean star Rain. His other nicknames are \"Village Chief of Broccoli Village\" because his curly hair resembles the top of a broccoli head. Also with his sunshine smile and dimples, he is named \"Taiwan's most adorable boyfriend\" by the media.","name":"Jasper Liu","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"劉以豪","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Джаспер Лю","primary":false}},{"iso_3166_1":"IR","iso_639_1":"fa","name":"فارسی","english_name":"Persian","data":{"biography":"","name":"جسپر لیو","primary":false}},{"iso_3166_1":"ID","iso_639_1":"id","name":"Bahasa indonesia","english_name":"Indonesian","data":{"biography":"","name":"Jasper Liu","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"류이하오","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Jasper Liu","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"劉以豪（Jasper Liu），1986 年 8 月 12 日出生於台灣，台灣男演員，獨立樂團“輕晨電”的團長兼吉他手，畢業於大葉大學視覺傳達設計系。\n\n2008 年，參加“新光三越超級男模大賽”，獲得總決賽第三名，從而正式進入演藝圈。2011 年，出演個人首部電視劇《我可能不會愛你》 。2012 年，擔任郭採潔演唱歌曲《該忘了》的 MV 男主角 。2013 年，主演台灣偶像劇《沒有名字的甜點店》，在劇中飾演男主角 Allen 侯衍任 。2014 年，主演台灣偶像劇《喜歡一個人》；同年，擔任楊丞琳演唱歌曲《點水》的 MV 男主角。2015 年，主演台灣偶像劇《他看她的第二眼》。2016 年，擔任動畫電影《櫻桃小丸子：來自義大利的少年》台灣版的配音工作，為男主角安德烈配音；同年，獲得第 11 屆首爾國際電視節亞洲明星獎 。2017 年，主演都市愛情偶像劇《瑪麗蘇遇上傑克蘇》，從而正式進軍中國內地熒屏；同年，在年代劇《台灣往事》中飾演男主角林清文 。2018 年，主演浪漫愛情電影《比悲傷更悲傷的故事》；10 月 5 日，獲得釜山電影節亞洲之星大賞亞洲面孔獎；11 月 28 日，獲得亞洲明星盛典最佳選擇獎（AAA Choice 賞）；12 月 22 日，獲得首屆“星和璀璨星光夜”魅力閃亮之星獎。2019 年，主演都市劇《極道千金》。","name":"劉以豪","primary":false}}]}},"person_5994183_translations":{"at":1774698747588,"data":{"id":5994183,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Wang Hongzhe","primary":false}}]}},"person_1844024_translations":{"at":1774698751357,"data":{"id":1844024,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Cres Chuang","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"莊益增","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"庄益增","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"莊益增","primary":false}}]}},"tv_281016_credits":{"at":1774698751928,"data":{"cast":[{"adult":false,"gender":1,"id":1875840,"known_for_department":"Acting","name":"JISOO","original_name":"지수","popularity":3.6929,"profile_path":"/23qpgi6fFBjybTuIcKItQBEINb5.jpg","character":"Seo Mi-rae","credit_id":"6777a35182cce15a76749c82","order":0},{"adult":false,"gender":2,"id":1255411,"known_for_department":"Acting","name":"Seo In-guk","original_name":"서인국","popularity":4.3808,"profile_path":"/qXsdm6uDD3Je6JW9VfgCdg4FqYq.jpg","character":"Park Kyeong-nam","credit_id":"6777a3565ac1bd826166815b","order":1},{"adult":false,"gender":1,"id":2288847,"known_for_department":"Acting","name":"Gong Min-jeung","original_name":"공민정","popularity":2.4536,"profile_path":"/wkUiwCHq2Z2h4A7JDlhjrVGQiCk.jpg","character":"Yoon Song","credit_id":"68074079c3e8e74b6dee823e","order":2},{"adult":false,"gender":2,"id":1203792,"known_for_department":"Acting","name":"Cho Han-cheul","original_name":"조한철","popularity":2.5561,"profile_path":"/58DGEXFyWfaFdqL7yKKW0VdEg3R.jpg","character":"Hwang Byung-hak","credit_id":"699e50b5c0ffcd7b8be85bc6","order":3}],"crew":[{"adult":false,"gender":2,"id":2790898,"known_for_department":"Directing","name":"Kim Jung-sik","original_name":"김정식","popularity":0.9076,"profile_path":"/dRzFunqNZgzYR8zZODAUHgn81ey.jpg","credit_id":"699e56721c55668b0aff443c","department":"Directing","job":"Director"},{"adult":false,"gender":0,"id":5990070,"known_for_department":"Creator","name":"Namgung Do-young","original_name":"남궁도영","popularity":0.4244,"profile_path":null,"credit_id":"699e5689014c66ef1ef22939","department":"Writing","job":"Writer"},{"adult":false,"gender":1,"id":4374338,"known_for_department":"Directing","name":"Kim A-young","original_name":"김아영","popularity":0.1165,"profile_path":null,"credit_id":"699e5bb2e171611dfcf22961","department":"Production","job":"Executive Producer"}],"id":281016}},"person_62001_translations":{"at":1774698752071,"data":{"id":62001,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Dee Wallace (born 14 December 1948) is an American actress and comedienne. She is perhaps best known for her roles in several popular films. These include the starring role as Elliot's mother in the Steven Spielberg film E.T. the Extra-Terrestrial (1982), her most widely seen role. She also played key roles in popular cult films The Hills Have Eyes (1977) and The Howling (1981) and appeared in The Stepford Wives in 1975 and 10 (1979). In total, Wallace has appeared in more than 85 films.","name":"Dee Wallace","primary":true}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"Deanna Wallace, conhecida pelos nomes artísticos de Dee Wallace ou Dee Wallace Stone, é uma atriz norte-americana. Wallace, cujo nome de batismo é Deanna Bowers, é filha de Robert Stanley Bowers com Maxine Nichols.","name":"","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Dee Wallace-Stone (* 14. Dezember 1949 in Kansas City, Kansas als Deanna Bowers) ist eine US-amerikanische Schauspielerin.\n\nIhre Schauspielkarriere begann sie mit kleineren Kinorollen sowie Gastauftritten in verschiedenen Fernsehserien wie Die Straßen von San Francisco, Hart aber herzlich, Starsky & Hutch und CHiPs. 1977 gelang es ihr, mit einer Nebenrolle in Wes Cravens Horrorfilm Hügel der blutigen Augen schauspielerisch auf sich aufmerksam zu machen.\n\nEinem weltweiten Publikum wurde sie 1982 bekannt, als sie in dem Steven-Spielberg-Film E.T. – Der Außerirdische die Rolle von Elliotts alleinerziehender Mutter Mary verkörperte. Für diesen Auftritt wurde sie 1983 für den Saturn Award nominiert. In diese Zeit fallen auch weitere Hauptrollen in einigen bekannten Horrorfilmen: So war sie unter anderem in Joe Dantes Werwolfsfilm Das Tier (1981), in der Stephen-King-Verfilmung Cujo (1983) und in Stephen Hereks Critters – Sie sind da! (1986) über feindliche Außerirdische zu sehen. Mit ihrem Auftritt in Peter Jacksons Horrorkomödie The Frighteners nahm sie 1996 ihren Status als bekannte Schauspielerin des Horrorgenres aufs Korn. Auch im neuen Jahrtausend blieb sie dem Horrorgenre treu und unternahm etwa Auftritte in mehreren Filmen unter Regie von Rob Zombie, darunter das Halloween-Remake von 2007 und 3 from Hell (2019).\n\nAbseits des Horrorgenres spielte Wallace-Stone eine der Hauptrollen in der von 1989 bis 1992 produzierten Familienserie The New Lassie. Sie übernahm auch Gastrollen in beliebten Serien wie Mord ist ihr Hobby, Supernatural, Navy CIS, Bones – Die Knochenjägerin, Criminal Minds und Grey’s Anatomy. An den Erfolg von ihren Horrorfilmen und E.T. konnte sie allerdings nicht immer anknüpfen, so drehte sie auch viele zweit- und drittklassige Filme. Insgesamt stand Wallace bisher für rund 250 Film- und Fernsehproduktionen vor der Kamera (Stand 2020).","name":"","primary":false}},{"iso_3166_1":"AT","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Dee Wallace-Stone (* 14. Dezember 1949 in Kansas City, Kansas als Deanna Bowers) ist eine US-amerikanische Schauspielerin.\n\nIhre Schauspielkarriere begann sie mit kleineren Kinorollen sowie Gastauftritten in verschiedenen Fernsehserien wie Die Straßen von San Francisco, Hart aber herzlich, Starsky & Hutch und CHiPs. 1977 gelang es ihr, mit einer Nebenrolle in Wes Cravens Horrorfilm Hügel der blutigen Augen schauspielerisch auf sich aufmerksam zu machen.\n\nEinem weltweiten Publikum wurde sie 1982 bekannt, als sie in dem Steven-Spielberg-Film E.T. – Der Außerirdische die Rolle von Elliotts alleinerziehender Mutter Mary verkörperte. Für diesen Auftritt wurde sie 1983 für den Saturn Award nominiert. In diese Zeit fallen auch weitere Hauptrollen in einigen bekannten Horrorfilmen: So war sie unter anderem in Joe Dantes Werwolfsfilm Das Tier (1981), in der Stephen-King-Verfilmung Cujo (1983) und in Stephen Hereks Critters – Sie sind da! (1986) über feindliche Außerirdische zu sehen. Mit ihrem Auftritt in Peter Jacksons Horrorkomödie The Frighteners nahm sie 1996 ihren Status als bekannte Schauspielerin des Horrorgenres aufs Korn. Auch im neuen Jahrtausend blieb sie dem Horrorgenre treu und unternahm etwa Auftritte in mehreren Filmen unter Regie von Rob Zombie, darunter das Halloween-Remake von 2007 und 3 from Hell (2019).\n\nAbseits des Horrorgenres spielte Wallace-Stone eine der Hauptrollen in der von 1989 bis 1992 produzierten Familienserie The New Lassie. Sie übernahm auch Gastrollen in beliebten Serien wie Mord ist ihr Hobby, Supernatural, Navy CIS, Bones – Die Knochenjägerin, Criminal Minds und Grey’s Anatomy. An den Erfolg von ihren Horrorfilmen und E.T. konnte sie allerdings nicht immer anknüpfen, so drehte sie auch viele zweit- und drittklassige Filme. Insgesamt stand Wallace bisher für rund 250 Film- und Fernsehproduktionen vor der Kamera (Stand 2020).","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"迪·華勒斯","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"迪·华莱士（Dee Wallace，1948年12月14日-），美国女演员、喜剧演员。","name":"迪·华莱士","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"ディー・ウォレス","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"디 월리스","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"迪·華萊士（Dee Wallace，1948 年 12 月 14 日-），美國女演員、喜劇演員。","name":"迪·華勒斯","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Ди Уоллес","primary":false}}]}},"movie_1470130_keywords":{"at":1774718578395,"data":{"id":1470130,"keywords":[{"id":4225,"name":"night shift"},{"id":41645,"name":"based on video game"},{"id":162335,"name":"mortuary"},{"id":256183,"name":"supernatural horror"},{"id":295907,"name":"psychological horror"}]}}}}