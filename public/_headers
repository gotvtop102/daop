/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

/css/*
  Cache-Control: public, max-age=604800, must-revalidate

/js/*
  Cache-Control: public, max-age=604800, must-revalidate

/images/*
  Cache-Control: public, max-age=604800, must-revalidate

# JS tại /data/*.js (movies-light, actors-index, …). Thư mục con có rule riêng (ver, index, search, …).
/data/*.js
  Cache-Control: public, max-age=3600, must-revalidate

# Phiên bản từng shard (chỉ Cloudflare Pages); trình duyệt không cache để luôn đọc etag mới.
/data/ver/*
  Cache-Control: no-store

/data/cdn.json
  Cache-Control: public, max-age=300, must-revalidate

/data/movies-manifest.json
  Cache-Control: public, max-age=300, must-revalidate

/data/index/*
  Cache-Control: public, max-age=3600, must-revalidate

/data/search/*
  Cache-Control: public, max-age=3600, must-revalidate

/data/actors-*.js
  Cache-Control: public, max-age=3600, must-revalidate

/data/actors-*.json
  Cache-Control: public, max-age=3600, must-revalidate

/data/actors-index.json
  Cache-Control: public, max-age=3600, must-revalidate

/data/filters.js
  Cache-Control: public, max-age=3600, must-revalidate

/data/filters.json
  Cache-Control: public, max-age=3600, must-revalidate

/data/lists/*
  Cache-Control: public, max-age=3600, must-revalidate

/data/config/*.json
  Cache-Control: public, max-age=3600

/data/home/*.json
  Cache-Control: public, max-age=3600

/data/build_version.json
  Cache-Control: public, max-age=60
