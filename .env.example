# ========== OPhim API ==========
OPHIM_BASE_URL=https://ophim1.com/v1/api
# Giới hạn build (tránh treo/chạy quá lâu): OPHIM_MAX_PAGES (0=all), OPHIM_MAX_MOVIES (0=all), OPHIM_FETCH_TIMEOUT_MS (ms, mặc định 25000)
# OPHIM_MAX_PAGES=5
# OPHIM_MAX_MOVIES=500

# ========== TMDB API (lấy key tại https://www.themoviedb.org/settings/api) ==========
# Một key hoặc nhiều key (phẩy): khi TMDB trả 429, build thử key tiếp theo.
TMDB_API_KEY=your_tmdb_api_key
# Hoặc tách riêng list (ghi đè nếu đặt): TMDB_API_KEYS=key_a,key_b
# Cache TMDB trên disk (public/data/cache/tmdb) — không commit thư mục này (đã .gitignore).
# TMDB_CACHE=0 tắt hoàn toàn (mỗi build gọi API đầy đủ).
# TMDB_CACHE_PRUNE=1 (mặc định) chỉ lưu field enrich cần; =0 lưu full JSON (dễ debug, nặng).
# TMDB_CACHE_GZIP=1 (mặc định) nén shard; =0 ghi JSON thuần (tương thích đọc cũ).
# TTL ngày (1–365; sai/missing → 7). CI chạy đều có thể giảm xuống 3–5 để dọn entry cũ nhanh hơn.
# TMDB_CACHE_TTL_DAYS=7
# Số file shard 1–256 (mặc định 200). Catalog rất lớn: thử 256 để mỗi file nhỏ hơn.
# TMDB_CACHE_SHARDS=200

# ========== Supabase Admin Core (project Admin - Org A; KHÔNG chứa movies/movie_episodes) ==========
SUPABASE_ADMIN_URL=https://xxxx-admin.supabase.co
SUPABASE_ADMIN_SERVICE_ROLE_KEY=your_admin_service_role_key

# ========== Supabase Movies (project Movies - Org B; chỉ bảng movies) ==========
SUPABASE_MOVIES_URL=https://xxxx-movies.supabase.co
SUPABASE_MOVIES_SERVICE_ROLE_KEY=your_movies_service_role_key

# ========== Supabase Episodes (project Episodes - Org B; chỉ bảng movie_episodes) ==========
SUPABASE_EPISODES_URL=https://xxxx-episodes.supabase.co
SUPABASE_EPISODES_SERVICE_ROLE_KEY=your_episodes_service_role_key

# API phim / build / export sẽ đọc Movies + Episodes project; không thay bằng anon key.
# Script npm run export-to-supabase: đẩy batch build → Movies + Episodes. EXPORT_TO_SUPABASE_SCOPE=all|custom
# Mặc định chỉ upsert + đồng bộ tập khi phim mới hoặc modified khác DB. EXPORT_TO_SUPABASE_ALWAYS_FULL=1 để full sync mọi lần.

# ========== Supabase User (chỉ dùng trên frontend - anon key) ==========
# Frontend dùng biến này qua config từ site-settings
SUPABASE_USER_URL=https://yyyy.supabase.co
SUPABASE_USER_ANON_KEY=your_anon_key

# ========== Ảnh trong repo + jsDelivr (public/thumbs|posters/{shard}/{slug}.webp) ==========
IMAGE_CDN_BASE=https://cdn.jsdelivr.net/gh/gotvtop102/goimg102
# Ref @… trên URL: để trống IMAGE_CDN_REF → dùng commit (IMAGE_REPO_COMMIT, CDN_JS_DELIVR_COMMIT, GITHUB_SHA, git HEAD) nếu có, không thì main.
# IMAGE_CDN_REF=main
# Commit đúng repo goimg102 (bắt buộc khuyến nghị khi repo site ≠ repo ảnh):
# IMAGE_REPO_COMMIT=   # SHA sau khi push goimg102 — cập nhật ver.thumbRef/posterRef khi ảnh đổi
IMAGE_PATH_PREFIX=public

# ========== JSON phim trên jsDelivr (repo pjs102: pubjs/{shard}/{slug}.json) — không commit pubjs-output ==========
PUBJS_CDN_BASE=https://cdn.jsdelivr.net/gh/gotvtop102/pjs102
# Đẩy lên pjs102: npm run push-pubjs-repo (cần PUBJS_REPO + token). Sau push, SHA mới gán cho phim vừa sửa.
# PUBJS_REPO=owner/pjs102
# Token: IMAGES_TOKEN hoặc GITHUB_TOKEN / GH_PAT (chung với repo ảnh)
# PUBJS_BRANCH=main
# Tuỳ chọn: PUBJS_CDN_REF=main | PUBJS_REPO_COMMIT=<sha> (local / không dùng push-pubjs-repo)
# PUBJS_PATH_PREFIX=pubjs
# CDN_JS_DELIVR_COMMIT=
# Thư mục local khi build (mặc định pubjs-output).
# PUBJS_OUTPUT_DIR=pubjs-output

# ========== Batch core (P2-1) — cân số file batch vs kích thước mỗi request lazy load ==========
# BASE_BATCH_SIZE: số phim mục tiêu mỗi cửa sổ (10–1000, mặc định 120). Tăng → ít file hơn, mỗi file thường nặng hơn (tới trần byte).
# BATCH_MAX_BYTES: trần kích thước file batch core JSON (50000–2000000, mặc định 300000). Vượt → tách cửa sổ nhỏ hơn.
# Catalog ~100k: thử tăng dần (vd. 160–240) + giữ hoặc tăng BATCH_MAX_BYTES; đo [TIMING] writeBatches + tải trang thật.
# BASE_BATCH_SIZE=120
# BATCH_MAX_BYTES=300000

# ========== Index / search prefix (build) — giảm dung lượng khi catalog rất lớn ==========
# SHARD_MAX_BYTES: trần mỗi file shard slug + idIndex + search prefix (50000–2000000, mặc định 300000).
# Catalog lớn: đo kích thước file sau build; nếu log [P2-1] Shard vượt… thì tăng dần hoặc giảm payload search.
# SHARD_MAX_BYTES=300000
# SEARCH_PREFIX_MIN_TOKEN_LEN: độ dài tối thiểu token (1–20, mặc định 2).
# SEARCH_PREFIX_MAX_TOKENS: tối đa từ/phim gán vào prefix (0 = không cắt; 1–500). Catalog lớn: thử 32–64.
# SEARCH_PREFIX_MIN_TOKEN_LEN=2
# SEARCH_PREFIX_MAX_TOKENS=0

# ========== GitHub (trigger Actions + repo chứa code) ==========
GITHUB_TOKEN=your_github_personal_token
GITHUB_REPO=username/repo-name
GITHUB_BRANCH=main

# ========== Repo GitHub chỉ lưu ảnh (public/thumbs, public/posters, …) — tuỳ chọn ==========
# GitHub Actions: tên secret không được bắt đầu bằng GITHUB_ — dùng IMAGES_REPO / IMAGES_TOKEN / IMAGES_BRANCH trong Settings → Secrets.
# Khi đặt: API /api/upload-image, /api/movies (ảnh) và workflow push ảnh lên repo này (push-images-to-assets-repo.js).
# Bỏ trống IMAGES_*: ảnh dùng chung GITHUB_REPO + GITHUB_TOKEN (tương thích cũ).
# IMAGES_TOKEN=   # tuỳ chọn — mặc định GITHUB_TOKEN
# IMAGES_BRANCH=main
IMAGES_REPO=gotvtop102/goimg102
