VITE_SUPABASE_ADMIN_URL=https://xxxx.supabase.co
VITE_SUPABASE_ADMIN_ANON_KEY=your_anon_key

# TMDB API Key (dùng cho chức năng thêm phim từ TMDB; tên phim/overview ưu tiên bản tiếng Việt từ TMDB)
VITE_TMDB_API_KEY=your_tmdb_api_key

# Bắt buộc khi chạy Admin local (npm run dev): URL deploy có API serverless (Vercel).
# Vite proxy /api → URL này; không có sẽ 404 khi gọi /api/movies, Build, GitHub Actions, v.v.
# Khi admin deploy cùng domain với API có thể để trống.
VITE_API_URL=https://your-project.vercel.app

# VITE_MOVIES_SOURCE=supabase (tuỳ chọn; Admin/API dùng Supabase)
