VITE_SUPABASE_ADMIN_URL=https://xxxx.supabase.co
VITE_SUPABASE_ADMIN_ANON_KEY=your_anon_key

# TMDB API Key (dùng cho chức năng thêm phim từ TMDB)
VITE_TMDB_API_KEY=your_tmdb_api_key

# Google Cloud Translation API Key (dùng để dịch tên đạo diễn/diễn viên sang tiếng Việt)
# Lấy tại: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key

# Chỉ khi chạy Admin local: URL Admin đã deploy (để nút Build website gọi đúng API)
VITE_API_URL=https://your-admin.vercel.app
